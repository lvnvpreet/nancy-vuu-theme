{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-schema-markup-{{ ai_gen_id }} {
    display: none;
  }
{% endstyle %}

<div class="ai-schema-markup-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{{ block.settings.schema_type }}",
      "name": "{{ block.settings.business_name }}",
      "url": "{{ block.settings.business_url }}",
      {% if block.settings.logo_image %}
        "logo": "{{ block.settings.logo_image | image_url }}",
      {% endif %}
      {% if block.settings.featured_image %}
        "image": "{{ block.settings.featured_image | image_url }}",
      {% endif %}
      {% if block.settings.street_address != blank or block.settings.city != blank %}
        "address": {
          "@type": "PostalAddress"
          {% if block.settings.street_address != blank %}
            ,"streetAddress": "{{ block.settings.street_address }}"
          {% endif %}
          {% if block.settings.city != blank %}
            ,"addressLocality": "{{ block.settings.city }}"
          {% endif %}
          {% if block.settings.state != blank %}
            ,"addressRegion": "{{ block.settings.state }}"
          {% endif %}
          {% if block.settings.postal_code != blank %}
            ,"postalCode": "{{ block.settings.postal_code }}"
          {% endif %}
          {% if block.settings.country != blank %}
            ,"addressCountry": "{{ block.settings.country }}"
          {% endif %}
        },
      {% endif %}
      {% if block.settings.service_area_1 != blank or block.settings.service_area_2 != blank or block.settings.service_area_3 != blank or block.settings.service_area_4 != blank or block.settings.service_area_5 != blank %}
        "serviceArea": [
          {% if block.settings.service_area_1 != blank %}
            {"@type": "City", "name": "{{ block.settings.service_area_1 }}"}
          {% endif %}
          {% if block.settings.service_area_2 != blank %}
            ,{"@type": "City", "name": "{{ block.settings.service_area_2 }}"}
          {% endif %}
          {% if block.settings.service_area_3 != blank %}
            ,{"@type": "City", "name": "{{ block.settings.service_area_3 }}"}
          {% endif %}
          {% if block.settings.service_area_4 != blank %}
            ,{"@type": "City", "name": "{{ block.settings.service_area_4 }}"}
          {% endif %}
          {% if block.settings.service_area_5 != blank %}
            ,{"@type": "City", "name": "{{ block.settings.service_area_5 }}"}
          {% endif %}
        ],
      {% endif %}
      {% if block.settings.offer_1_name != blank or block.settings.offer_2_name != blank %}
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "{{ block.settings.catalog_name }}",
          "itemListElement": [
            {% if block.settings.offer_1_name != blank %}
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "{{ block.settings.offer_1_name }}"
                  {% if block.settings.offer_1_description != blank %}
                    ,"description": "{{ block.settings.offer_1_description }}"
                  {% endif %}
                }
                {% if block.settings.offer_1_price != blank %}
                  ,"priceSpecification": {
                    "@type": "PriceSpecification",
                    "price": "{{ block.settings.offer_1_price }}",
                    "priceCurrency": "{{ block.settings.currency }}"
                  }
                {% endif %}
              }
            {% endif %}
            {% if block.settings.offer_2_name != blank %}
              ,{
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "{{ block.settings.offer_2_name }}"
                  {% if block.settings.offer_2_description != blank %}
                    ,"description": "{{ block.settings.offer_2_description }}"
                  {% endif %}
                }
                {% if block.settings.offer_2_price != blank %}
                  ,"priceSpecification": {
                    "@type": "PriceSpecification",
                    "price": "{{ block.settings.offer_2_price }}",
                    "priceCurrency": "{{ block.settings.currency }}"
                  }
                {% endif %}
              }
            {% endif %}
            {% if block.settings.offer_3_name != blank %}
              ,{
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "{{ block.settings.offer_3_name }}"
                  {% if block.settings.offer_3_description != blank %}
                    ,"description": "{{ block.settings.offer_3_description }}"
                  {% endif %}
                }
                {% if block.settings.offer_3_price != blank %}
                  ,"priceSpecification": {
                    "@type": "PriceSpecification",
                    "price": "{{ block.settings.offer_3_price }}",
                    "priceCurrency": "{{ block.settings.currency }}"
                  }
                {% endif %}
              }
            {% endif %}
          ]
        }
      {% endif %}
    }
  </script>
</div>

