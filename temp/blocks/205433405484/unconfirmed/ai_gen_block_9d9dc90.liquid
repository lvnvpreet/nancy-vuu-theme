{% doc %}
  @prompt
    Recreate the three colum editorial exactly the way it is but this time make the fonts Bodoni Moda (for title) and Manrope (for body) interchangeably. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-editorial-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-editorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-title-{{ ai_gen_id }} {
    font-family: 'Bodoni Moda', serif;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-editorial-text-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-editorial-link-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    display: inline-block;
    transition: opacity 0.3s ease;
  }

  .ai-editorial-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-editorial-column-{{ ai_gen_id }}:last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-editorial-column-{{ ai_gen_id }}:last-child {
      grid-column: auto;
    }

    .ai-editorial-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-editorial-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div class="ai-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'column_' | append: i | append: '_image'
          assign title_key = 'column_' | append: i | append: '_title'
          assign text_key = 'column_' | append: i | append: '_text'
          assign link_text_key = 'column_' | append: i | append: '_link_text'
          assign link_url_key = 'column_' | append: i | append: '_link_url'

          assign column_image = block.settings[image_key]
          assign column_title = block.settings[title_key]
          assign column_text = block.settings[text_key]
          assign column_link_text = block.settings[link_text_key]
          assign column_link_url = block.settings[link_url_key]
        %}

        <div class="ai-editorial-column-{{ ai_gen_id }}">
          <div class="ai-editorial-image-wrapper-{{ ai_gen_id }}">
            {% if column_image %}
              <img
                src="{{ column_image | image_url: width: 800 }}"
                alt="{{ column_image.alt | escape }}"
                loading="lazy"
                width="{{ column_image.width }}"
                height="{{ column_image.height }}"
                class="ai-editorial-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-editorial-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if column_title != blank %}
            <h3 class="ai-editorial-title-{{ ai_gen_id }}">{{ column_title }}</h3>
          {% endif %}

          {% if column_text != blank %}
            <div class="ai-editorial-text-{{ ai_gen_id }}">{{ column_text }}</div>
          {% endif %}

          {% if column_link_text != blank and column_link_url != blank %}
            <a href="{{ column_link_url }}" class="ai-editorial-link-{{ ai_gen_id }}">
              {{ column_link_text }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Three column editorial",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
