{% doc %}
  @prompt
    Create a contact form with the following: Header Content:
    
        Main Heading: Awaken Your Highest Self
    
        Subtext: Request an invitation to the Napa Sanctuary and begin the sacred preparation of your heart, mind, and couture for the covenant ahead.
    
    Initial Blocks to Generate:
    
        Text Field: 'The Muse (Full Name)'
    
        Email Field: 'The Connection (Email)'
    
        Phone Field: 'The Voice (Phone Number)'
    
        Date Field: 'The Covenant Date (Wedding Date)'
    
        Dropdown: 'Your Desired Path' (Options: I. The Becoming Bride, II. The Masterpiece Bride, III. The Unified Covenant, IV. The Matriarch & The Bride, V. The Masterpiece Collective)
    
        Large Text: 'The Vision: Please share the heart behind the woman you aspire to be as you stand at the altar—both in spirit and in style.'
    
        Large Text: 'The Soul’s Requirement: In this season of transition, what is the one thing your soul needs most before you say "I do"?'
    
        Text Field: 'How did the story of our bridal immersions first reach you?'
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bridal-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bridal-contact-form__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-bridal-contact-form__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-bridal-contact-form__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
  }

  .ai-bridal-contact-form__form-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-bridal-contact-form__field-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-bridal-contact-form__label-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-bridal-contact-form__input-{{ ai_gen_id }},
  .ai-bridal-contact-form__select-{{ ai_gen_id }},
  .ai-bridal-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background }};
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    transition: border-color 0.3s ease;
  }

  .ai-bridal-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-bridal-contact-form__select-{{ ai_gen_id }}:focus,
  .ai-bridal-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-bridal-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-bridal-contact-form__select-{{ ai_gen_id }} {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%230f0f0f' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  .ai-bridal-contact-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 500;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  .ai-bridal-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bridal-contact-form__success-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.success_background }};
    color: {{ block.settings.success_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    text-align: center;
    margin-bottom: 24px;
  }

  .ai-bridal-contact-form__error-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.error_background }};
    color: {{ block.settings.error_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-bridal-contact-form-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px;
    }

    .ai-bridal-contact-form__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-bridal-contact-form__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-bridal-contact-form__header-{{ ai_gen_id }} {
      margin-bottom: 32px;
    }

    .ai-bridal-contact-form__field-{{ ai_gen_id }} {
      margin-bottom: 24px;
    }
  }
{% endstyle %}

<bridal-contact-form-{{ ai_gen_id }}
  class="ai-bridal-contact-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-bridal-contact-form__header-{{ ai_gen_id }}">
    <h2 class="ai-bridal-contact-form__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
    <div class="ai-bridal-contact-form__subtext-{{ ai_gen_id }}">
      {{ block.settings.subtext }}
    </div>
  </div>

  {%- form 'contact' -%}
    <input type="hidden" name="contact[form_type]" value="bridal_immersion_inquiry">
    
    <div class="ai-bridal-contact-form__form-{{ ai_gen_id }}">
      {%- if form.posted_successfully? -%}
        <div
          id="ai-bridal-contact-form-success-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__success-{{ ai_gen_id }}"
        >
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div
          id="ai-bridal-contact-form-error-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__error-{{ ai_gen_id }}"
        >
          <p>{{ block.settings.error_message }}</p>
          {%- for field in form.errors -%}
            <p>{{ field | capitalize }}: {{ form.errors.messages[field] }}</p>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-name-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_name }}
        </label>
        <input
          type="text"
          id="ai-bridal-name-{{ ai_gen_id }}"
          name="contact[name]"
          class="ai-bridal-contact-form__input-{{ ai_gen_id }}"
          value="{{ form.name }}"
          required
          {% if form.errors contains 'name' %}
            aria-invalid="true"
            aria-describedby="ai-bridal-contact-form-error-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-email-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_email }}
        </label>
        <input
          type="email"
          id="ai-bridal-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-bridal-contact-form__input-{{ ai_gen_id }}"
          value="{{ form.email }}"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          required
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="ai-bridal-contact-form-error-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-phone-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_phone }}
        </label>
        <input
          type="tel"
          id="ai-bridal-phone-{{ ai_gen_id }}"
          name="contact[phone]"
          class="ai-bridal-contact-form__input-{{ ai_gen_id }}"
          value="{{ form.phone }}"
          autocomplete="tel"
        >
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-wedding-date-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_wedding_date }}
        </label>
        <input
          type="text"
          id="ai-bridal-wedding-date-{{ ai_gen_id }}"
          name="contact[wedding_date]"
          class="ai-bridal-contact-form__input-{{ ai_gen_id }}"
          placeholder="MM/DD/YYYY"
        >
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-path-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_path }}
        </label>
        <select
          id="ai-bridal-path-{{ ai_gen_id }}"
          name="contact[desired_path]"
          class="ai-bridal-contact-form__select-{{ ai_gen_id }}"
        >
          <option value="">Select your path</option>
          <option value="I. The Becoming Bride">I. The Becoming Bride</option>
          <option value="II. The Masterpiece Bride">II. The Masterpiece Bride</option>
          <option value="III. The Unified Covenant">III. The Unified Covenant</option>
          <option value="IV. The Matriarch & The Bride">IV. The Matriarch & The Bride</option>
          <option value="V. The Masterpiece Collective">V. The Masterpiece Collective</option>
        </select>
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-vision-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_vision }}
        </label>
        <textarea
          id="ai-bridal-vision-{{ ai_gen_id }}"
          name="contact[vision]"
          class="ai-bridal-contact-form__textarea-{{ ai_gen_id }}"
        ></textarea>
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-soul-requirement-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_soul_requirement }}
        </label>
        <textarea
          id="ai-bridal-soul-requirement-{{ ai_gen_id }}"
          name="contact[soul_requirement]"
          class="ai-bridal-contact-form__textarea-{{ ai_gen_id }}"
        ></textarea>
      </div>

      <div class="ai-bridal-contact-form__field-{{ ai_gen_id }}">
        <label
          for="ai-bridal-referral-{{ ai_gen_id }}"
          class="ai-bridal-contact-form__label-{{ ai_gen_id }}"
        >
          {{ block.settings.label_referral }}
        </label>
        <input
          type="text"
          id="ai-bridal-referral-{{ ai_gen_id }}"
          name="contact[referral_source]"
          class="ai-bridal-contact-form__input-{{ ai_gen_id }}"
        >
      </div>

      <button
        type="submit"
        class="ai-bridal-contact-form__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </button>
    </div>
  {%- endform -%}
</bridal-contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class BridalContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form) {
          form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const form = event.target;
        const requiredFields = form.querySelectorAll('[required]');
        let isValid = true;

        requiredFields.forEach(field => {
          if (!field.value.trim()) {
            isValid = false;
            field.setAttribute('aria-invalid', 'true');
          } else {
            field.removeAttribute('aria-invalid');
          }
        });

        if (!isValid) {
          event.preventDefault();
        }
      }
    }

    customElements.define('bridal-contact-form-{{ ai_gen_id }}', BridalContactForm{{ ai_gen_id }});
  })();
</script>

