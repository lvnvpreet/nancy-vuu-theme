{% doc %}
  @prompt
    Create a section that duplicates the layout of the "Atelier Inquiry" section but with these questions: Text Field: 'The Muse (Full Name)'
    
        Email Field: 'The Connection (Email)'
    
        Phone Field: 'The Voice (Phone Number)'
    
        Date Field: 'The Covenant Date (Wedding Date)'
    
        Dropdown: 'Your Desired Path' (Options: I. The Becoming Bride, II. The Masterpiece Bride, III. The Unified Covenant, IV. The Matriarch & The Bride, V. The Masterpiece Collective)
    
        Large Text: 'The Vision: Please share the heart behind the woman you aspire to be as you stand at the altar—both in spirit and in style.'
    
        Large Text: 'The Soul’s Requirement: In this season of transition, what is the one thing your soul needs most before you say "I do"?'
    
        Text Field: 'How did the story of our bridal immersions first reach you?' Give block space to answer the questions and use text Bodoni Moda  for title and Manrope for all other  text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bridal-inquiry-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bridal-inquiry-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-bridal-inquiry-title-{{ ai_gen_id }} {
    font-family: 'Bodoni Moda', serif;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    text-align: {{ block.settings.title_alignment }};
    line-height: 1.2;
  }

  .ai-bridal-inquiry-description-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.form_spacing }}px 0;
    text-align: {{ block.settings.title_alignment }};
    line-height: 1.6;
  }

  .ai-bridal-inquiry-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-bridal-inquiry-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-bridal-inquiry-label-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-bridal-inquiry-input-{{ ai_gen_id }},
  .ai-bridal-inquiry-select-{{ ai_gen_id }},
  .ai-bridal-inquiry-textarea-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    padding: {{ block.settings.input_padding }}px;
    width: 100%;
    transition: border-color 0.3s ease;
  }

  .ai-bridal-inquiry-input-{{ ai_gen_id }}:focus,
  .ai-bridal-inquiry-select-{{ ai_gen_id }}:focus,
  .ai-bridal-inquiry-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-bridal-inquiry-textarea-{{ ai_gen_id }} {
    min-height: {{ block.settings.textarea_height }}px;
    resize: vertical;
  }

  .ai-bridal-inquiry-select-{{ ai_gen_id }} {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%230f0f0f' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right {{ block.settings.input_padding }}px center;
    padding-right: calc({{ block.settings.input_padding }}px + 24px);
  }

  .ai-bridal-inquiry-button-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.button_size }}px;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: {{ block.settings.button_padding }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-bridal-inquiry-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bridal-inquiry-success-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.success_color }};
    margin-top: 16px;
    text-align: center;
  }

  .ai-bridal-inquiry-error-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.error_color }};
    margin-top: 8px;
  }

  @media screen and (max-width: 749px) {
    .ai-bridal-inquiry-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-bridal-inquiry-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-bridal-inquiry-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<bridal-inquiry-{{ ai_gen_id }} class="ai-bridal-inquiry-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bridal-inquiry-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-bridal-inquiry-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-bridal-inquiry-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {% form 'contact' %}
      <input type="hidden" name="contact[form_type]" value="bridal_inquiry">
      
      <div class="ai-bridal-inquiry-form-{{ ai_gen_id }}">
        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-name-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            The Muse (Full Name)
          </label>
          <input
            type="text"
            id="ai-bridal-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-bridal-inquiry-input-{{ ai_gen_id }}"
            required
            {% if form.errors %}
              aria-invalid="true"
            {% endif %}
          >
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-email-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            The Connection (Email)
          </label>
          <input
            type="email"
            id="ai-bridal-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-bridal-inquiry-input-{{ ai_gen_id }}"
            autocomplete="email"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-bridal-inquiry-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-bridal-inquiry-success-{{ ai_gen_id }}"
            {% endif %}
          >
          {% if form.errors %}
            <div id="ai-bridal-inquiry-error-{{ ai_gen_id }}" class="ai-bridal-inquiry-error-{{ ai_gen_id }}">
              {{ form.errors.messages.email }}
            </div>
          {% endif %}
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-phone-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            The Voice (Phone Number)
          </label>
          <input
            type="tel"
            id="ai-bridal-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-bridal-inquiry-input-{{ ai_gen_id }}"
            autocomplete="tel"
          >
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-wedding-date-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            The Covenant Date (Wedding Date)
          </label>
          <input
            type="text"
            id="ai-bridal-wedding-date-{{ ai_gen_id }}"
            name="contact[wedding_date]"
            class="ai-bridal-inquiry-input-{{ ai_gen_id }}"
            placeholder="MM/DD/YYYY"
          >
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-path-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            Your Desired Path
          </label>
          <select
            id="ai-bridal-path-{{ ai_gen_id }}"
            name="contact[desired_path]"
            class="ai-bridal-inquiry-select-{{ ai_gen_id }}"
            required
          >
            <option value="">Please select</option>
            <option value="I. The Becoming Bride">I. The Becoming Bride</option>
            <option value="II. The Masterpiece Bride">II. The Masterpiece Bride</option>
            <option value="III. The Unified Covenant">III. The Unified Covenant</option>
            <option value="IV. The Matriarch & The Bride">IV. The Matriarch & The Bride</option>
            <option value="V. The Masterpiece Collective">V. The Masterpiece Collective</option>
          </select>
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-vision-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            The Vision: Please share the heart behind the woman you aspire to be as you stand at the altar—both in spirit and in style.
          </label>
          <textarea
            id="ai-bridal-vision-{{ ai_gen_id }}"
            name="contact[vision]"
            class="ai-bridal-inquiry-textarea-{{ ai_gen_id }}"
          ></textarea>
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-soul-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            The Soul's Requirement: In this season of transition, what is the one thing your soul needs most before you say "I do"?
          </label>
          <textarea
            id="ai-bridal-soul-{{ ai_gen_id }}"
            name="contact[soul_requirement]"
            class="ai-bridal-inquiry-textarea-{{ ai_gen_id }}"
          ></textarea>
        </div>

        <div class="ai-bridal-inquiry-field-{{ ai_gen_id }}">
          <label for="ai-bridal-how-{{ ai_gen_id }}" class="ai-bridal-inquiry-label-{{ ai_gen_id }}">
            How did the story of our bridal immersions first reach you?
          </label>
          <input
            type="text"
            id="ai-bridal-how-{{ ai_gen_id }}"
            name="contact[how_found]"
            class="ai-bridal-inquiry-input-{{ ai_gen_id }}"
          >
        </div>

        <button type="submit" class="ai-bridal-inquiry-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>

        {% if form.posted_successfully? %}
          <div id="ai-bridal-inquiry-success-{{ ai_gen_id }}" class="ai-bridal-inquiry-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}
      </div>
    {% endform %}
  </div>
</bridal-inquiry-{{ ai_gen_id }}>

<script>
  (function() {
    class BridalInquiry{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.setupFormValidation();
        }
      }

      setupFormValidation() {
        const dateInput = this.querySelector('#ai-bridal-wedding-date-{{ ai_gen_id }}');
        if (dateInput) {
          dateInput.addEventListener('blur', function() {
            const value = this.value.trim();
            if (value && !value.match(/^\d{2}\/\d{2}\/\d{4}$/)) {
              this.setCustomValidity('Please use MM/DD/YYYY format');
            } else {
              this.setCustomValidity('');
            }
          });
        }
      }
    }

    customElements.define('bridal-inquiry-{{ ai_gen_id }}', BridalInquiry{{ ai_gen_id }});
  })();
</script>

