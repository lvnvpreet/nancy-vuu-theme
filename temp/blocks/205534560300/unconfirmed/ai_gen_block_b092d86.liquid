{% doc %}
  @prompt
    Create a bridal inquiry form with exact layout design and questions with added white space before the eyebrow.  Make the CTA Button "Request Invitation" actually submit the form. this should be build as a Contact form so I receive the submission to my email but design it with the current layout design as the Bridal Inquiry form. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bridal-inquiry-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bridal-inquiry__container-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-bridal-inquiry__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
    font-weight: 400;
  }

  .ai-bridal-inquiry__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
    font-weight: 400;
  }

  .ai-bridal-inquiry__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin-bottom: 40px;
  }

  .ai-bridal-inquiry__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-bridal-inquiry__field-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-bridal-inquiry__label-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: 14px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-bridal-inquiry__input-{{ ai_gen_id }},
  .ai-bridal-inquiry__textarea-{{ ai_gen_id }},
  .ai-bridal-inquiry__select-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: 16px;
    padding: 14px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.text_color }};
    border-radius: 0;
    width: 100%;
    transition: border-color 0.2s ease;
  }

  .ai-bridal-inquiry__input-{{ ai_gen_id }}:focus,
  .ai-bridal-inquiry__textarea-{{ ai_gen_id }}:focus,
  .ai-bridal-inquiry__select-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.text_color }};
  }

  .ai-bridal-inquiry__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-bridal-inquiry__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .ai-bridal-inquiry__button-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.button_size }}px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 16px 40px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_background }};
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 16px;
    font-weight: 500;
  }

  .ai-bridal-inquiry__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_background }};
  }

  .ai-bridal-inquiry__success-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    color: {{ block.settings.success_color }};
    padding: 16px;
    background-color: {{ block.settings.success_background }};
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .ai-bridal-inquiry__error-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-bridal-inquiry__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-bridal-inquiry__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-bridal-inquiry__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<bridal-inquiry-form-{{ ai_gen_id }} class="ai-bridal-inquiry-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bridal-inquiry__container-{{ ai_gen_id }}">
    {% if block.settings.show_eyebrow and block.settings.eyebrow != blank %}
      <div class="ai-bridal-inquiry__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-bridal-inquiry__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-bridal-inquiry__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {%- form 'contact', id: 'bridal-inquiry-form-' | append: ai_gen_id -%}
      {% if form.posted_successfully? %}
        <div class="ai-bridal-inquiry__success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      <input type="hidden" name="contact[form_type]" value="Bridal Inquiry">

      <div class="ai-bridal-inquiry__form-{{ ai_gen_id }}">
        <div class="ai-bridal-inquiry__row-{{ ai_gen_id }}">
          <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
            <label for="first-name-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
              First Name *
            </label>
            <input
              type="text"
              id="first-name-{{ ai_gen_id }}"
              name="contact[first_name]"
              class="ai-bridal-inquiry__input-{{ ai_gen_id }}"
              required
              aria-required="true"
            >
          </div>

          <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
            <label for="last-name-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
              Last Name *
            </label>
            <input
              type="text"
              id="last-name-{{ ai_gen_id }}"
              name="contact[last_name]"
              class="ai-bridal-inquiry__input-{{ ai_gen_id }}"
              required
              aria-required="true"
            >
          </div>
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="email-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Email Address *
          </label>
          <input
            type="email"
            id="email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-bridal-inquiry__input-{{ ai_gen_id }}"
            required
            aria-required="true"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="email-error-{{ ai_gen_id }}"
            {% endif %}
          >
          {% if form.errors %}
            <div id="email-error-{{ ai_gen_id }}" class="ai-bridal-inquiry__error-{{ ai_gen_id }}">
              {{ form.errors.messages.email }}
            </div>
          {% endif %}
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="phone-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Phone Number
          </label>
          <input
            type="tel"
            id="phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-bridal-inquiry__input-{{ ai_gen_id }}"
            autocomplete="tel"
          >
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="wedding-date-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Wedding Date
          </label>
          <input
            type="text"
            id="wedding-date-{{ ai_gen_id }}"
            name="contact[wedding_date]"
            class="ai-bridal-inquiry__input-{{ ai_gen_id }}"
            placeholder="MM/DD/YYYY"
          >
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="wedding-location-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Wedding Location
          </label>
          <input
            type="text"
            id="wedding-location-{{ ai_gen_id }}"
            name="contact[wedding_location]"
            class="ai-bridal-inquiry__input-{{ ai_gen_id }}"
            placeholder="City, State/Country"
          >
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="dress-style-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Preferred Dress Style
          </label>
          <select
            id="dress-style-{{ ai_gen_id }}"
            name="contact[dress_style]"
            class="ai-bridal-inquiry__select-{{ ai_gen_id }}"
          >
            <option value="">Select a style</option>
            <option value="Classic & Timeless">Classic & Timeless</option>
            <option value="Modern & Minimalist">Modern & Minimalist</option>
            <option value="Romantic & Ethereal">Romantic & Ethereal</option>
            <option value="Bohemian">Bohemian</option>
            <option value="Vintage Inspired">Vintage Inspired</option>
            <option value="Not Sure Yet">Not Sure Yet</option>
          </select>
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="budget-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Budget Range
          </label>
          <select
            id="budget-{{ ai_gen_id }}"
            name="contact[budget_range]"
            class="ai-bridal-inquiry__select-{{ ai_gen_id }}"
          >
            <option value="">Select a range</option>
            <option value="Under $5,000">Under $5,000</option>
            <option value="$5,000 - $8,000">$5,000 - $8,000</option>
            <option value="$8,000 - $12,000">$8,000 - $12,000</option>
            <option value="$12,000 - $15,000">$12,000 - $15,000</option>
            <option value="$15,000+">$15,000+</option>
          </select>
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="how-heard-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            How Did You Hear About Us?
          </label>
          <select
            id="how-heard-{{ ai_gen_id }}"
            name="contact[how_heard]"
            class="ai-bridal-inquiry__select-{{ ai_gen_id }}"
          >
            <option value="">Select an option</option>
            <option value="Instagram">Instagram</option>
            <option value="Pinterest">Pinterest</option>
            <option value="Google Search">Google Search</option>
            <option value="Wedding Planner">Wedding Planner</option>
            <option value="Friend/Family Referral">Friend/Family Referral</option>
            <option value="Bridal Magazine">Bridal Magazine</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="ai-bridal-inquiry__field-group-{{ ai_gen_id }}">
          <label for="message-{{ ai_gen_id }}" class="ai-bridal-inquiry__label-{{ ai_gen_id }}">
            Tell Us About Your Vision
          </label>
          <textarea
            id="message-{{ ai_gen_id }}"
            name="contact[message]"
            class="ai-bridal-inquiry__textarea-{{ ai_gen_id }}"
            placeholder="Share any details about your dream dress, wedding style, or special requests..."
          ></textarea>
        </div>

        <button type="submit" class="ai-bridal-inquiry__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      </div>
    {%- endform -%}
  </div>
</bridal-inquiry-form-{{ ai_gen_id }}>

<script>
(function() {
  class BridalInquiryForm{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.form = this.querySelector('form');
      if (this.form) {
        this.form.addEventListener('submit', this.handleSubmit.bind(this));
      }
    }

    handleSubmit(event) {
      const requiredFields = this.querySelectorAll('[required]');
      let isValid = true;

      requiredFields.forEach(field => {
        if (!field.value.trim()) {
          isValid = false;
          field.style.borderColor = '{{ block.settings.error_color }}';
        } else {
          field.style.borderColor = '{{ block.settings.input_border_color }}';
        }
      });

      if (!isValid) {
        event.preventDefault();
      }
    }
  }

  customElements.define('bridal-inquiry-form-{{ ai_gen_id }}', BridalInquiryForm{{ ai_gen_id }});
})();
</script>

{% schema %}
{
  "name": "Bridal inquiry form",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_eyebrow",
      "label": "Show eyebrow text",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Begin Your Journey"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bridal Inquiry"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We're honored to be part of your special day. Please share your details below and we'll be in touch within 48 hours to schedule your private appointment.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Request Invitation"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your inquiry! We'll be in touch soon."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "input_background",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#d4d1ca"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#3a3a3a"
    },
    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success text",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "success_background",
      "label": "Success background",
      "default": "#e8f5f1"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error",
      "default": "#D82C0D"
    }
  ],
  "presets": [
    {
      "name": "Bridal inquiry form"
    }
  ]
}
{% endschema %}
