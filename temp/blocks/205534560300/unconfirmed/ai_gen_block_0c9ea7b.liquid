{% doc %}
  @prompt
    Create a duplicate of the "selection gallery" for our bridal immersions but this time only have 4 boxes for our Dream Immersion packages since we only have 4 different offerings. Make sure I can edit the names of the package. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dream-packages-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-dream-packages__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-dream-packages__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-dream-packages__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-dream-packages__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-dream-packages__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-dream-packages__box-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.box_border_radius }}px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    aspect-ratio: {{ block.settings.box_aspect_ratio }};
  }

  .ai-dream-packages__box-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-dream-packages__box-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-dream-packages__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-dream-packages__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-dream-packages__box-{{ ai_gen_id }}:hover .ai-dream-packages__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-dream-packages__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-dream-packages__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-dream-packages__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), transparent);
    padding: {{ block.settings.overlay_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 40%;
  }

  .ai-dream-packages__package-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.package_name_size }}px;
    color: {{ block.settings.overlay_text_color }};
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 989px) {
    .ai-dream-packages__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-dream-packages__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-dream-packages__package-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.package_name_size | times: 0.85 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-dream-packages-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 0;
    }

    .ai-dream-packages__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.5 }}px;
    }

    .ai-dream-packages__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-dream-packages__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-dream-packages__package-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.package_name_size | times: 0.75 }}px;
    }
  }
{% endstyle %}

<dream-packages-{{ ai_gen_id }} class="ai-dream-packages-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dream-packages__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtitle != blank %}
      <div class="ai-dream-packages__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-dream-packages__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-dream-packages__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-dream-packages__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign package_name_key = 'package_' | append: i | append: '_name'
          assign package_image_key = 'package_' | append: i | append: '_image'
          assign package_link_key = 'package_' | append: i | append: '_link'

          assign package_name = block.settings[package_name_key]
          assign package_image = block.settings[package_image_key]
          assign package_link = block.settings[package_link_key]
        %}

        <div class="ai-dream-packages__box-{{ ai_gen_id }}">
          {% if package_link != blank %}
            <a href="{{ package_link }}" class="ai-dream-packages__box-link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-dream-packages__box-link-{{ ai_gen_id }}">
          {% endif %}
            <div class="ai-dream-packages__image-wrapper-{{ ai_gen_id }}">
              {% if package_image %}
                <img
                  src="{{ package_image | image_url: width: 800 }}"
                  alt="{{ package_image.alt | escape }}"
                  loading="lazy"
                  width="{{ package_image.width }}"
                  height="{{ package_image.height }}"
                  class="ai-dream-packages__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-dream-packages__image-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <div class="ai-dream-packages__overlay-{{ ai_gen_id }}">
                {% if package_name != blank %}
                  <h3 class="ai-dream-packages__package-name-{{ ai_gen_id }}">{{ package_name }}</h3>
                {% endif %}
              </div>
            </div>
          {% if package_link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</dream-packages-{{ ai_gen_id }}>

<script>
  (function() {
    class DreamPackages{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.boxes = this.querySelectorAll('.ai-dream-packages__box-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.boxes.forEach((box) => {
          const link = box.querySelector('.ai-dream-packages__box-link-{{ ai_gen_id }}');
          if (link && link.tagName === 'A') {
            link.setAttribute('role', 'link');
          }
        });
      }
    }

    customElements.define('dream-packages-{{ ai_gen_id }}', DreamPackages{{ ai_gen_id }});
  })();
</script>

