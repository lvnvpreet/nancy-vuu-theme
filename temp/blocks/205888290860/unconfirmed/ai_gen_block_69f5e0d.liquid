{% doc %}
  @prompt
    Segment Intent: Create a high-impact, minimalist "Collective Call to Action" segment that concludes the Three Phases of Restoration.
    Aesthetic: Sovereign Luxury. Use a palette of Cream (#F5F5F1), Charcoal Black (#1A1A1A), and Muted Gold.
    
    1. Layout & Separator:
    
    Spacing: Center all elements. Use 100px vertical padding (top and bottom).
    
    Top Separator: Add a 1px thin, Muted Gold horizontal line (100px width) above the header.
    
    2. The Collective Heading:
    
    Text: ONE HOUSE. ONE MISSION. TOTAL RESTORATION.
    
    Style: All Caps, Serif font (Bodoni Moda or Montserrat Light). Letter spacing: 0.4em. Font size: 2rem.
    
    3. The Narrative Connector:
    
    Text: "We do not just heal; we house. We do not just protect; we propel. Your investment fuels the complete cycle—from the restoration of worth to the elevation of dreams realized."
    
    Style: Italicized Serif font, max-width 750px. Font size: 1.1rem. Line height: 1.8.     give me the option to have 3 separate paragraphs here. 
    
    4. The Sovereign CTA Button:
    
    Button Text: JOIN THE ALLIANCE
    
    Link: [Insert Your PayPal Alliance Link Here]
    
    Style: Sharp-edged rectangle (no rounded corners). Solid Charcoal Black background with White text. Letter spacing: 0.2em.
    
    5. Animation:
    
    Apply a gentle 'Upward Slide' fade-in animation as the user scrolls to this segment. give me control access to edit all content and top and bottom padding of segment. also make sure all content is centered.  and create a subtext under the title. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collective-cta-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  .ai-collective-cta-{{ ai_gen_id }}.ai-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-collective-cta-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .ai-collective-separator-{{ ai_gen_id }} {
    width: 100px;
    height: 1px;
    background-color: {{ block.settings.separator_color }};
  }

  .ai-collective-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-transform: uppercase;
    letter-spacing: 0.4em;
    margin: 0;
    line-height: 1.3;
  }

  .ai-collective-subtext-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: italic;
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    max-width: 750px;
    margin: 0;
    line-height: 1.8;
  }

  .ai-collective-narrative-{{ ai_gen_id }} {
    max-width: 750px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-collective-paragraph-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: italic;
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.8;
  }

  .ai-collective-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 18px 50px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .ai-collective-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-collective-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      letter-spacing: 0.2em;
    }

    .ai-collective-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-collective-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-collective-cta-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size | times: 0.9 }}px;
      padding: 15px 35px;
    }

    .ai-collective-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 20px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-collective-cta-container-{{ ai_gen_id }} {
      gap: 30px;
    }
  }
{% endstyle %}

<collective-cta-{{ ai_gen_id }}
  class="ai-collective-cta-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collective-cta-container-{{ ai_gen_id }}">
    <div class="ai-collective-separator-{{ ai_gen_id }}"></div>

    <div>
      {% if block.settings.heading != blank %}
        <h2 class="ai-collective-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subtext != blank %}
        <div class="ai-collective-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
      {% endif %}
    </div>

    <div class="ai-collective-narrative-{{ ai_gen_id }}">
      {% if block.settings.paragraph_1 != blank %}
        <div class="ai-collective-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph_1 }}</div>
      {% endif %}

      {% if block.settings.paragraph_2 != blank %}
        <div class="ai-collective-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph_2 }}</div>
      {% endif %}

      {% if block.settings.paragraph_3 != blank %}
        <div class="ai-collective-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph_3 }}</div>
      {% endif %}
    </div>

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-collective-cta-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</collective-cta-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectiveCta{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.classList.add('ai-visible');
              this.observer.unobserve(this);
            }
          });
        }, options);

        this.observer.observe(this);
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('collective-cta-{{ ai_gen_id }}', CollectiveCta{{ ai_gen_id }});
  })();
</script>

