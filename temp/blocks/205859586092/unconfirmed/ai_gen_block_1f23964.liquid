  "settings": [
    {
      "type": "header",
      "content": "Anchor"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "engage-the-visionary"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Form content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engage the Visionary"
    },
    {
