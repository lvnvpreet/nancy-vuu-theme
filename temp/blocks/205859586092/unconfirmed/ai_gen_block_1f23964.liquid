{% doc %}
  @prompt
    Shopify AI Master Instructions: The Library Engagement Architecture
    Objective: Create two integrated segments at the bottom of the Library page (following the Author Bio) to facilitate institutional partnerships and curriculum immersion for the book Let There Be Fashion.
    
    Segment 1: The Shared Narrative (The Invitation)
    Purpose: To bridge the individual book purchase to a collective, institutional immersion.
    
    Layout: Full-width text immersion.
    
    Background Color: Pure White (#FFFFFF).
    
    Padding: 120px Top / 80px Bottom.
    
    Dividing Line: A subtle 1px horizontal rule (#E5E5E5) at the very top of the section.
    
    Typography & Copy:
    
    Eyebrow (Sans-Serif): "THE SHARED NARRATIVE" (11px, All Caps, 0.3em letter spacing, Color: #999).
    
    Header (Serif/Bodoni Moda): "IMMERSION & IMPACT" (32px, All Caps, 0.25em letter spacing).
    
    Body Text (Sans-Serif/Inter): > "Beyond the individual journey lies the opportunity for collective transformation. The Let There Be Fashion curriculum is designed for leadership collectives, academic institutions, and faith-based organizations seeking to move beyond theory and into the structural restoration of worth. We invite you to engage the House of Vuu to facilitate a shared narrative through group immersion and speaking engagements."
    
    Style: 18px, Line Height 1.8, Max-width: 800px, Centered. (Italicize the book title).
    
    CTA Button:
    
    Text: "INITIATE THE DIALOGUE"
    
    Style: Minimalist Ghost Button (1px solid black border, no background, 12px, Bold, All Caps).
    
    Link: Anchor to #engage-the-visionary.
    
    Segment 2: Engage the Visionary (The Action)
    Purpose: A sophisticated inquiry form that handles diverse requests (Curriculum, Speaking, Media).
    
    Layout: 50/50 Split (Image Left / Form Right).
    
    ID: engage-the-visionary
    
    Left Side (Visual Asset): * Image: Use the high-contrast B&W photo of Nancy Vuu speaking to a crowd with raised hands.
    
    Style: Full bleed to the left edge; apply a soft "fade-to-white" at the bottom to transition cleanly.
    
    Right Side (The Inquiry Form):
    
    Background Color: Pure White (#FFFFFF).
    
    Header (Serif): "Engage the Visionary" (Bodoni Moda, 28px).
    
    Intro Text: "Please entrust the details of your brief below as we review for visionary alignment and the potential for a shared narrative."
    
    Form Fields (Clean 1px borders, no shadows):
    
    Full Name & Title (Text)
    
    Organization / Media Outlet (Text)
    
    Professional Email (Email)
    
    Nature of Inquiry (Dropdown Menu):
    
    Let There Be Fashion Curriculum Immersion
    
    Speaking Engagement / Keynote
    
    Dream Academy & Foundation Partnership
    
    Global Advisory / Consultation
    
    Media & Press Inquiry
    
    The Vision (Text Area): Label as "Describe the narrative or mandate you wish for Nancy Vuu to deliver."
    
    Proposed Timeline (Date/Text)
    
    Final Submit Button:
    
    Text: "INITIATE THE DIALOGUE"
    
    Style: Solid Black Bar, White Text, All Caps, Bold.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-engage-visionary-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-engage-visionary__wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 800px;
  }

  .ai-engage-visionary__image-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-engage-visionary__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-engage-visionary__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-engage-visionary__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-engage-visionary__image-fade-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.8) 100%);
    pointer-events: none;
  }

  .ai-engage-visionary__form-container-{{ ai_gen_id }} {
    padding: 80px 60px;
    background-color: {{ block.settings.form_background }};
  }

  .ai-engage-visionary__form-content-{{ ai_gen_id }} {
    max-width: 540px;
  }

  .ai-engage-visionary__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px;
    font-weight: 400;
    line-height: 1.3;
  }

  .ai-engage-visionary__intro-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.intro_size }}px;
    line-height: 1.6;
    color: {{ block.settings.body_color }};
    margin: 0 0 40px;
  }

  .ai-engage-visionary__field-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-engage-visionary__label-{{ ai_gen_id }} {
    display: block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-engage-visionary__input-{{ ai_gen_id }},
  .ai-engage-visionary__select-{{ ai_gen_id }},
  .ai-engage-visionary__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.input_color }};
    background-color: {{ block.settings.input_background }};
    border: 1px solid {{ block.settings.input_border }};
    border-radius: 0;
    transition: border-color 0.3s ease;
  }

  .ai-engage-visionary__input-{{ ai_gen_id }}:focus,
  .ai-engage-visionary__select-{{ ai_gen_id }}:focus,
  .ai-engage-visionary__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-engage-visionary__textarea-{{ ai_gen_id }} {
    min-height: 140px;
    resize: vertical;
  }

  .ai-engage-visionary__submit-{{ ai_gen_id }} {
    width: 100%;
    padding: 18px 32px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.button_size }}px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-engage-visionary__submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
  }

  .ai-engage-visionary__success-{{ ai_gen_id }} {
    padding: 20px;
    background-color: #f0f9f4;
    border: 1px solid #4ade80;
    color: #166534;
    margin-bottom: 24px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.input_size }}px;
  }

  .ai-engage-visionary__error-{{ ai_gen_id }} {
    padding: 20px;
    background-color: #fef2f2;
    border: 1px solid #f87171;
    color: #991b1b;
    margin-bottom: 24px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.input_size }}px;
  }

  @media screen and (max-width: 989px) {
    .ai-engage-visionary__wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-engage-visionary__image-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-engage-visionary__form-container-{{ ai_gen_id }} {
      padding: 60px 40px;
    }

    .ai-engage-visionary__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-engage-visionary__form-container-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-engage-visionary__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-engage-visionary__intro-{{ ai_gen_id }} {
      font-size: {{ block.settings.intro_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-engage-visionary-{{ ai_gen_id }}" id="{{ block.settings.anchor_id }}" {{ block.shopify_attributes }}>
  <div class="ai-engage-visionary__wrapper-{{ ai_gen_id }}">
    <div class="ai-engage-visionary__image-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-engage-visionary__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-engage-visionary__image-fade-{{ ai_gen_id }}"></div>
    </div>

    <div class="ai-engage-visionary__form-container-{{ ai_gen_id }}">
      {%- form 'contact' -%}
        <div class="ai-engage-visionary__form-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-engage-visionary__heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.intro_text != blank %}
            <div class="ai-engage-visionary__intro-{{ ai_gen_id }}">
              {{ block.settings.intro_text }}
            </div>
          {% endif %}

          {%- if form.posted_successfully? -%}
            <div class="ai-engage-visionary__success-{{ ai_gen_id }}" id="ai-engage-success-{{ ai_gen_id }}">
              {{ block.settings.success_message }}
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="ai-engage-visionary__error-{{ ai_gen_id }}" id="ai-engage-error-{{ ai_gen_id }}">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="ai-engage-visionary__field-{{ ai_gen_id }}">
            <label for="contact-name-{{ ai_gen_id }}" class="ai-engage-visionary__label-{{ ai_gen_id }}">
              Full Name & Title
            </label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-engage-visionary__input-{{ ai_gen_id }}"
              value="{{ form.name }}"
              required
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-engage-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-engage-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-engage-visionary__field-{{ ai_gen_id }}">
            <label for="contact-organization-{{ ai_gen_id }}" class="ai-engage-visionary__label-{{ ai_gen_id }}">
              Organization / Media Outlet
            </label>
            <input
              type="text"
              id="contact-organization-{{ ai_gen_id }}"
              name="contact[organization]"
              class="ai-engage-visionary__input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="ai-engage-visionary__field-{{ ai_gen_id }}">
            <label for="contact-email-{{ ai_gen_id }}" class="ai-engage-visionary__label-{{ ai_gen_id }}">
              Professional Email
            </label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-engage-visionary__input-{{ ai_gen_id }}"
              value="{{ form.email }}"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              required
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-engage-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-engage-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-engage-visionary__field-{{ ai_gen_id }}">
            <label for="contact-inquiry-{{ ai_gen_id }}" class="ai-engage-visionary__label-{{ ai_gen_id }}">
              Nature of Inquiry
            </label>
            <select
              id="contact-inquiry-{{ ai_gen_id }}"
              name="contact[inquiry_type]"
              class="ai-engage-visionary__select-{{ ai_gen_id }}"
              required
            >
              <option value="">Select an option</option>
              <option value="curriculum">Let There Be Fashion Curriculum Immersion</option>
              <option value="speaking">Speaking Engagement / Keynote</option>
              <option value="partnership">Dream Academy & Foundation Partnership</option>
              <option value="advisory">Global Advisory / Consultation</option>
              <option value="media">Media & Press Inquiry</option>
            </select>
          </div>

          <div class="ai-engage-visionary__field-{{ ai_gen_id }}">
            <label for="contact-vision-{{ ai_gen_id }}" class="ai-engage-visionary__label-{{ ai_gen_id }}">
              The Vision
            </label>
            <textarea
              id="contact-vision-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-engage-visionary__textarea-{{ ai_gen_id }}"
              placeholder="Describe the narrative or mandate you wish for Nancy Vuu to deliver."
              required
            >{{ form.body }}</textarea>
          </div>

          <div class="ai-engage-visionary__field-{{ ai_gen_id }}">
            <label for="contact-timeline-{{ ai_gen_id }}" class="ai-engage-visionary__label-{{ ai_gen_id }}">
              Proposed Timeline
            </label>
            <input
              type="text"
              id="contact-timeline-{{ ai_gen_id }}"
              name="contact[timeline]"
              class="ai-engage-visionary__input-{{ ai_gen_id }}"
              placeholder="e.g., Q2 2026, Spring 2026, or specific date"
            >
          </div>

          <button type="submit" class="ai-engage-visionary__submit-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
