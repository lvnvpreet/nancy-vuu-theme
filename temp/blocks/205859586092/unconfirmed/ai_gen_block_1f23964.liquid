      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "form_background",
      "label": "Form background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "body_color",
