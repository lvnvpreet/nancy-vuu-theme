{% doc %}
  @prompt
    Create another manifesto section that has eyebrow that says "The Mandate" and a  body that says: " At Nancy Vuu Atelier, we believe a suit is more than a garment; it is the physical architecture of a leader’s triumph. Our Seth Eden collection offers world-class bespoke custom suits for men and women, architected with the same precision and soul as our global couture pieces. From our San Jose sanctuary, we serve the discerning executive and visionary clientele of Atherton, Palo Alto, Los Altos Hills, and Saratoga." I want the words "San Jose Sanctuary" to be linked to my homepage www.nancyvuu.com.  also give me control access to adjust font sizes. also include a CTA button that says "Start the Commission" i need control access to edit all conent. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-manifesto-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 40px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-manifesto-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-manifesto-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 {{ block.settings.eyebrow_spacing }}px 0;
  }

  .ai-manifesto-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_font_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin: 0 0 {{ block.settings.body_spacing }}px 0;
  }

  .ai-manifesto-body-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    border-bottom: 1px solid {{ block.settings.link_color }};
    transition: opacity 0.2s ease;
  }

  .ai-manifesto-body-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  .ai-manifesto-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_font_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-manifesto-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-manifesto-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 20px;
    }

    .ai-manifesto-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size | times: 0.85 }}px;
    }

    .ai-manifesto-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-manifesto-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-manifesto-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-manifesto-container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-manifesto-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow }}
      </div>
    {% endif %}

    {% if block.settings.body != blank %}
      <div class="ai-manifesto-body-{{ ai_gen_id }}">
        {{ block.settings.body }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a 
        href="{{ block.settings.button_link }}" 
        class="ai-manifesto-cta-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Manifesto section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Mandate"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>At Nancy Vuu Atelier, we believe a suit is more than a garment; it is the physical architecture of a leader's triumph. Our Seth Eden collection offers world-class bespoke custom suits for men and women, architected with the same precision and soul as our global couture pieces. From our <a href=\"https://www.nancyvuu.com\">San Jose sanctuary</a>, we serve the discerning executive and visionary clientele of Atherton, Palo Alto, Los Altos Hills, and Saratoga.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Start the Commission"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
