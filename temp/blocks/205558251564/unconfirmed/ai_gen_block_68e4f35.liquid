{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin: 0 auto;
  }

  .ai-editorial-hero-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    position: relative;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.hero_height }}px;
    object-fit: cover;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.hero_height }}px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: #666;
    font-size: 14px;
    text-align: center;
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  .ai-editorial-hero-caption-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.caption_offset }}px;
    left: {{ block.settings.caption_offset }}px;
    right: {{ block.settings.caption_offset }}px;
    background-color: {{ block.settings.caption_bg }};
    padding: {{ block.settings.caption_padding }}px;
    max-width: 600px;
  }

  .ai-editorial-hero-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.hero_title_size }}px;
    line-height: 1.1;
    color: {{ block.settings.hero_title_color }};
    margin: 0 0 12px 0;
  }

  .ai-editorial-hero-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_subtitle_size }}px;
    line-height: 1.4;
    color: {{ block.settings.hero_subtitle_color }};
    margin: 0;
  }

  .ai-editorial-feature-{{ ai_gen_id }} {
    grid-column: span 8;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-editorial-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.feature_height }}px;
    object-fit: cover;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.feature_height }}px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-feature-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-editorial-feature-category-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.category_color }};
    font-weight: 600;
  }

  .ai-editorial-feature-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.feature_title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-editorial-feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-sidebar-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-editorial-sidebar-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.sidebar_height }}px;
    object-fit: cover;
  }

  .ai-editorial-sidebar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.sidebar_height }}px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-sidebar-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-sidebar-category-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.category_color }};
    font-weight: 600;
  }

  .ai-editorial-sidebar-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.sidebar_title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-editorial-sidebar-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.sidebar_text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-feature-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.hero_title_size }}px * 0.7);
    }

    .ai-editorial-feature-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.feature_title_size }}px * 0.8);
    }

    .ai-editorial-sidebar-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.sidebar_title_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px;
    }

    .ai-editorial-hero-image-{{ ai_gen_id }},
    .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.hero_height | times: 0.6 }}px;
    }

    .ai-editorial-feature-image-{{ ai_gen_id }},
    .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.feature_height | times: 0.7 }}px;
    }

    .ai-editorial-sidebar-image-{{ ai_gen_id }},
    .ai-editorial-sidebar-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.sidebar_height | times: 0.8 }}px;
    }

    .ai-editorial-hero-caption-{{ ai_gen_id }} {
      position: static;
      margin-top: 16px;
    }
  }
{% endstyle %}

<editorial-layout-{{ ai_gen_id }}
  class="ai-editorial-layout-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <div class="ai-editorial-hero-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 2000 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
          class="ai-editorial-hero-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
            Add a hero image to get started
          </div>
        </div>
      {% endif %}

      {% if block.settings.hero_title != blank or block.settings.hero_subtitle != blank %}
        <div class="ai-editorial-hero-caption-{{ ai_gen_id }}">
          {% if block.settings.hero_title != blank %}
            <h1 class="ai-editorial-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h1>
          {% endif %}
          {% if block.settings.hero_subtitle != blank %}
            <div class="ai-editorial-hero-subtitle-{{ ai_gen_id }}">{{ block.settings.hero_subtitle }}</div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="ai-editorial-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_image %}
        <img
          src="{{ block.settings.feature_image | image_url: width: 1200 }}"
          alt="{{ block.settings.feature_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.feature_image.width }}"
          height="{{ block.settings.feature_image.height }}"
          class="ai-editorial-feature-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-feature-placeholder-{{ ai_gen_id }}">
          {{ 'collection-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <div class="ai-editorial-feature-content-{{ ai_gen_id }}">
        {% if block.settings.feature_category != blank %}
          <div class="ai-editorial-feature-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</div>
        {% endif %}
        {% if block.settings.feature_title != blank %}
          <h2 class="ai-editorial-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h2>
        {% endif %}
        {% if block.settings.feature_excerpt != blank %}
          <div class="ai-editorial-feature-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</div>
        {% endif %}
      </div>
    </div>

    <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'sidebar_' | append: i | append: '_image'
          assign category_key = 'sidebar_' | append: i | append: '_category'
          assign title_key = 'sidebar_' | append: i | append: '_title'
          assign excerpt_key = 'sidebar_' | append: i | append: '_excerpt'

          assign sidebar_image = block.settings[image_key]
          assign sidebar_category = block.settings[category_key]
          assign sidebar_title = block.settings[title_key]
          assign sidebar_excerpt = block.settings[excerpt_key]
        %}

        <div class="ai-editorial-sidebar-item-{{ ai_gen_id }}">
          {% if sidebar_image %}
            <img
              src="{{ sidebar_image | image_url: width: 600 }}"
              alt="{{ sidebar_image.alt | escape }}"
              loading="lazy"
              width="{{ sidebar_image.width }}"
              height="{{ sidebar_image.height }}"
              class="ai-editorial-sidebar-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-editorial-sidebar-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div>
            {% if sidebar_category != blank %}
              <div class="ai-editorial-sidebar-category-{{ ai_gen_id }}">{{ sidebar_category }}</div>
            {% endif %}
            {% if sidebar_title != blank %}
              <h3 class="ai-editorial-sidebar-title-{{ ai_gen_id }}">{{ sidebar_title }}</h3>
            {% endif %}
            {% if sidebar_excerpt != blank %}
              <div class="ai-editorial-sidebar-excerpt-{{ ai_gen_id }}">{{ sidebar_excerpt }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</editorial-layout-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialLayout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('editorial-layout-{{ ai_gen_id }}', EditorialLayout{{ ai_gen_id }});
  })();
</script>

