{% doc %}
  @prompt
    <div class="shopify-custom-landing-page">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
    
        <style>
            .shopify-custom-landing-page {
                --color-bg-primary: #FAF9F6;
                --color-bg-secondary: #1A1A1A;
                --color-text-dark: #222222;
                --color-text-muted: #666666;
                --color-text-light: #FAF9F6;
                --color-accent: #C5A059;
                --font-serif: 'Cormorant Garamond', serif;
                --font-sans: 'Montserrat', sans-serif;
                background-color: var(--color-bg-primary);
                color: var(--color-text-dark);
                font-family: var(--font-sans);
                font-weight: 300;
                line-height: 1.7;
            }
            .shopify-custom-landing-page h1, 
            .shopify-custom-landing-page h2, 
            .shopify-custom-landing-page h3, 
            .shopify-custom-landing-page h4 {
                font-family: var(--font-serif);
                font-weight: 300;
                letter-spacing: 0.05em;
            }
            .shopify-custom-landing-page .container {
                max-width: 1200px;
                margin: 0 auto;
                padding: 0 2rem;
            }
            .shopify-custom-landing-page .btn {
                display: inline-block;
                font-family: var(--font-sans);
                font-weight: 400;
                font-size: 0.85rem;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                padding: 1.1rem 2.2rem;
                border: 1px solid var(--color-text-dark);
                cursor: pointer;
                transition: all 0.4s ease;
                background: transparent;
            }
            .shopify-custom-landing-page .btn-dark {
                background-color: var(--color-text-dark);
                color: var(--color-bg-primary);
            }
            .shopify-custom-landing-page .btn-dark:hover {
                background-color: transparent;
                color: var(--color-text-dark);
            }
            .shopify-custom-landing-page .hero {
                position: relative;
                min-height: 600px;
                display: flex;
                align-items: center;
                background-color: #EBEAE6;
                padding: 6rem 0;
            }
            .shopify-custom-landing-page .hero-bg {
                position: absolute;
                top: 0; left: 0; width: 100%; height: 100%;
                display: flex; z-index: 1;
            }
            .shopify-custom-landing-page .hero-panel {
                flex: 1; height: 100%; background-size: cover; background-position: center; position: relative;
            }
            .shopify-custom-landing-page .hero-panel::after {
                content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
                background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.05) 100%);
            }
            .shopify-custom-landing-page .panel-left { background-image: linear-gradient(45deg, #111, #333); }
            .shopify-custom-landing-page .panel-right { background-image: linear-gradient(45deg, #dcdcd8, #f5f5f3); }
            .shopify-custom-landing-page .hero .container { position: relative; z-index: 2; width: 100%; }
            .shopify-custom-landing-page .hero-content {
                max-width: 650px; background: rgba(250, 249, 246, 0.95); padding: 3rem;
                border-left: 2px solid var(--color-accent); box-shadow: 0 30px 60px rgba(0,0,0,0.05);
            }
            .shopify-custom-landing-page .hero h1 { font-size: 2.8rem; line-height: 1.15; margin-bottom: 1.5rem; }
            .shopify-custom-landing-page .hero h2 {
                font-family: var(--font-sans); font-size: 1rem; text-transform: uppercase;
                letter-spacing: 0.08em; margin-bottom: 2.5rem; color: var(--color-text-muted); font-weight: 400;
            }
            .shopify-custom-landing-page .hero-actions { display: flex; gap: 1.5rem; flex-wrap: wrap; }
            .shopify-custom-landing-page .manifesto { padding: 7rem 0; text-align: center; }
            .shopify-custom-landing-page .manifesto-inner { max-width: 800px; margin: 0 auto; }
            .shopify-custom-landing-page .tagline {
                font-family: var(--font-sans); font-size: 0.85rem; text-transform: uppercase;
                letter-spacing: 0.2em; color: var(--color-accent); margin-bottom: 1.5rem; display: block; font-weight: 500;
            }
            .shopify-custom-landing-page .manifesto h3 { font-size: 2.2rem; margin-bottom: 2rem; }
            .shopify-custom-landing-page .manifesto p { font-size: 1.15rem; font-family: var(--font-serif); font-style: italic; }
            .shopify-custom-landing-page .pillars { padding: 6rem 0; background-color: #F3F2EE; }
            .shopify-custom-landing-page .section-header { text-align: center; margin-bottom: 4rem; }
      
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-hero-{{ ai_gen_id }} {
    position: relative;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    background-color: {{ block.settings.hero_bg_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
    width: 100%;
  }

  .ai-editorial-hero-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    z-index: 1;
  }

  .ai-editorial-hero-panel-{{ ai_gen_id }} {
    flex: 1;
    height: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .ai-editorial-hero-panel-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.05) 100%);
  }

  .ai-editorial-hero-panel-left-{{ ai_gen_id }} {
    {% if block.settings.left_panel_image %}
      background-image: url('{{ block.settings.left_panel_image | image_url: width: 1200 }}');
    {% else %}
      background: linear-gradient(45deg, #111, #333);
    {% endif %}
  }

  .ai-editorial-hero-panel-right-{{ ai_gen_id }} {
    {% if block.settings.right_panel_image %}
      background-image: url('{{ block.settings.right_panel_image | image_url: width: 1200 }}');
    {% else %}
      background: linear-gradient(45deg, #dcdcd8, #f5f5f3);
    {% endif %}
  }

  .ai-editorial-hero-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ai-editorial-hero-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    background: {{ block.settings.content_bg_color }};
    padding: {{ block.settings.content_padding }}px;
    border-left: {{ block.settings.accent_border_width }}px solid {{ block.settings.accent_color }};
    box-shadow: 0 30px 60px rgba(0,0,0,{{ block.settings.shadow_opacity }});
  }

  .ai-editorial-hero-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.eyebrow_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 2.5rem;
    color: {{ block.settings.eyebrow_color }};
    font-weight: 400;
  }

  .ai-editorial-hero-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: {{ block.settings.title_color }};
  }

  .ai-editorial-hero-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.7;
    margin-bottom: 2rem;
    color: {{ block.settings.description_color }};
    font-weight: 300;
  }

  .ai-editorial-hero-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .ai-editorial-hero-btn-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 400;
    font-size: {{ block.settings.button_text_size }}px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1.1rem 2.2rem;
    border: 1px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    transition: all 0.4s ease;
    background: transparent;
    text-decoration: none;
    color: {{ block.settings.button_text_color }};
  }

  .ai-editorial-hero-btn-dark-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_dark_bg }};
    color: {{ block.settings.button_dark_text }};
    border-color: {{ block.settings.button_dark_bg }};
  }

  .ai-editorial-hero-btn-dark-{{ ai_gen_id }}:hover {
    background-color: transparent;
    color: {{ block.settings.button_dark_bg }};
    border-color: {{ block.settings.button_dark_bg }};
  }

  .ai-editorial-hero-btn-light-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_border_color }};
    color: {{ block.settings.button_dark_text }};
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height | times: 0.7 }}px;
      padding: {{ block.settings.vertical_padding | times: 0.6 }}px 0;
    }

    .ai-editorial-hero-bg-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-editorial-hero-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-editorial-hero-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }

    .ai-editorial-hero-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-editorial-hero-btn-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<div class="ai-editorial-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-hero-bg-{{ ai_gen_id }}">
    <div class="ai-editorial-hero-panel-{{ ai_gen_id }} ai-editorial-hero-panel-left-{{ ai_gen_id }}"></div>
    <div class="ai-editorial-hero-panel-{{ ai_gen_id }} ai-editorial-hero-panel-right-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-editorial-hero-container-{{ ai_gen_id }}">
    <div class="ai-editorial-hero-content-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-editorial-hero-eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow }}
        </div>
      {% endif %}

      {% if block.settings.title != blank %}
        <h1 class="ai-editorial-hero-title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h1>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-editorial-hero-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      <div class="ai-editorial-hero-actions-{{ ai_gen_id }}">
        {% if block.settings.primary_button_text != blank %}
          <a 
            href="{{ block.settings.primary_button_link }}" 
            class="ai-editorial-hero-btn-{{ ai_gen_id }} ai-editorial-hero-btn-dark-{{ ai_gen_id }}"
          >
            {{ block.settings.primary_button_text }}
          </a>
        {% endif %}

        {% if block.settings.secondary_button_text != blank %}
          <a 
            href="{{ block.settings.secondary_button_link }}" 
            class="ai-editorial-hero-btn-{{ ai_gen_id }} ai-editorial-hero-btn-light-{{ ai_gen_id }}"
          >
            {{ block.settings.secondary_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Editorial hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Introducing"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Belbelle and the Grand Garden Ball"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>An enchanting collection inspired by timeless elegance and modern romance.</p>"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "Explore the Collection"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "View Lookbook"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Background panels"
    },
    {
      "type": "image_picker",
      "id": "left_panel_image",
      "label": "Left panel image"
    },
    {
      "type": "image_picker",
      "id": "right_panel_image",
      "label": "Right panel image"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Base background",
      "default": "#EBEAE6"
    },
    {
      "type": "header",
      "content": "Content box"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Background",
      "default": "#FAF9F6"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Max width",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent border color",
      "default": "#C5A059"
    },
    {
      "type": "range",
      "id": "accent_border_width",
      "label": "Accent border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 0.2,
      "step": 0.1,
      "default": 0.1
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#222222"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#222222"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "color",
      "id": "button_dark_bg",
      "label": "Dark button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "button_dark_text",
      "label": "Dark button text",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Light button text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Light button border",
      "default": "#222222"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 40,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Editorial hero"
    }
  ]
}
{% endschema %}
