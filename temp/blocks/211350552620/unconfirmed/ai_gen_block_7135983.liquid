{% doc %}
  @prompt
    Hero Section: Split-screen layout. Headline: 'Bespoke Bridal & Custom Suiting Crafted for Flawless Coordination.' Subheadline: 'From the boardroom to the altar, we design synchronized, custom wardrobe legacies for high-profile couples.' Add a dark, premium call-to-action button that reads 'Reserve Your Dual Consultation'.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-split-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    min-height: {{ block.settings.min_height }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-hero-split__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ block.settings.min_height }}px;
    width: 100%;
  }

  .ai-hero-split__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.content_bg_color }};
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-hero-split__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-style: {{ block.settings.headline_font.style }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    margin: 0;
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-hero-split__subheadline-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheadline_font.family }}, {{ block.settings.subheadline_font.fallback_families }};
    font-weight: {{ block.settings.subheadline_font.weight }};
    font-style: {{ block.settings.subheadline_font.style }};
    font-size: {{ block.settings.subheadline_size }}px;
    line-height: {{ block.settings.subheadline_line_height }};
    color: {{ block.settings.subheadline_color }};
    margin: 0;
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-hero-split__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    letter-spacing: 0.05em;
    text-transform: {{ block.settings.button_text_transform }};
  }

  .ai-hero-split__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-hero-split__image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height }}px;
    overflow: hidden;
  }

  .ai-hero-split__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .ai-hero-split__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-split__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-hero-split__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-hero-split__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      {% if block.settings.mobile_layout == 'image_first' %}
        grid-template-rows: auto 1fr;
      {% else %}
        grid-template-rows: 1fr auto;
      {% endif %}
    }

    .ai-hero-split__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
      {% if block.settings.mobile_layout == 'image_first' %}
        order: 2;
      {% else %}
        order: 1;
      {% endif %}
    }

    .ai-hero-split__image-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
      {% if block.settings.mobile_layout == 'image_first' %}
        order: 1;
      {% else %}
        order: 2;
      {% endif %}
    }

    .ai-hero-split__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-hero-split__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size_mobile }}px;
    }

    .ai-hero-split__cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-split__container-{{ ai_gen_id }}">
    <div class="ai-hero-split__content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h1 class="ai-hero-split__headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h1>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <p class="ai-hero-split__subheadline-{{ ai_gen_id }}">
          {{ block.settings.subheadline }}
        </p>
      {% endif %}

      {% if block.settings.cta_text != blank %}
        <a
          href="{{ block.settings.cta_link }}"
          class="ai-hero-split__cta-{{ ai_gen_id }}"
        >
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-hero-split__image-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-hero-split__image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-split__empty-state-{{ ai_gen_id }}">
            Next, add a hero image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
