{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coordinated-styling-{{ ai_gen_id }} {
    --color-bg-primary: {{ block.settings.bg_primary }};
    --color-bg-secondary: {{ block.settings.bg_secondary }};
    --color-text-dark: {{ block.settings.text_dark }};
    --color-text-muted: {{ block.settings.text_muted }};
    --color-accent: {{ block.settings.accent_color }};
    
    background-color: var(--color-bg-primary);
    color: var(--color-text-dark);
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    line-height: 2.2;
    -webkit-font-smoothing: antialiased;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} h1,
  .ai-coordinated-styling-{{ ai_gen_id }} h2,
  .ai-coordinated-styling-{{ ai_gen_id }} h3,
  .ai-coordinated-styling-{{ ai_gen_id }} h4,
  .ai-coordinated-styling-{{ ai_gen_id }} h5 {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    color: var(--color-text-dark);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .btn-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 300;
    font-size: {{ block.settings.button_font_size }}px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 1.4rem 3rem;
    border: 1px solid rgba(34, 34, 34, 0.3);
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    background: transparent;
    color: var(--color-text-dark);
    text-decoration: none;
    margin-top: 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .btn-{{ ai_gen_id }}:hover {
    border-color: var(--color-text-dark);
    background-color: var(--color-text-dark);
    color: #FFFFFF;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .section-pad-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}rem 0;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} {
    position: relative;
    min-height: {{ block.settings.hero_min_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-secondary);
    text-align: center;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-content-{{ ai_gen_id }} {
    max-width: 900px;
    padding: 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h1 {
    font-size: {{ block.settings.hero_title_size }}rem;
    line-height: 1.15;
    margin-bottom: 2rem;
    letter-spacing: 0.05em;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h2 {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.hero_subtitle_size }}rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: 3rem;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} {
    text-align: center;
    background-color: var(--color-bg-primary);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-inner-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .tagline-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.tagline_size }}rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-accent);
    margin-bottom: 2.5rem;
    display: block;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.manifesto_title_size }}rem;
    margin-bottom: 2.5rem;
    font-style: italic;
    line-height: 1.3;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} p {
    font-size: {{ block.settings.manifesto_text_size }}rem;
    color: var(--color-text-muted);
    line-height: 2.2;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillars-{{ ai_gen_id }} {
    background-color: var(--color-bg-secondary);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .section-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 7rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .section-header-{{ ai_gen_id }} h2 {
    font-size: {{ block.settings.section_title_size }}rem;
    margin-bottom: 1.5rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.pillar_columns }}, 1fr);
    gap: 3.5rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }} {
    background-color: var(--color-bg-primary);
    padding: 3rem 2rem;
    text-align: center;
    transition: transform 0.4s ease;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-number-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: 3rem;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }} h4 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }} p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.9;
  }

  @media screen and (max-width: 990px) {
    .ai-coordinated-styling-{{ ai_gen_id }} .pillar-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h1 {
      font-size: 2.5rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} h3 {
      font-size: 2rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .section-header-{{ ai_gen_id }} h2 {
      font-size: 2.2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-coordinated-styling-{{ ai_gen_id }} .pillar-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h1 {
      font-size: 2rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h2 {
      font-size: 0.7rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} h3 {
      font-size: 1.6rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .section-pad-{{ ai_gen_id }} {
      padding: 6rem 0;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .btn-{{ ai_gen_id }} {
      padding: 1.2rem 2rem;
      font-size: 0.65rem;
    }
  }
{% endstyle %}

<coordinated-styling-{{ ai_gen_id }} class="ai-coordinated-styling-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_hero %}
    <section class="hero-{{ ai_gen_id }}">
      <div class="hero-content-{{ ai_gen_id }}">
        {% if block.settings.hero_title != blank %}
          <h1>{{ block.settings.hero_title }}</h1>
        {% endif %}
        {% if block.settings.hero_subtitle != blank %}
          <h2>{{ block.settings.hero_subtitle }}</h2>
        {% endif %}
        {% if block.settings.hero_button_text != blank and block.settings.hero_button_link != blank %}
          <a href="{{ block.settings.hero_button_link }}" class="btn-{{ ai_gen_id }}">
            {{ block.settings.hero_button_text }}
          </a>
        {% endif %}
      </div>
    </section>
  {% endif %}

  {% if block.settings.show_manifesto %}
    <section class="manifesto-{{ ai_gen_id }} section-pad-{{ ai_gen_id }}">
      <div class="container-{{ ai_gen_id }}">
        <div class="manifesto-inner-{{ ai_gen_id }}">
          {% if block.settings.manifesto_tagline != blank %}
            <span class="tagline-{{ ai_gen_id }}">{{ block.settings.manifesto_tagline }}</span>
          {% endif %}
          {% if block.settings.manifesto_title != blank %}
            <h3>{{ block.settings.manifesto_title }}</h3>
          {% endif %}
          {% if block.settings.manifesto_text != blank %}
            <div>{{ block.settings.manifesto_text }}</div>
          {% endif %}
        </div>
      </div>
    </section>
  {% endif %}

  {% if block.settings.show_pillars %}
    <section class="pillars-{{ ai_gen_id }} section-pad-{{ ai_gen_id }}">
      <div class="container-{{ ai_gen_id }}">
        {% if block.settings.pillars_title != blank %}
          <div class="section-header-{{ ai_gen_id }}">
            <h2>{{ block.settings.pillars_title }}</h2>
          </div>
        {% endif %}
        <div class="pillar-grid-{{ ai_gen_id }}">
          {% for i in (1..6) %}
            {% assign pillar_title_key = 'pillar_' | append: i | append: '_title' %}
            {% assign pillar_text_key = 'pillar_' | append: i | append: '_text' %}
            {% assign pillar_title = block.settings[pillar_title_key] %}
            {% assign pillar_text = block.settings[pillar_text_key] %}
            
            {% if pillar_title != blank or pillar_text != blank %}
              <div class="pillar-card-{{ ai_gen_id }}">
                <div class="pillar-number-{{ ai_gen_id }}">{{ i }}</div>
                {% if pillar_title != blank %}
                  <h4>{{ pillar_title }}</h4>
                {% endif %}
                {% if pillar_text != blank %}
                  <p>{{ pillar_text }}</p>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
</coordinated-styling-{{ ai_gen_id }}>

<script>
  (function() {
    class CoordinatedStyling{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('coordinated-styling-{{ ai_gen_id }}', CoordinatedStyling{{ ai_gen_id }});
  })();
</script>

