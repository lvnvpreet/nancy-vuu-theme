{% doc %}
  @prompt
    3-Column Grid Feature: Detail our three service pillars: Column 1 is 'The Boardroom Blueprint' (made-to-measure executive wear), Column 2 is 'The Social Calendar' (gala and red-carpet evening wear), and Column 3 is 'The Definitive Day' (perfectly coordinated custom bridal gowns and wedding suiting).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-service-pillars-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-service-pillars__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-service-pillars__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-service-pillars__eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 {{ block.settings.eyebrow_margin }}px;
    font-weight: 400;
  }

  .ai-service-pillars__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.2;
  }

  .ai-service-pillars__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-service-pillars__column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.column_alignment }};
  }

  .ai-service-pillars__column-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    color: {{ block.settings.number_color }};
    margin: 0 0 {{ block.settings.number_margin }}px;
    font-weight: 300;
    opacity: {{ block.settings.number_opacity }};
  }

  .ai-service-pillars__column-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.column_title_size }}px;
    color: {{ block.settings.column_title_color }};
    margin: 0 0 {{ block.settings.column_title_margin }}px;
    font-weight: 400;
    line-height: 1.3;
  }

  .ai-service-pillars__column-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: {{ block.settings.description_line_height }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-service-pillars__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_column_gap }}px;
    }

    .ai-service-pillars__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-service-pillars__column-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.column_title_size }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-service-pillars-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-service-pillars__container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-service-pillars__header-{{ ai_gen_id }}">
        {% if block.settings.eyebrow != blank %}
          <p class="ai-service-pillars__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</p>
        {% endif %}
        {% if block.settings.title != blank %}
          <h2 class="ai-service-pillars__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-service-pillars__grid-{{ ai_gen_id }}">
      <div class="ai-service-pillars__column-{{ ai_gen_id }}">
        {% if block.settings.show_numbers %}
          <div class="ai-service-pillars__column-number-{{ ai_gen_id }}">01</div>
        {% endif %}
        <h3 class="ai-service-pillars__column-title-{{ ai_gen_id }}">{{ block.settings.column_1_title }}</h3>
        <div class="ai-service-pillars__column-description-{{ ai_gen_id }}">{{ block.settings.column_1_description }}</div>
      </div>

      <div class="ai-service-pillars__column-{{ ai_gen_id }}">
        {% if block.settings.show_numbers %}
          <div class="ai-service-pillars__column-number-{{ ai_gen_id }}">02</div>
        {% endif %}
        <h3 class="ai-service-pillars__column-title-{{ ai_gen_id }}">{{ block.settings.column_2_title }}</h3>
        <div class="ai-service-pillars__column-description-{{ ai_gen_id }}">{{ block.settings.column_2_description }}</div>
      </div>

      <div class="ai-service-pillars__column-{{ ai_gen_id }}">
        {% if block.settings.show_numbers %}
          <div class="ai-service-pillars__column-number-{{ ai_gen_id }}">03</div>
        {% endif %}
        <h3 class="ai-service-pillars__column-title-{{ ai_gen_id }}">{{ block.settings.column_3_title }}</h3>
        <div class="ai-service-pillars__column-description-{{ ai_gen_id }}">{{ block.settings.column_3_description }}</div>
      </div>
    </div>
  </div>
</div>

