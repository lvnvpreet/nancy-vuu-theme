{% doc %}
  @prompt
    Please create a "Custom Liquid" Hero section for a high-end luxury website. The aesthetic must be extremely elegant, editorial, and minimalist.
    
    Please build the code using modular CSS Variables (Custom Properties) placed at the top of the <style> block. Add clear comments calling this the "USER CONTROL PANEL" so I can easily adjust the hero height, image split widths, text box opacity, font sizes, and all CTA button design elements (background color, border, text color, spacing).
    
    Layout & Imagery:
    
    Background: A 50/50 split-screen layout.
    
    Left Side: Image placeholder for the Groom (Sartorial).
    
    Right Side: Image placeholder for the Bride (Bridal).
    
    Both images must cover their respective halves perfectly (object-fit: cover) and span the full width of the screen.
    
    Center Text Overlay Box:
    
    Place an elegant, opaque box absolutely centered over the middle of the screen, overlapping the split between the two images.
    
    The box should have a semi-transparent white background (e.g., rgba(255, 255, 255, 0.85)) and a subtle blur effect to ensure the text is highly readable while still feeling light and airy.
    
    Add generous padding inside the box so the text has room to breathe.
    
    Add a very thin, subtle border to the box (e.g., 1px solid rgba(212, 175, 55, 0.2)).
    
    Typography (Inside the Box):
    
    Center all text.
    
    Headline (H1): "Bespoke Bridal & Sartorial Commissions Crafted for Flawless Coordination." (Format in an elegant, thin Serif font like Cormorant Garamond, dark grey).
    
    Subheadline (H2): "From the boardroom to the sanctuary, we architect synchronized wardrobe legacies." (Format in a thin Sans-serif font like Montserrat, ALL CAPS, wide letter spacing, smaller size, muted grey).
    
    Call to Action Button:
    
    Text: "REQUEST A PRIVATE CONSULTATION"
    
    Link: The button must link to the anchor ID #shopify-intake-form.
    
    Initial Style: Transparent background, dark grey text, thin dark grey border, wide letter spacing, uppercase, thin Sans-serif font. (Make sure I can change these exact properties easily via the CSS variables at the top).
    
    Please generate the complete HTML and CSS for this section, ensuring the "USER CONTROL PANEL" variables are clearly marked at the top of the style section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-split-{{ ai_gen_id }} {
    /* ========================================
       USER CONTROL PANEL - CSS VARIABLES
       ======================================== */
    
    --hero-height: 100vh;
    --hero-min-height: 600px;
    
    --left-image-width: 50%;
    --right-image-width: 50%;
    
    --text-box-bg-color: rgba(255, 255, 255, 0.85);
    --text-box-blur: 10px;
    --text-box-padding: 60px;
    --text-box-max-width: 700px;
    --text-box-border-color: rgba(212, 175, 55, 0.2);
    --text-box-border-width: 1px;
    
    --headline-font-size: 48px;
    --headline-color: #2c2c2c;
    --headline-line-height: 1.3;
    
    --subheadline-font-size: 13px;
    --subheadline-color: #6b6b6b;
    --subheadline-letter-spacing: 3px;
    --subheadline-margin-top: 20px;
    
    --cta-bg-color: transparent;
    --cta-text-color: #2c2c2c;
    --cta-border-color: #2c2c2c;
    --cta-border-width: 1px;
    --cta-font-size: 12px;
    --cta-letter-spacing: 2px;
    --cta-padding-vertical: 16px;
    --cta-padding-horizontal: 40px;
    --cta-margin-top: 35px;
    
    --cta-hover-bg-color: #2c2c2c;
    --cta-hover-text-color: #ffffff;
    --cta-hover-border-color: #2c2c2c;
    
    /* ======================================== */
    
    position: relative;
    width: 100%;
    height: var(--hero-height);
    min-height: var(--hero-min-height);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .ai-hero-split__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
  }
  
  .ai-hero-split__image-half-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    overflow: hidden;
  }
  
  .ai-hero-split__image-half-{{ ai_gen_id }}--left {
    width: var(--left-image-width);
  }
  
  .ai-hero-split__image-half-{{ ai_gen_id }}--right {
    width: var(--right-image-width);
  }
  
  .ai-hero-split__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .ai-hero-split__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ai-hero-split__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }
  
  .ai-hero-split__content-box-{{ ai_gen_id }} {
    position: relative;
    z-index: 10;
    background-color: var(--text-box-bg-color);
    backdrop-filter: blur(var(--text-box-blur));
    -webkit-backdrop-filter: blur(var(--text-box-blur));
    padding: var(--text-box-padding);
    max-width: var(--text-box-max-width);
    width: 90%;
    text-align: center;
    border: var(--text-box-border-width) solid var(--text-box-border-color);
  }
  
  .ai-hero-split__headline-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: var(--headline-font-size);
    font-weight: 300;
    color: var(--headline-color);
    line-height: var(--headline-line-height);
    margin: 0;
  }
  
  .ai-hero-split__subheadline-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-size: var(--subheadline-font-size);
    font-weight: 300;
    color: var(--subheadline-color);
    letter-spacing: var(--subheadline-letter-spacing);
    text-transform: uppercase;
    margin: var(--subheadline-margin-top) 0 0;
    line-height: 1.6;
  }
  
  .ai-hero-split__cta-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: var(--cta-margin-top);
    padding: var(--cta-padding-vertical) var(--cta-padding-horizontal);
    background-color: var(--cta-bg-color);
    color: var(--cta-text-color);
    border: var(--cta-border-width) solid var(--cta-border-color);
    font-family: 'Montserrat', sans-serif;
    font-size: var(--cta-font-size);
    font-weight: 400;
    letter-spacing: var(--cta-letter-spacing);
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .ai-hero-split__cta-{{ ai_gen_id }}:hover {
    background-color: var(--cta-hover-bg-color);
    color: var(--cta-hover-text-color);
    border-color: var(--cta-hover-border-color);
  }
  
  @media screen and (max-width: 768px) {
    .ai-hero-split-{{ ai_gen_id }} {
      --hero-height: 80vh;
      --hero-min-height: 500px;
      --text-box-padding: 40px;
      --headline-font-size: 32px;
      --subheadline-font-size: 11px;
      --cta-font-size: 11px;
      --cta-padding-vertical: 14px;
      --cta-padding-horizontal: 30px;
    }
    
    .ai-hero-split__background-{{ ai_gen_id }} {
      flex-direction: column;
    }
    
    .ai-hero-split__image-half-{{ ai_gen_id }}--left,
    .ai-hero-split__image-half-{{ ai_gen_id }}--right {
      width: 100%;
      height: 50%;
    }
  }
{% endstyle %}

<div class="ai-hero-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-split__background-{{ ai_gen_id }}">
    <div class="ai-hero-split__image-half-{{ ai_gen_id }} ai-hero-split__image-half-{{ ai_gen_id }}--left">
      {% if block.settings.left_image %}
        <img
          src="{{ block.settings.left_image | image_url: width: 2000 }}"
          alt="{{ block.settings.left_image.alt | escape }}"
          class="ai-hero-split__image-{{ ai_gen_id }}"
          loading="eager"
          width="{{ block.settings.left_image.width }}"
          height="{{ block.settings.left_image.height }}"
        >
      {% else %}
        <div class="ai-hero-split__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    
    <div class="ai-hero-split__image-half-{{ ai_gen_id }} ai-hero-split__image-half-{{ ai_gen_id }}--right">
      {% if block.settings.right_image %}
        <img
          src="{{ block.settings.right_image | image_url: width: 2000 }}"
          alt="{{ block.settings.right_image.alt | escape }}"
          class="ai-hero-split__image-{{ ai_gen_id }}"
          loading="eager"
          width="{{ block.settings.right_image.width }}"
          height="{{ block.settings.right_image.height }}"
        >
      {% else %}
        <div class="ai-hero-split__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>
  
  <div class="ai-hero-split__content-box-{{ ai_gen_id }}">
    <h1 class="ai-hero-split__headline-{{ ai_gen_id }}">
      {{ block.settings.headline }}
    </h1>
    
    <h2 class="ai-hero-split__subheadline-{{ ai_gen_id }}">
      {{ block.settings.subheadline }}
    </h2>
    
    <a href="#shopify-intake-form" class="ai-hero-split__cta-{{ ai_gen_id }}">
      {{ block.settings.cta_text }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Luxury split hero",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image (Sartorial)"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image (Bridal)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Bespoke Bridal & Sartorial Commissions Crafted for Flawless Coordination"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "From the boardroom to the sanctuary, we architect synchronized wardrobe legacies"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "REQUEST A PRIVATE CONSULTATION"
    }
  ],
  "presets": [
    {
      "name": "Luxury split hero"
    }
  ]
}
{% endschema %}
