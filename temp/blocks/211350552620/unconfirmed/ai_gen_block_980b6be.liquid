    },
    {
      "type": "font_picker",
      "id": "headline_font",
      "label": "Headline font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Subheadline"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline text",
      "default": "From the boardroom to the altar, we design synchronized, custom wardrobe legacies for high-profile couples."
    },
    {
      "type": "font_picker",
      "id": "subheadline_font",
      "label": "Subheadline font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "subheadline_size",
      "label": "Subheadline size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheadline_color",
      "label": "Subheadline color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Reserve Your Consultation"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Button font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button text size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Button vertical padding",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Button horizontal padding",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
