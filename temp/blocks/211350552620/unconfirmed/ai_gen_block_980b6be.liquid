{% doc %}
  @prompt
    Hero Section: Split-screen layout where i can put a photo on each side. then i want the Headline: 'Bespoke Bridal & Custom Suiting Crafted for Flawless Coordination.' to be in the center of the section on top of the photos. i want the Subheadline to read: 'From the boardroom to the altar, we design synchronized, custom wardrobe legacies for high-profile couples.' Add a dark, premium call-to-action button that reads 'Reserve Your Consultation'. give me access to adjust font style, font size and cta button size and padding in between lines and top adn bottom padding of segment. , give me access to enlarge the photos to maximize the space so there is no white space in the secment. i want ti to be portrait for both photos. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-hero-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    overflow: hidden;
    display: block;
  }

  .ai-split-hero__images-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: {{ block.settings.section_height }}px;
  }

  .ai-split-hero__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-split-hero__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-split-hero__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-split-hero__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-split-hero__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    max-width: 90%;
    width: 100%;
  }

  .ai-split-hero__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-style: {{ block.settings.headline_font.style }};
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.line_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-split-hero__subheadline-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheadline_font.family }}, {{ block.settings.subheadline_font.fallback_families }};
    font-weight: {{ block.settings.subheadline_font.weight }};
    font-style: {{ block.settings.subheadline_font.style }};
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    margin: 0 0 {{ block.settings.line_spacing }}px 0;
    line-height: 1.5;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-split-hero__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
    font-size: {{ block.settings.button_size }}px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
  }

  .ai-split-hero__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-split-hero__images-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      height: {{ block.settings.section_height | times: 0.7 }}px;
    }

    .ai-split-hero__headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.6);
    }

    .ai-split-hero__subheadline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheadline_size }}px * 0.8);
    }

    .ai-split-hero__cta-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_size }}px * 0.9);
      padding: calc({{ block.settings.button_padding_vertical }}px * 0.8) calc({{ block.settings.button_padding_horizontal }}px * 0.8);
    }
  }
{% endstyle %}

<split-hero-{{ ai_gen_id }} class="ai-split-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-hero__images-{{ ai_gen_id }}">
    <div class="ai-split-hero__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_left %}
        <img
          src="{{ block.settings.image_left | image_url: width: 1200 }}"
          alt="{{ block.settings.image_left.alt | escape }}"
          class="ai-split-hero__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image_left.width }}"
          height="{{ block.settings.image_left.height }}"
        >
      {% else %}
        <div class="ai-split-hero__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-split-hero__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_right %}
        <img
          src="{{ block.settings.image_right | image_url: width: 1200 }}"
          alt="{{ block.settings.image_right.alt | escape }}"
          class="ai-split-hero__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image_right.width }}"
          height="{{ block.settings.image_right.height }}"
        >
      {% else %}
        <div class="ai-split-hero__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-split-hero__content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-split-hero__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-split-hero__subheadline-{{ ai_gen_id }}">
        {{ block.settings.subheadline }}
      </p>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <a
        href="{{ block.settings.cta_link }}"
        class="ai-split-hero__cta-{{ ai_gen_id }}"
      >
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</split-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('split-hero-{{ ai_gen_id }}', SplitHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Split hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
