{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coordinated-styling-{{ ai_gen_id }} {
    --color-bg-primary: {{ block.settings.bg_primary }};
    --color-bg-secondary: {{ block.settings.bg_secondary }};
    --color-text-dark: {{ block.settings.text_dark }};
    --color-text-muted: {{ block.settings.text_muted }};
    --color-accent: {{ block.settings.accent_color }};
    
    display: block;
    background-color: var(--color-bg-primary);
    color: var(--color-text-dark);
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    line-height: {{ block.settings.line_height }};
    -webkit-font-smoothing: antialiased;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} h1,
  .ai-coordinated-styling-{{ ai_gen_id }} h2,
  .ai-coordinated-styling-{{ ai_gen_id }} h3,
  .ai-coordinated-styling-{{ ai_gen_id }} h4,
  .ai-coordinated-styling-{{ ai_gen_id }} h5 {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    color: var(--color-text-dark);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-btn-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 300;
    font-size: {{ block.settings.button_font_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    text-transform: uppercase;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: 1px solid rgba(34, 34, 34, {{ block.settings.button_border_opacity }});
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    background: transparent;
    color: var(--color-text-dark);
    text-decoration: none;
    margin-top: 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-btn-{{ ai_gen_id }}:hover {
    border-color: var(--color-text-dark);
    background-color: var(--color-text-dark);
    color: #FFFFFF;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-section-pad-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_vertical }}px 0;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-hero-{{ ai_gen_id }} {
    position: relative;
    min-height: {{ block.settings.hero_min_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-secondary);
    text-align: center;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-hero-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.hero_content_max_width }}px;
    padding: 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-hero-{{ ai_gen_id }} h1 {
    font-size: {{ block.settings.hero_title_size }}px;
    line-height: 1.15;
    margin-bottom: 2rem;
    letter-spacing: {{ block.settings.hero_title_spacing }}em;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-hero-{{ ai_gen_id }} h2 {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.hero_subtitle_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.hero_subtitle_spacing }}em;
    margin-bottom: 3rem;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-manifesto-{{ ai_gen_id }} {
    text-align: center;
    background-color: var(--color-bg-primary);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-manifesto-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.manifesto_max_width }}px;
    margin: 0 auto;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-tagline-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.tagline_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.tagline_spacing }}em;
    color: var(--color-accent);
    margin-bottom: 2.5rem;
    display: block;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-manifesto-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.manifesto_title_size }}px;
    margin-bottom: 2.5rem;
    font-style: italic;
    line-height: 1.3;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .ai-manifesto-{{ ai_gen_id }} p {
    font-size: {{ block.settings.manifesto_text_size }}px;
    color: var(--color-text-muted);
    line-height: {{ block.settings.line_height }};
    margin-bottom: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .ai-coordinated-styling-{{ ai_gen_id }} .ai-hero-{{ ai_gen_id }} h1 {
      font-size: calc({{ block.settings.hero_title_size }}px * 0.6);
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .ai-hero-{{ ai_gen_id }} h2 {
      font-size: calc({{ block.settings.hero_subtitle_size }}px * 0.85);
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .ai-manifesto-{{ ai_gen_id }} h3 {
      font-size: calc({{ block.settings.manifesto_title_size }}px * 0.65);
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .ai-section-pad-{{ ai_gen_id }} {
      padding: calc({{ block.settings.section_padding_vertical }}px * 0.5) 0;
    }
  }
{% endstyle %}

<div class="ai-coordinated-styling-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_hero %}
    <section class="ai-hero-{{ ai_gen_id }}">
      <div class="ai-hero-content-{{ ai_gen_id }}">
        {% if block.settings.hero_title != blank %}
          <h1>{{ block.settings.hero_title }}</h1>
        {% endif %}
        {% if block.settings.hero_subtitle != blank %}
          <h2>{{ block.settings.hero_subtitle }}</h2>
        {% endif %}
        {% if block.settings.hero_button_text != blank and block.settings.hero_button_link != blank %}
          <a href="{{ block.settings.hero_button_link }}" class="ai-btn-{{ ai_gen_id }}">
            {{ block.settings.hero_button_text }}
          </a>
        {% endif %}
      </div>
    </section>
  {% endif %}

  {% if block.settings.show_manifesto %}
    <section class="ai-manifesto-{{ ai_gen_id }} ai-section-pad-{{ ai_gen_id }}">
      <div class="ai-container-{{ ai_gen_id }}">
        <div class="ai-manifesto-inner-{{ ai_gen_id }}">
          {% if block.settings.manifesto_tagline != blank %}
            <span class="ai-tagline-{{ ai_gen_id }}">{{ block.settings.manifesto_tagline }}</span>
          {% endif %}
          {% if block.settings.manifesto_title != blank %}
            <h3>{{ block.settings.manifesto_title }}</h3>
          {% endif %}
          {% if block.settings.manifesto_text != blank %}
            <div>{{ block.settings.manifesto_text }}</div>
          {% endif %}
          {% if block.settings.manifesto_button_text != blank and block.settings.manifesto_button_link != blank %}
            <a href="{{ block.settings.manifesto_button_link }}" class="ai-btn-{{ ai_gen_id }}">
              {{ block.settings.manifesto_button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </section>
  {% endif %}
</div>

