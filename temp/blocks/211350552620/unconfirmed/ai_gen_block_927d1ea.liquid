{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Montserrat:wght@200;300;400&display=swap" rel="stylesheet">

{% style %}
  .ai-coordinated-styling-{{ ai_gen_id }} {
    --color-bg-primary: {{ block.settings.bg_primary }};
    --color-bg-secondary: {{ block.settings.bg_secondary }};
    --color-text-dark: {{ block.settings.text_dark }};
    --color-text-muted: {{ block.settings.text_muted }};
    --color-accent: {{ block.settings.accent_color }};
    
    --font-serif: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    --font-sans: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    
    background-color: var(--color-bg-primary);
    color: var(--color-text-dark);
    font-family: var(--font-sans);
    font-weight: {{ block.settings.body_weight }};
    line-height: {{ block.settings.body_line_height }};
    -webkit-font-smoothing: antialiased;
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} h1,
  .ai-coordinated-styling-{{ ai_gen_id }} h2,
  .ai-coordinated-styling-{{ ai_gen_id }} h3,
  .ai-coordinated-styling-{{ ai_gen_id }} h4,
  .ai-coordinated-styling-{{ ai_gen_id }} h5 {
    font-family: var(--font-serif);
    font-weight: {{ block.settings.heading_weight }};
    color: var(--color-text-dark);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .btn-{{ ai_gen_id }} {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: {{ block.settings.button_weight }};
    font-size: {{ block.settings.button_font_size }}rem;
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    text-transform: uppercase;
    padding: {{ block.settings.button_padding_y }}rem {{ block.settings.button_padding_x }}rem;
    border: 1px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    background: transparent;
    color: var(--color-text-dark);
    text-decoration: none;
    margin-top: 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .btn-{{ ai_gen_id }}:hover {
    border-color: var(--color-text-dark);
    background-color: var(--color-text-dark);
    color: {{ block.settings.button_hover_text }};
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .section-pad-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}rem 0;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} {
    position: relative;
    min-height: {{ block.settings.hero_min_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-secondary);
    text-align: center;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.hero_content_width }}px;
    padding: 2rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h1 {
    font-size: {{ block.settings.hero_title_size }}rem;
    line-height: {{ block.settings.hero_title_line_height }};
    margin-bottom: 2rem;
    letter-spacing: {{ block.settings.hero_title_spacing }}em;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h2 {
    font-family: var(--font-sans);
    font-size: {{ block.settings.hero_subtitle_size }}rem;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.hero_subtitle_spacing }}em;
    margin-bottom: 3rem;
    color: var(--color-text-muted);
    font-weight: {{ block.settings.heading_weight }};
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} {
    text-align: center;
    background-color: var(--color-bg-primary);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.manifesto_width }}px;
    margin: 0 auto;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .tagline-{{ ai_gen_id }} {
    font-family: var(--font-sans);
    font-size: {{ block.settings.tagline_size }}rem;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.tagline_spacing }}em;
    color: var(--color-accent);
    margin-bottom: 2.5rem;
    display: block;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.manifesto_title_size }}rem;
    margin-bottom: 2.5rem;
    font-style: italic;
    line-height: {{ block.settings.manifesto_title_line_height }};
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} p {
    font-size: {{ block.settings.manifesto_text_size }}rem;
    color: var(--color-text-muted);
    line-height: {{ block.settings.body_line_height }};
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillars-{{ ai_gen_id }} {
    background-color: var(--color-bg-secondary);
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .section-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 7rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .section-header-{{ ai_gen_id }} h2 {
    font-size: {{ block.settings.section_header_size }}rem;
    margin-bottom: 1.5rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.pillar_columns }}, 1fr);
    gap: {{ block.settings.pillar_gap }}rem;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }} {
    background-color: var(--color-bg-primary);
    padding: {{ block.settings.pillar_card_padding }}rem;
    text-align: center;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }} h4 {
    font-size: {{ block.settings.pillar_title_size }}rem;
    margin-bottom: 1.5rem;
    letter-spacing: {{ block.settings.pillar_title_spacing }}em;
  }

  .ai-coordinated-styling-{{ ai_gen_id }} .pillar-card-{{ ai_gen_id }} p {
    font-size: {{ block.settings.pillar_text_size }}rem;
    color: var(--color-text-muted);
    line-height: {{ block.settings.body_line_height }};
  }

  @media screen and (max-width: 768px) {
    .ai-coordinated-styling-{{ ai_gen_id }} .hero-{{ ai_gen_id }} h1 {
      font-size: calc({{ block.settings.hero_title_size }}rem * 0.6);
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .manifesto-{{ ai_gen_id }} h3 {
      font-size: calc({{ block.settings.manifesto_title_size }}rem * 0.7);
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .pillar-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ai-coordinated-styling-{{ ai_gen_id }} .section-header-{{ ai_gen_id }} h2 {
      font-size: calc({{ block.settings.section_header_size }}rem * 0.7);
    }
  }
{% endstyle %}

<coordinated-styling-{{ ai_gen_id }} class="ai-coordinated-styling-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_hero %}
    <section class="hero-{{ ai_gen_id }}">
      <div class="hero-content-{{ ai_gen_id }}">
        {% if block.settings.hero_title != blank %}
          <h1>{{ block.settings.hero_title }}</h1>
        {% endif %}
        {% if block.settings.hero_subtitle != blank %}
          <h2>{{ block.settings.hero_subtitle }}</h2>
        {% endif %}
        {% if block.settings.hero_button_text != blank and block.settings.hero_button_link != blank %}
          <a href="{{ block.settings.hero_button_link }}" class="btn-{{ ai_gen_id }}">
            {{ block.settings.hero_button_text }}
          </a>
        {% endif %}
      </div>
    </section>
  {% endif %}

  {% if block.settings.show_manifesto %}
    <section class="manifesto-{{ ai_gen_id }} section-pad-{{ ai_gen_id }}">
      <div class="container-{{ ai_gen_id }}">
        <div class="manifesto-inner-{{ ai_gen_id }}">
          {% if block.settings.manifesto_tagline != blank %}
            <span class="tagline-{{ ai_gen_id }}">{{ block.settings.manifesto_tagline }}</span>
          {% endif %}
          {% if block.settings.manifesto_title != blank %}
            <h3>{{ block.settings.manifesto_title }}</h3>
          {% endif %}
          {% if block.settings.manifesto_text != blank %}
            <div>{{ block.settings.manifesto_text }}</div>
          {% endif %}
        </div>
      </div>
    </section>
  {% endif %}

  {% if block.settings.show_pillars %}
    <section class="pillars-{{ ai_gen_id }} section-pad-{{ ai_gen_id }}">
      <div class="container-{{ ai_gen_id }}">
        {% if block.settings.pillars_header != blank %}
          <div class="section-header-{{ ai_gen_id }}">
            <h2>{{ block.settings.pillars_header }}</h2>
          </div>
        {% endif %}
        <div class="pillar-grid-{{ ai_gen_id }}">
          {% if block.settings.pillar_1_title != blank %}
            <div class="pillar-card-{{ ai_gen_id }}">
              <h4>{{ block.settings.pillar_1_title }}</h4>
              {% if block.settings.pillar_1_text != blank %}
                <p>{{ block.settings.pillar_1_text }}</p>
              {% endif %}
            </div>
          {% endif %}
          {% if block.settings.pillar_2_title != blank %}
            <div class="pillar-card-{{ ai_gen_id }}">
              <h4>{{ block.settings.pillar_2_title }}</h4>
              {% if block.settings.pillar_2_text != blank %}
                <p>{{ block.settings.pillar_2_text }}</p>
              {% endif %}
            </div>
          {% endif %}
          {% if block.settings.pillar_3_title != blank %}
            <div class="pillar-card-{{ ai_gen_id }}">
              <h4>{{ block.settings.pillar_3_title }}</h4>
              {% if block.settings.pillar_3_text != blank %}
                <p>{{ block.settings.pillar_3_text }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </section>
  {% endif %}
</coordinated-styling-{{ ai_gen_id }}>

<script>
  (function() {
    class CoordinatedStyling{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('coordinated-styling-{{ ai_gen_id }}', CoordinatedStyling{{ ai_gen_id }});
  })();
</script>

