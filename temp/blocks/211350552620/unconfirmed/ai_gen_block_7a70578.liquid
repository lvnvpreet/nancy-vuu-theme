{% doc %}
  @prompt
    Please create a "Multicolumn" section (or "Text Columns") with 3 equal-width columns. Do not include any images or icons in these columns—this must be a text-only layout. Use a pure white background, center align all text, and add massive padding (white space) above and below the section for a high-end, editorial aesthetic.
    
    Section Header Area:
    
    Main Heading: "The Atelier Ritual" (Format in an elegant, thin Serif font, dark grey/black).
    
    Subheading: "AN INTIMATE PARTNERSHIP IN CO-CREATION" (Format in a thin Sans-serif font, all caps, very wide letter spacing, in a muted champagne gold color). Add generous spacing below this subheading before the columns begin.
    
    Column Configuration (Text Only, Centered):
    
    Column 1:
    
    Overline/Tag: "01 / SANCTUARY ARRIVAL" (Format in Sans-serif, all caps, wide letter spacing, muted champagne gold).
    
    Heading: "The Dual Vision Assessment" (Format in Serif font, elegant and thin).
    
    Body Text: "We review your calendar, structural style goals, and legacy in a private studio session, mapping out an original blueprint exclusive to both of you." (Format in a very light, thin Sans-serif font, muted grey color, with a tall line height).
    
    Column 2:
    
    Overline/Tag: "02 / THE MASTER BUILD" (Format in Sans-serif, all caps, wide letter spacing, muted champagne gold).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-columns-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-text-columns-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-text-columns-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-text-columns-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .ai-text-columns-subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
    font-weight: {{ block.settings.subheading_font.weight }};
    font-style: {{ block.settings.subheading_font.style }};
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.subheading_letter_spacing }}px;
    margin: 0;
    line-height: 1.5;
  }

  .ai-text-columns-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
    margin-top: {{ block.settings.columns_top_spacing }}px;
  }

  .ai-text-columns-column-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-text-columns-overline-{{ ai_gen_id }} {
    font-family: {{ block.settings.overline_font.family }}, {{ block.settings.overline_font.fallback_families }};
    font-weight: {{ block.settings.overline_font.weight }};
    font-style: {{ block.settings.overline_font.style }};
    font-size: {{ block.settings.overline_size }}px;
    color: {{ block.settings.overline_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.overline_letter_spacing }}px;
    margin: 0 0 {{ block.settings.overline_spacing }}px;
    line-height: 1.5;
  }

  .ai-text-columns-column-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.column_heading_font.family }}, {{ block.settings.column_heading_font.fallback_families }};
    font-weight: {{ block.settings.column_heading_font.weight }};
    font-style: {{ block.settings.column_heading_font.style }};
    font-size: {{ block.settings.column_heading_size }}px;
    color: {{ block.settings.column_heading_color }};
    margin: 0 0 {{ block.settings.column_heading_spacing }}px;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .ai-text-columns-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: {{ block.settings.body_line_height }};
    margin: 0;
    letter-spacing: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-columns-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap_mobile }}px;
    }

    .ai-text-columns-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-text-columns-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-text-columns-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .ai-text-columns-column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.column_heading_size_mobile }}px;
    }

    .ai-text-columns-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-text-columns-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-columns-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-text-columns-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-text-columns-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-text-columns-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-text-columns-grid-{{ ai_gen_id }}">
      {% if block.settings.column_1_overline != blank or block.settings.column_1_heading != blank or block.settings.column_1_body != blank %}
        <div class="ai-text-columns-column-{{ ai_gen_id }}">
          {% if block.settings.column_1_overline != blank %}
            <p class="ai-text-columns-overline-{{ ai_gen_id }}">{{ block.settings.column_1_overline }}</p>
          {% endif %}
          {% if block.settings.column_1_heading != blank %}
            <h3 class="ai-text-columns-column-heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
          {% endif %}
          {% if block.settings.column_1_body != blank %}
            <div class="ai-text-columns-body-{{ ai_gen_id }}">{{ block.settings.column_1_body }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.column_2_overline != blank or block.settings.column_2_heading != blank or block.settings.column_2_body != blank %}
        <div class="ai-text-columns-column-{{ ai_gen_id }}">
          {% if block.settings.column_2_overline != blank %}
            <p class="ai-text-columns-overline-{{ ai_gen_id }}">{{ block.settings.column_2_overline }}</p>
          {% endif %}
          {% if block.settings.column_2_heading != blank %}
            <h3 class="ai-text-columns-column-heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
          {% endif %}
          {% if block.settings.column_2_body != blank %}
            <div class="ai-text-columns-body-{{ ai_gen_id }}">{{ block.settings.column_2_body }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.column_3_overline != blank or block.settings.column_3_heading != blank or block.settings.column_3_body != blank %}
        <div class="ai-text-columns-column-{{ ai_gen_id }}">
          {% if block.settings.column_3_overline != blank %}
            <p class="ai-text-columns-overline-{{ ai_gen_id }}">{{ block.settings.column_3_overline }}</p>
          {% endif %}
          {% if block.settings.column_3_heading != blank %}
            <h3 class="ai-text-columns-column-heading-{{ ai_gen_id }}">{{ block.settings.column_3_heading }}</h3>
          {% endif %}
          {% if block.settings.column_3_body != blank %}
            <div class="ai-text-columns-body-{{ ai_gen_id }}">{{ block.settings.column_3_body }}</div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

