{% doc %}
  @prompt
    Create another manifesto section that has eyebrow that says "The Mandate" and a  body that says: " At Nancy Vuu Atelier, we believe a suit is more than a garment; it is the physical architecture of a leader’s triumph. Our Seth Eden collection offers world-class bespoke custom suits for men and women, architected with the same precision and soul as our global couture pieces. From our San Jose sanctuary, we serve the discerning executive and visionary clientele of Palo Alto, Los Altos Hills, and Saratoga." I want the words "San Jose Sanctuary" to be linked to my homepage www.nancyvuu.com.  also give me control access to ajust font sizes. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-manifesto-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-manifesto-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-manifesto-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-style: {{ block.settings.eyebrow_font.style }};
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: {{ block.settings.eyebrow_transform }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}em;
    margin: 0 0 {{ block.settings.eyebrow_margin_bottom }}px;
  }

  .ai-manifesto-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.body_font_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  .ai-manifesto-body-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_decoration }};
    transition: color 0.2s ease;
  }

  .ai-manifesto-body-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-manifesto-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-manifesto-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_mobile }}px;
    }

    .ai-manifesto-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-manifesto-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-manifesto-inner-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-manifesto-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow }}
      </div>
    {% endif %}

    {% if block.settings.body != blank %}
      <div class="ai-manifesto-body-{{ ai_gen_id }}">
        {{ block.settings.body }}
      </div>
    {% endif %}
  </div>
</div>

