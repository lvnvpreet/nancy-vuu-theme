{% doc %}
  @prompt
    create a small (height is between 1/30 of a page to 1/4 of a page) section  i want to have the option to make the segment height completely adjustable even to the point of being a fine thin line.  add eyebrow in manrope and title in bodoni moda , ALLOW ME TO CHOOSE BACKGROUND COLOR, GIVE ME CONTROL ACCESS TO ADJUST SPACING IN BETWEEN WORDS AND LETTERS, AND THE ACCESS TO ADJUST FONT SIZE
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-adjustable-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_height }}px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .ai-adjustable-section__eyebrow-{{ ai_gen_id }} {
    font-family: 'Manrope', {{ block.settings.type_body_font.family }}, sans-serif;
    font-size: {{ block.settings.eyebrow_font_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}em;
    word-spacing: {{ block.settings.eyebrow_word_spacing }}em;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_between_eyebrow_title }}px 0;
    text-transform: uppercase;
    font-weight: 400;
  }

  .ai-adjustable-section__title-{{ ai_gen_id }} {
    font-family: 'Bodoni Moda', {{ block.settings.type_header_font.family }}, serif;
    font-size: {{ block.settings.title_font_size }}px;
    letter-spacing: {{ block.settings.title_letter_spacing }}em;
    word-spacing: {{ block.settings.title_word_spacing }}em;
    color: {{ block.settings.text_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-adjustable-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_height | times: 0.7 }}px 20px;
    }

    .ai-adjustable-section__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size | times: 0.8 }}px;
    }

    .ai-adjustable-section__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-adjustable-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.eyebrow != blank %}
    <div class="ai-adjustable-section__eyebrow-{{ ai_gen_id }}">
      {{ block.settings.eyebrow }}
    </div>
  {% endif %}

  {% if block.settings.title != blank %}
    <h2 class="ai-adjustable-section__title-{{ ai_gen_id }}">
      {{ block.settings.title }}
    </h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Adjustable text section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Introducing"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Sanctuary Experiences"
    },
    {
      "type": "header",
      "content": "Section dimensions"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 1,
      "max": 401,
      "step": 4,
      "unit": "px",
      "default": 121
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0f0f0f"
    },
    {
      "type": "header",
      "content": "Eyebrow typography"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Font size",
      "min": 8,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "unit": "em",
      "default": 0.1
    },
    {
      "type": "range",
      "id": "eyebrow_word_spacing",
      "label": "Word spacing",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "unit": "em",
      "default": 0
    },
    {
      "type": "header",
      "content": "Title typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Font size",
      "min": 16,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "unit": "em",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_word_spacing",
      "label": "Word spacing",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "unit": "em",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_between_eyebrow_title",
      "label": "Space between eyebrow and title",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Adjustable text section"
    }
  ]
}
{% endschema %}
