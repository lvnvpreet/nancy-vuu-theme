{% doc %}
  @prompt
    Shopify AI Task: Insert 'Legacy of Influence' Segment on Press Page
    
    1. Placement: Insert this new section directly after the Hero, before the logo grid.
    
    2. Layout: A "Staggered, Alternating Grid" (Image/Text then Text/Image) with high visual contrast and extreme padding (min. 120px) to signify Quiet Luxury.
    
    3. Content Block One: The Cannes Gateway
    
        Image (The Assignment): High-resolution photo of Nancy and the teenagers at Cannes Film Festival.
    
        Treatment: Black & White (high contrast, desaturated) to strip away time and focus on the moment of Dignity.
    
        Typography: Style all H-headers in soft grey Bodoni Serif (Letter-spaced) and body copy in clear, regular Serif.
    
            Eyebrow: THE ASSIGNMENT: CANNES
    
            Headline: “A Decade of Opening Doors for the Next Generation.”
    
            Body: > "True stewardship isn't just about walking the carpet; it's about building a gateway for the next generation to step into their own original design. For years, the House has used the world’s most prestigious stages as a platform to mentor young visionaries—cloaking them in the dignity of couture and the reality of their high calling."
    
    4. Content Block Two: Cinematic Truth
    
        Image (The Award): Photo of Nancy at the podium accepting the award.
    
        Treatment: Black & White (high contrast) to create a "Cinematic Still" effect.
    
        Typography:
    
            Eyebrow: THE RECOGNITION
    
            Headline: “Establishing the standard for Cinematic Truth.”
    
            Body: > "Recognition as 'Best Fashion Film' is a testament to our belief that the lens should be a mirror for the soul. Whether through a single garment or a high-definition film, we are dedicated to architecting narratives of restoration that remain timeless—long after the flashbulbs fade." give me control access to increase padding on top and bottom of segment and access to change and reword content. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-legacy-influence-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-legacy-influence__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .ai-legacy-influence__block-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: center;
    margin-bottom: {{ block.settings.block_spacing }}px;
  }

  .ai-legacy-influence__block-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-legacy-influence__block--reverse-{{ ai_gen_id }} {
    direction: rtl;
  }

  .ai-legacy-influence__block--reverse-{{ ai_gen_id }} > * {
    direction: ltr;
  }

  .ai-legacy-influence__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-legacy-influence__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale({{ block.settings.image_grayscale }}%) contrast({{ block.settings.image_contrast }}%);
  }

  .ai-legacy-influence__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-legacy-influence__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-legacy-influence__content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-legacy-influence__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.eyebrow_margin }}px;
  }

  .ai-legacy-influence__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.headline_size }}px;
    letter-spacing: {{ block.settings.headline_letter_spacing }}em;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    margin-bottom: {{ block.settings.headline_margin }}px;
  }

  .ai-legacy-influence__body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-legacy-influence__container-{{ ai_gen_id }} {
      padding: 0 24px;
    }

    .ai-legacy-influence__block-{{ ai_gen_id }},
    .ai-legacy-influence__block--reverse-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      direction: ltr;
    }

    .ai-legacy-influence__content-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-legacy-influence__headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.75);
    }
  }
{% endstyle %}

<ai-legacy-influence-{{ ai_gen_id }} class="ai-legacy-influence-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-legacy-influence__container-{{ ai_gen_id }}">
    <div class="ai-legacy-influence__block-{{ ai_gen_id }}">
      <div class="ai-legacy-influence__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.block_1_image %}
          <img
            src="{{ block.settings.block_1_image | image_url: width: 1400 }}"
            alt="{{ block.settings.block_1_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.block_1_image.width }}"
            height="{{ block.settings.block_1_image.height }}"
            class="ai-legacy-influence__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-legacy-influence__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="ai-legacy-influence__content-{{ ai_gen_id }}">
        {% if block.settings.block_1_eyebrow != blank %}
          <div class="ai-legacy-influence__eyebrow-{{ ai_gen_id }}">
            {{ block.settings.block_1_eyebrow }}
          </div>
        {% endif %}
        {% if block.settings.block_1_headline != blank %}
          <h2 class="ai-legacy-influence__headline-{{ ai_gen_id }}">
            {{ block.settings.block_1_headline }}
          </h2>
        {% endif %}
        {% if block.settings.block_1_body != blank %}
          <div class="ai-legacy-influence__body-{{ ai_gen_id }}">
            {{ block.settings.block_1_body }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-legacy-influence__block-{{ ai_gen_id }} ai-legacy-influence__block--reverse-{{ ai_gen_id }}">
      <div class="ai-legacy-influence__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.block_2_image %}
          <img
            src="{{ block.settings.block_2_image | image_url: width: 1400 }}"
            alt="{{ block.settings.block_2_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.block_2_image.width }}"
            height="{{ block.settings.block_2_image.height }}"
            class="ai-legacy-influence__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-legacy-influence__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="ai-legacy-influence__content-{{ ai_gen_id }}">
        {% if block.settings.block_2_eyebrow != blank %}
          <div class="ai-legacy-influence__eyebrow-{{ ai_gen_id }}">
            {{ block.settings.block_2_eyebrow }}
          </div>
        {% endif %}
        {% if block.settings.block_2_headline != blank %}
          <h2 class="ai-legacy-influence__headline-{{ ai_gen_id }}">
            {{ block.settings.block_2_headline }}
          </h2>
        {% endif %}
        {% if block.settings.block_2_body != blank %}
          <div class="ai-legacy-influence__body-{{ ai_gen_id }}">
            {{ block.settings.block_2_body }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</ai-legacy-influence-{{ ai_gen_id }}>

