{% doc %}
  @prompt
    create a small (height is between 1/30 of a page to 1/4 of a page) section that i can insert a photo to be full blead. give me control to do a white or black adjustable overlay i want to have the option to make the segment height completely adjustable even to the point of being a fine thin line. also give me the option of putting a video or photo as a full bleed. add eyebrow in manrope and title in bodoni moda 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-strip-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height }}vh;
    overflow: hidden;
    display: block;
  }

  .ai-media-strip__media-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-media-strip__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    {% if block.settings.overlay_color == 'black' %}
      background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    {% elsif block.settings.overlay_color == 'white' %}
      background-color: rgba(255, 255, 255, {{ block.settings.overlay_opacity }});
    {% endif %}
    pointer-events: none;
  }

  .ai-media-strip__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    padding: 20px;
    text-align: {% if block.settings.horizontal_alignment == 'flex-start' %}left{% elsif block.settings.horizontal_alignment == 'flex-end' %}right{% else %}center{% endif %};
  }

  .ai-media-strip__eyebrow-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ai-media-strip__title-{{ ai_gen_id }} {
    font-family: 'Bodoni Moda', serif;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-media-strip__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-media-strip__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .ai-media-strip__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.8 }}px;
    }

    .ai-media-strip__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-media-strip-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.media_type == 'image' %}
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-media-strip__media-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-media-strip__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  {% elsif block.settings.media_type == 'video' %}
    {% if block.settings.video %}
      <video
        class="ai-media-strip__media-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="{{ block.settings.video }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-media-strip__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  {% endif %}

  <div class="ai-media-strip__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-media-strip__content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-media-strip__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}
    {% if block.settings.title != blank %}
      <h2 class="ai-media-strip__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Media strip",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "video",
      "label": "Video URL (MP4)"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 3,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 25
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "select",
      "id": "overlay_color",
      "label": "Overlay color",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "black",
          "label": "Black"
        },
        {
          "value": "white",
          "label": "White"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Horizontal alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Media strip"
    }
  ]
}
{% endschema %}
