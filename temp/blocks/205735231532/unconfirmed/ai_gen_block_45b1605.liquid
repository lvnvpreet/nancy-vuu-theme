{% doc %}
  @prompt
    "Create a new section called 'Global Distinctions.'
    
        Header: Small grey eyebrow 'DISTINCTION & IMPACT' followed by a large serif Title 'Global Accolades.'
    
        Logo Bar: Below the title, insert a full-width scrolling bar of desaturated (grayscale) logos: KTVU, Oscars, Grammys, Cannes, Vogue, Bazaar, Elle, Huffington Post.
    
        The List: Below the logos, create a 3-column clean text grid. Use Bodoni Serif for headers.
    
            Col 1: 'Cinematic Excellence' - Include "Unto Me" Film Honors details.
    
            Col 2: 'Leadership Recognition' - Include Silicon Valley Business Journal/Women on the Move.
    
            Col 3: 'Humanitarian & Diplomatic' - Include The Courage Award and Big Ben Award.
    
        Styling: Maintain 100px padding and a white background to keep it looking like a gallery plaque."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-global-distinctions-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
    width: 100%;
  }

  .ai-global-distinctions__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-global-distinctions__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-global-distinctions__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: 16px;
  }

  .ai-global-distinctions__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-global-distinctions__logo-bar-{{ ai_gen_id }} {
    overflow: hidden;
    margin-bottom: 80px;
    position: relative;
    width: 100%;
  }

  .ai-global-distinctions__logo-track-{{ ai_gen_id }} {
    display: flex;
    gap: 60px;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    width: max-content;
  }

  .ai-global-distinctions__logo-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: 40px;
    display: flex;
    align-items: center;
  }

  .ai-global-distinctions__logo-item-{{ ai_gen_id }} img {
    height: 100%;
    width: auto;
    filter: grayscale(100%);
    opacity: 0.6;
  }

  .ai-global-distinctions__logo-placeholder-{{ ai_gen_id }} {
    height: 40px;
    width: 120px;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-global-distinctions__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }

  .ai-global-distinctions__column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-global-distinctions__column-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: 20px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px 0;
    line-height: 1.3;
  }

  .ai-global-distinctions__column-content-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 14px;
    line-height: 1.8;
    color: {{ block.settings.text_color }};
  }

  .ai-global-distinctions__column-content-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-global-distinctions__column-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-global-distinctions__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-global-distinctions__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-global-distinctions__logo-track-{{ ai_gen_id }} {
      gap: 40px;
    }
  }
{% endstyle %}

<global-distinctions-{{ ai_gen_id }} class="ai-global-distinctions-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-global-distinctions__container-{{ ai_gen_id }}">
    <div class="ai-global-distinctions__header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-global-distinctions__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {% endif %}
      {% if block.settings.title != blank %}
        <h2 class="ai-global-distinctions__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
    </div>

    <div class="ai-global-distinctions__logo-bar-{{ ai_gen_id }}">
      <div class="ai-global-distinctions__logo-track-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          <div class="ai-global-distinctions__logo-item-{{ ai_gen_id }}">
            {% if logo %}
              <img src="{{ logo | image_url: height: 80 }}" alt="Logo {{ i }}" loading="lazy">
            {% else %}
              <div class="ai-global-distinctions__logo-placeholder-{{ ai_gen_id }}">Logo {{ i }}</div>
            {% endif %}
          </div>
        {% endfor %}
        {% for i in (1..8) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          <div class="ai-global-distinctions__logo-item-{{ ai_gen_id }}">
            {% if logo %}
              <img src="{{ logo | image_url: height: 80 }}" alt="Logo {{ i }}" loading="lazy">
            {% else %}
              <div class="ai-global-distinctions__logo-placeholder-{{ ai_gen_id }}">Logo {{ i }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-global-distinctions__grid-{{ ai_gen_id }}">
      <div class="ai-global-distinctions__column-{{ ai_gen_id }}">
        {% if block.settings.column_1_title != blank %}
          <h3 class="ai-global-distinctions__column-title-{{ ai_gen_id }}">{{ block.settings.column_1_title }}</h3>
        {% endif %}
        {% if block.settings.column_1_content != blank %}
          <div class="ai-global-distinctions__column-content-{{ ai_gen_id }}">{{ block.settings.column_1_content }}</div>
        {% endif %}
      </div>

      <div class="ai-global-distinctions__column-{{ ai_gen_id }}">
        {% if block.settings.column_2_title != blank %}
          <h3 class="ai-global-distinctions__column-title-{{ ai_gen_id }}">{{ block.settings.column_2_title }}</h3>
        {% endif %}
        {% if block.settings.column_2_content != blank %}
          <div class="ai-global-distinctions__column-content-{{ ai_gen_id }}">{{ block.settings.column_2_content }}</div>
        {% endif %}
      </div>

      <div class="ai-global-distinctions__column-{{ ai_gen_id }}">
        {% if block.settings.column_3_title != blank %}
          <h3 class="ai-global-distinctions__column-title-{{ ai_gen_id }}">{{ block.settings.column_3_title }}</h3>
        {% endif %}
        {% if block.settings.column_3_content != blank %}
          <div class="ai-global-distinctions__column-content-{{ ai_gen_id }}">{{ block.settings.column_3_content }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</global-distinctions-{{ ai_gen_id }}>

<script>
  (function() {
    class GlobalDistinctions{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupLogoScroll();
      }

      setupLogoScroll() {
        const track = this.querySelector('.ai-global-distinctions__logo-track-{{ ai_gen_id }}');
        if (!track) return;

        track.addEventListener('mouseenter', () => {
          track.style.animationPlayState = 'paused';
        });

        track.addEventListener('mouseleave', () => {
          track.style.animationPlayState = 'running';
        });
      }
    }

    customElements.define('global-distinctions-{{ ai_gen_id }}', GlobalDistinctions{{ ai_gen_id }});
  })();
</script>

