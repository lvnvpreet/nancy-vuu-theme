{% doc %}
  @prompt
    Create a clean, horizontal text-link row section to sit immediately below the 3-column banner. It should look like a premium editorial sub-menu. Center-align four text links spaced evenly across the screen in a luxury serif font.
    
    Link 1 text: '[ Flower Girl Gowns ]'
    Link 2 text: '[ Suiting & Ring Bearer ]'
    Link 3 text: '[ Bar & Bat Mitzvah ]'
    Link 4 text: '[ Quinceañera, Prom & Gala ]'
    
    Ensure the design is understated, sleek, and matches a high-end luxury brand layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-submenu-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 20px;
  }

  .ai-editorial-submenu__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.link_spacing }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .ai-editorial-submenu__link-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    letter-spacing: {{ block.settings.letter_spacing }}em;
    transition: color 0.3s ease, opacity 0.3s ease;
    white-space: nowrap;
  }

  .ai-editorial-submenu__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_color }};
    opacity: {{ block.settings.hover_opacity }};
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-submenu__container-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_link_spacing }}px;
    }

    .ai-editorial-submenu__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
    }
  }
{% endstyle %}

<editorial-submenu-{{ ai_gen_id }}
  class="ai-editorial-submenu-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <nav class="ai-editorial-submenu__container-{{ ai_gen_id }}" role="navigation" aria-label="Editorial submenu">
    <a href="{{ block.settings.link_1_url }}" class="ai-editorial-submenu__link-{{ ai_gen_id }}">
      {{ block.settings.link_1_text }}
    </a>
    <a href="{{ block.settings.link_2_url }}" class="ai-editorial-submenu__link-{{ ai_gen_id }}">
      {{ block.settings.link_2_text }}
    </a>
    <a href="{{ block.settings.link_3_url }}" class="ai-editorial-submenu__link-{{ ai_gen_id }}">
      {{ block.settings.link_3_text }}
    </a>
    <a href="{{ block.settings.link_4_url }}" class="ai-editorial-submenu__link-{{ ai_gen_id }}">
      {{ block.settings.link_4_text }}
    </a>
  </nav>
</editorial-submenu-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialSubmenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-editorial-submenu__link-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.links.forEach((link) => {
          if (!link.getAttribute('href') || link.getAttribute('href') === '') {
            link.setAttribute('aria-disabled', 'true');
            link.style.pointerEvents = 'none';
            link.style.opacity = '0.5';
          }
        });
      }
    }

    customElements.define('editorial-submenu-{{ ai_gen_id }}', EditorialSubmenu{{ ai_gen_id }});
  })();
</script>

