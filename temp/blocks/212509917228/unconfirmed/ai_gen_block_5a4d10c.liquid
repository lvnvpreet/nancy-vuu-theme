{% doc %}
  @prompt
    Create a clean, horizontal text-link row section for a luxury editorial sub-menu. Center-align four text links spaced evenly across the full width of the screen in a luxury serif font (such as Bodoni Moda or similar). The links should be: 1. '[ Flower Girl Gowns ]' 2. '[ Suiting & Ring Bearer ]' 3. '[ Bar & Bat Mitzvah ]' 4. '[ Quinceañera, Prom & Gala ]' Design requirements: Understated, sleek, high-end luxury brand aesthetic. Horizontal single-row layout, evenly spaced. Serif font, refined letter-spacing (tracked out), small-to-medium font size. Minimal padding above and below (tight, editorial). Subtle hover state (e.g. underline or slight opacity shift). No background color or a very subtle neutral (off-white or transparent). Each link should be customizable (text + URL) via theme editor settings. Section should be easy to position immediately below a 3-column banner section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-submenu-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-luxury-submenu__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.link_spacing }}px;
    max-width: 100%;
    padding: 0 20px;
    flex-wrap: wrap;
  }

  .ai-luxury-submenu__link-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    letter-spacing: {{ block.settings.letter_spacing }}em;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: opacity 0.3s ease, text-decoration 0.3s ease;
    white-space: nowrap;
  }

  .ai-luxury-submenu__link-{{ ai_gen_id }}:hover {
    {% if block.settings.hover_style == 'underline' %}
      text-decoration: underline;
      text-underline-offset: 4px;
    {% elsif block.settings.hover_style == 'opacity' %}
      opacity: 0.6;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-submenu__container-{{ ai_gen_id }} {
      gap: {{ block.settings.link_spacing | divided_by: 2 }}px;
    }

    .ai-luxury-submenu__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<luxury-submenu-{{ ai_gen_id }}
  class="ai-luxury-submenu-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <nav class="ai-luxury-submenu__container-{{ ai_gen_id }}" aria-label="Secondary navigation">
    {% if block.settings.link_1_text != blank %}
      <a
        href="{{ block.settings.link_1_url }}"
        class="ai-luxury-submenu__link-{{ ai_gen_id }}"
      >
        {{ block.settings.link_1_text }}
      </a>
    {% endif %}

    {% if block.settings.link_2_text != blank %}
      <a
        href="{{ block.settings.link_2_url }}"
        class="ai-luxury-submenu__link-{{ ai_gen_id }}"
      >
        {{ block.settings.link_2_text }}
      </a>
    {% endif %}

    {% if block.settings.link_3_text != blank %}
      <a
        href="{{ block.settings.link_3_url }}"
        class="ai-luxury-submenu__link-{{ ai_gen_id }}"
      >
        {{ block.settings.link_3_text }}
      </a>
    {% endif %}

    {% if block.settings.link_4_text != blank %}
      <a
        href="{{ block.settings.link_4_url }}"
        class="ai-luxury-submenu__link-{{ ai_gen_id }}"
      >
        {{ block.settings.link_4_text }}
      </a>
    {% endif %}
  </nav>
</luxury-submenu-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxurySubmenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-luxury-submenu__link-{{ ai_gen_id }}');
        links.forEach((link) => {
          if (!link.getAttribute('href') || link.getAttribute('href') === '') {
            link.setAttribute('tabindex', '-1');
            link.setAttribute('aria-disabled', 'true');
          }
        });
      }
    }

    customElements.define('luxury-submenu-{{ ai_gen_id }}', LuxurySubmenu{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Luxury submenu",
  "settings": [
    {
      "type": "header",
      "content": "Link 1"
    },
    {
      "type": "text",
      "id": "link_1_text",
      "label": "Text",
      "default": "[ Flower Girl Gowns ]"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Link 2"
    },
    {
      "type": "text",
      "id": "link_2_text",
      "label": "Text",
      "default": "[ Suiting & Ring Bearer ]"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Link 3"
    },
    {
      "type": "text",
      "id": "link_3_text",
      "label": "Text",
      "default": "[ Bar & Bat Mitzvah ]"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Link 4"
    },
    {
      "type": "text",
      "id": "link_4_text",
      "label": "Text",
      "default": "[ Quinceañera, Prom & Gala ]"
    },
    {
      "type": "url",
      "id": "link_4_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "unit": "em",
      "default": 0.1
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "link_spacing",
      "label": "Link spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "select",
      "id": "hover_style",
      "label": "Hover effect",
      "options": [
        {
          "value": "underline",
          "label": "Underline"
        },
        {
          "value": "opacity",
          "label": "Opacity shift"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "underline"
    }
  ],
  "presets": [
    {
      "name": "Luxury submenu"
    }
  ]
}
{% endschema %}
