{% doc %}
  @prompt
    Generate a single, centered rich-text block section to place at the very bottom of the page layout, sitting directly below the product grid. Use a classic, elegant typography layout with a light background.
    
    Insert this exact text paragraph:
    'The House of Nancy Vuu architects legacy children’s and teen couture for discerning families across Northern California. From master-tailored boys Bar Mitzvah suits and velvet ring bearer attire in Atherton and Palo Alto, to custom flower girl dresses and luxury bespoke Quinceañera or high-end prom gowns in San Francisco and San Jose, our atelier ensures the next generation enters their sacred milestones in unparalleled, made-to-measure luxury.'
    
    Ensure the section feels cohesive with an elite fashion house footprint. give me complete control to make any changes with content and typography
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-richtext-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .ai-footer-richtext__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-footer-richtext__content-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
  }

  .ai-footer-richtext__content-{{ ai_gen_id }} p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-footer-richtext-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 16px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-footer-richtext__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-footer-richtext-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-richtext__container-{{ ai_gen_id }}">
    <div class="ai-footer-richtext__content-{{ ai_gen_id }}">
      {{ block.settings.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer rich text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Text",
      "default": "<p>The House of Nancy Vuu architects legacy children's and teen couture for discerning families across Northern California. From master-tailored boys Bar Mitzvah suits and velvet ring bearer attire in Atherton and Palo Alto, to custom flower girl dresses and luxury bespoke Quinceañera or high-end prom gowns in San Francisco and San Jose, our atelier ensures the next generation enters their sacred milestones in unparalleled, made-to-measure luxury.</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 0.2,
      "step": 0.1,
      "unit": "em",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0f0f0f"
    }
  ],
  "presets": [
    {
      "name": "Footer rich text"
    }
  ]
}
{% endschema %}
