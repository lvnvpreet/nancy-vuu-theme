      "id": "column_2_text",
      "label": "Text",
      "default": "Select an established House design, meticulously tailored and adjusted to your child or teen's precise structural proportions."
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "text",
      "id": "column_3_heading",
      "label": "Heading",
      "default": "III — Bespoke Commission"
    },
    {
