{% doc %}
  @prompt
    Generate a minimalist, high-end 3-column multi-column text section to place at the absolute top of the page layout, directly beneath the header menu. The layout must have thin, elegant borders, generous luxury whitespace, and clean editorial typography. Do not include images.
    
    Column 1 Heading: 'I — The Runway Collection'
    Column 1 Text: 'Explore and acquire our current architectural couture silhouettes, ready for immediate seasonal curation.'
    
    Column 2 Heading: 'II — Made-to-Measure'
    Column 2 Text: 'Select an established House design, meticulously tailored and adjusted to your child or teen’s precise structural proportions.'
    
    Column 3 Heading: 'III — Bespoke Commission'
    Column 3 Text: 'An elite, blank-canvas design journey to architect an original, one-of-a-kind masterpiece for your family's next generation legacy milestone.'
    
    Set all background colors to clean white or transparent to match a high-fashion atelier aesthetic.  Give me control access to change font typography, font size and padding in all areas.  Use Bodoni and Manrope to be consistent with my current page
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-column-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-three-column-text__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-three-column-text__column-{{ ai_gen_id }} {
    padding: {{ block.settings.column_padding }}px;
    border-right: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.heading_text_gap }}px;
  }

  .ai-three-column-text__column-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .ai-three-column-text__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_font_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}em;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-transform: {{ block.settings.heading_text_transform }};
  }

  .ai-three-column-text__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.body_font_size }}px;
    line-height: {{ block.settings.body_line_height }};
    letter-spacing: {{ block.settings.body_letter_spacing }}em;
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-three-column-text__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .ai-three-column-text__column-{{ ai_gen_id }} {
      border-right: none;
      border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    }

    .ai-three-column-text__column-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }

    .ai-three-column-text__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.85 }}px;
    }

    .ai-three-column-text__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<three-column-text-{{ ai_gen_id }} class="ai-three-column-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-column-text__container-{{ ai_gen_id }}">
    <div class="ai-three-column-text__column-{{ ai_gen_id }}">
      <h3 class="ai-three-column-text__heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
      <p class="ai-three-column-text__text-{{ ai_gen_id }}">{{ block.settings.column_1_text }}</p>
    </div>

    <div class="ai-three-column-text__column-{{ ai_gen_id }}">
      <h3 class="ai-three-column-text__heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
      <p class="ai-three-column-text__text-{{ ai_gen_id }}">{{ block.settings.column_2_text }}</p>
    </div>

    <div class="ai-three-column-text__column-{{ ai_gen_id }}">
      <h3 class="ai-three-column-text__heading-{{ ai_gen_id }}">{{ block.settings.column_3_heading }}</h3>
      <p class="ai-three-column-text__text-{{ ai_gen_id }}">{{ block.settings.column_3_text }}</p>
    </div>
  </div>
</three-column-text-{{ ai_gen_id }}>

<script>
  (function() {
    class ThreeColumnText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('three-column-text-{{ ai_gen_id }}', ThreeColumnText{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Three column text",
  "settings": [
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "column_1_heading",
      "label": "Heading",
      "default": "I — The Runway Collection"
    },
    {
      "type": "textarea",
      "id": "column_1_text",
      "label": "Text",
      "default": "Explore and acquire our current architectural couture silhouettes, ready for immediate seasonal curation."
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "column_2_heading",
      "label": "Heading",
      "default": "II — Made-to-Measure"
    },
    {
