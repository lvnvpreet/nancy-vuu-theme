{% doc %}
  @prompt
    {% comment %}
      Custom Luxury Hero Header with Unlimited Layout Control
    {% endcomment %}
    
    <div class="luxury-hero-{{ section.id }} {% if section.settings.full_width %}hero-full-width{% endif %}">
      
      {%- if section.settings.video_url != blank -%}
        <video class="hero-bg-video" autoplay loop muted playsinline poster="{{ section.settings.image | img_url: '2000x' }}">
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {%- elif section.settings.image != blank -%}
        <img class="hero-bg-image" src="{{ section.settings.image | img_url: '2000x' }}" alt="{{ section.settings.h1_title | escape }}">
      {%- endif -%}
    
      <div class="hero-overlay" style="background-color: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
    
      <div class="hero-content-box">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        
        {%- if section.settings.h1_title != blank -%}
          <h1 class="hero-h1">{{ section.settings.h1_title }}</h1>
        {%- endif -%}
    
        {%- if section.settings.content_text != blank -%}
          <div class="hero-description">{{ section.settings.content_text }}</div>
        {%- endif -%}
    
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link }}" class="hero-btn">{{ section.settings.btn_label }}</a>
        {%- endif -%}
      </div>
    </div>
    
    <style>
    .luxury-hero-{{ section.id }} {
      position: relative;
      width: 100%;
      min-height: {{ section.settings.hero_height }}vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-sizing: border-box;
      padding: 40px 20px;
    }
    .hero-bg-image, .hero-bg-video {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: translate(-50%, -50%);
      z-index: 1;
    }
    .hero-overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      z-index: 2;
    }
    .luxury-hero-{{ section.id }} .hero-content-box {
      position: relative;
      z-index: 3;
      width: 100%;
      max-width: {{ section.settings.box_max_width }}px;
      text-align: {{ section.settings.text_alignment }};
      padding: {{ section.settings.box_padding }}px;
      box-sizing: border-box;
    }
    
    /* Eyebrow Typography Styling */
    .luxury-hero-{{ section.id }} .hero-eyebrow {
      font-family: {{ section.settings.eyebrow_font }};
      font-size: {{ section.settings.eyebrow_size }}px;
      font-weight: {{ section.settings.eyebrow_weight }};
      color: {{ section.settings.color_text }};
      letter-spacing: {{ section.settings.eyebrow_word_space }}px;
      line-height: {{ section.settings.eyebrow_line_space }};
      margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
      text-transform: uppercase;
    }
    
    /* H1 Title Typography Styling */
    .luxury-hero-{{ section.id }} .hero-h1 {
      font-family: {{ section.settings.h1_font }};
      font-size: {{ section.settings.h1_size }}px;
      font-weight: {{ section.settings.h1_weight }};
      color: {{ section.settings.color_text }};
      letter-spacing: {{ section.settings.h1_word_space }}px;
      line-height: {{ section.settings.h1_line_space }};
      margin-top: 0;
      margin-bottom: {{ section.settings.h1_margin_bottom }}px;
    }
    
    /* Content/Manifesto Typography Styling */
    .luxury-hero-{{ section.id }} .hero-description {
      font-family: {{ section.settings.content_font }};
      font-size: {{ section.settings.content_size }}px;
      font-weight: {{ section.settings.content_weight }};
      color: {{ section.settings.color_text }};
      letter-spacing: {{ section.settings.content_word_space }}px;
      line-height: {{ section.settings.content_line_space }};
      margin-bottom: {{ section.settings.content_margin_bottom }}px;
    }
    
    /* Button Customizing */
    .luxury-hero-{{ section.id }} .hero-btn {
      display: inline-block;
      font-family: {{ section.settings.content_font }};
      padding: 12px 35px;
      text-decoration: none;
      text-transform: uppercase;
      font-size: 11px;
      letter-spacing: 2px;
      color: {{ section.settings.color_text }};
      border: 1px solid {{ section.settings.color_text }};
      background: transparent;
      transition: all 0.3s ease;
      margin-top: 15px;
    }
    .luxury-hero-{{ section.id }} .hero-btn:hover {
      background-color: {{ section.settings.color_text }};
      color: #000;
    }
    
    @media (max-width: 768px) {
      .luxury-hero-{{ section.id }} .hero-h1 { font-size: calc({{ section.settings.h1_size }}px * 0.7); }
      .luxury-hero-{{ section.id }} .hero-description { font-size: calc({{ section.settings.content_size }}px * 0.9); }
    }
    </style>
    
    {% schema %}
    {
      "name": "Luxury Architecture Hero",
      "settings": [
        { "type": "header", "content": "Media Configuration" },
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "video_url", "label": "Background Video MP4 URL", "info": "Upload your video to Shopify Files and copy/paste the link here." },
