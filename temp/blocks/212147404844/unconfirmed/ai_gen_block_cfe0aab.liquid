{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .luxury-hero-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    min-height: {{ block.settings.hero_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
    padding: 40px 20px;
  }

  .hero-bg-image-{{ ai_gen_id }},
  .hero-bg-video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
  }

  .hero-content-box-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ block.settings.box_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.box_padding }}px;
    box-sizing: border-box;
  }

  .hero-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-style: {{ block.settings.eyebrow_font.style }};
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.color_text }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    line-height: {{ block.settings.eyebrow_line_height }};
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
    text-transform: uppercase;
  }

  .hero-h1-{{ ai_gen_id }} {
    font-family: {{ block.settings.h1_font.family }}, {{ block.settings.h1_font.fallback_families }};
    font-weight: {{ block.settings.h1_font.weight }};
    font-style: {{ block.settings.h1_font.style }};
    font-size: {{ block.settings.h1_size }}px;
    color: {{ block.settings.color_text }};
    letter-spacing: {{ block.settings.h1_letter_spacing }}px;
    line-height: {{ block.settings.h1_line_height }};
    margin-top: 0;
    margin-bottom: {{ block.settings.h1_margin_bottom }}px;
  }

  .hero-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.content_font.family }}, {{ block.settings.content_font.fallback_families }};
    font-weight: {{ block.settings.content_font.weight }};
    font-style: {{ block.settings.content_font.style }};
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.color_text }};
    letter-spacing: {{ block.settings.content_letter_spacing }}px;
    line-height: {{ block.settings.content_line_height }};
    margin-bottom: {{ block.settings.content_margin_bottom }}px;
  }

  .hero-btn-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.content_font.family }}, {{ block.settings.content_font.fallback_families }};
    padding: {{ block.settings.btn_padding_vertical }}px {{ block.settings.btn_padding_horizontal }}px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: {{ block.settings.btn_font_size }}px;
    letter-spacing: {{ block.settings.btn_letter_spacing }}px;
    color: {{ block.settings.color_text }};
    border: {{ block.settings.btn_border_width }}px solid {{ block.settings.color_text }};
    background: transparent;
    transition: all 0.3s ease;
    margin-top: {{ block.settings.btn_margin_top }}px;
    border-radius: {{ block.settings.btn_border_radius }}px;
  }

  .hero-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.btn_hover_bg }};
    color: {{ block.settings.btn_hover_text }};
    border-color: {{ block.settings.btn_hover_bg }};
  }

  @media (max-width: 768px) {
    .luxury-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}vh;
    }

    .hero-h1-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.h1_size }}px * 0.7);
    }

    .hero-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.content_size }}px * 0.9);
    }

    .hero-eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="luxury-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.video_url != blank %}
    <video
      class="hero-bg-video-{{ ai_gen_id }}"
      autoplay
      loop
      muted
      playsinline
      {% if block.settings.image != blank %}
        poster="{{ block.settings.image | image_url: width: 2000 }}"
      {% endif %}
    >
      <source src="{{ block.settings.video_url }}" type="video/mp4">
    </video>
  {% elsif block.settings.image != blank %}
    <img
      class="hero-bg-image-{{ ai_gen_id }}"
      src="{{ block.settings.image | image_url: width: 2000 }}"
      alt="{{ block.settings.h1_title | escape }}"
      loading="lazy"
      width="2000"
      height="1333"
    >
  {% endif %}

  <div class="hero-overlay-{{ ai_gen_id }}"></div>

  <div class="hero-content-box-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <p class="hero-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</p>
    {% endif %}

    {% if block.settings.h1_title != blank %}
      <h1 class="hero-h1-{{ ai_gen_id }}">{{ block.settings.h1_title }}</h1>
    {% endif %}

    {% if block.settings.content_text != blank %}
      <div class="hero-description-{{ ai_gen_id }}">{{ block.settings.content_text }}</div>
    {% endif %}

    {% if block.settings.btn_label != blank %}
      <a href="{{ block.settings.btn_link }}" class="hero-btn-{{ ai_gen_id }}">
        {{ block.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Luxury hero",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background video URL",
      "info": "Upload MP4 to Shopify Files and paste the link here"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Height (desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Height (mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "h1_title",
      "label": "Heading",
      "default": "Bespoke Bridal Gowns"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "Description",
      "default": "<p>Custom wedding dresses crafted with quiet luxury and timeless elegance.</p>"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "box_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 800
    },
    {
      "type": "range",
      "id": "box_padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Content padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Eyebrow typography"
    },
    {
      "type": "font_picker",
      "id": "eyebrow_font",
      "label": "Font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 2
    },
    {
      "type": "range",
      "id": "eyebrow_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "eyebrow_margin_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bottom margin",
      "default": 16
    },
    {
      "type": "header",
      "content": "Heading typography"
    },
    {
      "type": "font_picker",
      "id": "h1_font",
      "label": "Font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "range",
      "id": "h1_size",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 64
    },
    {
      "type": "range",
