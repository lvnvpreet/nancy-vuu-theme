{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-hero-{{ ai_gen_id }} {
    grid-column: 1 / 13;
    position: relative;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.hero_height }}px;
    object-fit: cover;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.hero_height }}px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-hero-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.hero_content_padding }}px;
    left: {{ block.settings.hero_content_padding }}px;
    right: {{ block.settings.hero_content_padding }}px;
    color: {{ block.settings.hero_text_color }};
    background: {{ block.settings.hero_overlay_color }};
    padding: {{ block.settings.hero_content_padding }}px;
  }

  .ai-editorial-hero-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .ai-editorial-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    line-height: 1.1;
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-editorial-hero-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.5;
    margin: 0;
    opacity: 0.9;
  }

  .ai-editorial-feature-{{ ai_gen_id }} {
    grid-column: 1 / 8;
    display: flex;
    flex-direction: column;
  }

  .ai-editorial-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.feature_height }}px;
    object-fit: cover;
    margin-bottom: 20px;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.feature_height }}px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-feature-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-editorial-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px 0;
    color: {{ block.settings.text_color }};
    font-weight: 700;
  }

  .ai-editorial-feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: 8 / 13;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.sidebar_gap }}px;
  }

  .ai-editorial-sidebar-item-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
  }

  .ai-editorial-sidebar-image-{{ ai_gen_id }} {
    width: {{ block.settings.sidebar_image_width }}px;
    height: {{ block.settings.sidebar_image_width }}px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ai-editorial-sidebar-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.sidebar_image_width }}px;
    height: {{ block.settings.sidebar_image_width }}px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-editorial-sidebar-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-sidebar-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-editorial-sidebar-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.sidebar_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-editorial-sidebar-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.sidebar_title_size }}px;
    line-height: 1.3;
    margin: 0;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-editorial-hero-{{ ai_gen_id }},
    .ai-editorial-feature-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }

    .ai-editorial-hero-image-{{ ai_gen_id }},
    .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.hero_height | times: 0.6 }}px;
    }

    .ai-editorial-feature-image-{{ ai_gen_id }},
    .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.feature_height | times: 0.7 }}px;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.6 }}px;
    }

    .ai-editorial-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<editorial-layout-{{ ai_gen_id }} class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <div class="ai-editorial-hero-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 1600 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          class="ai-editorial-hero-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
        >
      {% else %}
        <div class="ai-editorial-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-editorial-hero-content-{{ ai_gen_id }}">
        {% if block.settings.hero_category != blank %}
          <div class="ai-editorial-hero-category-{{ ai_gen_id }}">{{ block.settings.hero_category }}</div>
        {% endif %}
        {% if block.settings.hero_title != blank %}
          <h2 class="ai-editorial-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h2>
        {% endif %}
        {% if block.settings.hero_excerpt != blank %}
          <p class="ai-editorial-hero-excerpt-{{ ai_gen_id }}">{{ block.settings.hero_excerpt }}</p>
        {% endif %}
      </div>
    </div>

    <div class="ai-editorial-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_image %}
        <img
          src="{{ block.settings.feature_image | image_url: width: 1000 }}"
          alt="{{ block.settings.feature_image.alt | escape }}"
          class="ai-editorial-feature-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.feature_image.width }}"
          height="{{ block.settings.feature_image.height }}"
        >
      {% else %}
        <div class="ai-editorial-feature-placeholder-{{ ai_gen_id }}">
          {{ 'collection-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.feature_category != blank %}
        <div class="ai-editorial-feature-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</div>
      {% endif %}
      {% if block.settings.feature_title != blank %}
        <h3 class="ai-editorial-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h3>
      {% endif %}
      {% if block.settings.feature_excerpt != blank %}
        <div class="ai-editorial-feature-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</div>
      {% endif %}
    </div>

    <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'sidebar_' | append: i | append: '_image'
          assign category_key = 'sidebar_' | append: i | append: '_category'
          assign title_key = 'sidebar_' | append: i | append: '_title'
          
          assign sidebar_image = block.settings[image_key]
          assign sidebar_category = block.settings[category_key]
          assign sidebar_title = block.settings[title_key]
        %}
        
        <div class="ai-editorial-sidebar-item-{{ ai_gen_id }}">
          {% if sidebar_image %}
            <img
              src="{{ sidebar_image | image_url: width: 300 }}"
              alt="{{ sidebar_image.alt | escape }}"
              class="ai-editorial-sidebar-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ sidebar_image.width }}"
              height="{{ sidebar_image.height }}"
            >
          {% else %}
            <div class="ai-editorial-sidebar-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-editorial-sidebar-content-{{ ai_gen_id }}">
            {% if sidebar_category != blank %}
              <div class="ai-editorial-sidebar-category-{{ ai_gen_id }}">{{ sidebar_category }}</div>
            {% endif %}
            {% if sidebar_title != blank %}
              <h4 class="ai-editorial-sidebar-title-{{ ai_gen_id }}">{{ sidebar_title }}</h4>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</editorial-layout-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialLayout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('editorial-layout-{{ ai_gen_id }}', EditorialLayout{{ ai_gen_id }});
  })();
</script>

