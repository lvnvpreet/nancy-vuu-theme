      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "button_italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
