    {
      "type": "range",
      "id": "frame_thickness",
      "label": "Frame thickness",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "frame_color",
      "label": "Frame color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "frame_border_radius",
      "label": "Frame border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Speaker hero"
    }
  ]
}
{% endschema %}
