{% doc %}
  @prompt
    Add a book nancy vuu speaker hero section with eyebrow, title and subtext. use bodoni moda for title and manrope for everthing else.  the fonts should be adjustable in color (black or white), size, boldness and italicized. the overlay should also be adjustable in strength from white or black overlay. there should be a cta button with a thin ine that frames around teh cta button with just enough space, the cta button should be able to be link to another destination link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-speaker-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-speaker-hero-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-speaker-hero-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-speaker-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-speaker-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    {% if block.settings.overlay_color == 'black' %}
      background-color: rgba(0, 0, 0, {{ block.settings.overlay_strength }});
    {% else %}
      background-color: rgba(255, 255, 255, {{ block.settings.overlay_strength }});
    {% endif %}
  }

  .ai-speaker-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
  }

  .ai-speaker-hero-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.eyebrow_spacing }}px;
    {% if block.settings.eyebrow_italic %}
      font-style: italic;
    {% endif %}
  }

  .ai-speaker-hero-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin-bottom: {{ block.settings.title_spacing }}px;
    line-height: 1.1;
    {% if block.settings.title_italic %}
      font-style: italic;
    {% endif %}
  }

  .ai-speaker-hero-subtext-{{ ai_gen_id }} {
    font-family: {{ block.settings.subtext_font.family }}, {{ block.settings.subtext_font.fallback_families }};
    font-weight: {{ block.settings.subtext_font.weight }};
    font-size: {{ block.settings.subtext_font_size }}px;
    color: {{ block.settings.subtext_color }};
    margin-bottom: {{ block.settings.subtext_spacing }}px;
    line-height: 1.6;
    {% if block.settings.subtext_italic %}
      font-style: italic;
    {% endif %}
  }

  .ai-speaker-hero-cta-wrapper-{{ ai_gen_id }} {
    display: inline-block;
    position: relative;
    padding: {{ block.settings.frame_spacing }}px;
    border: {{ block.settings.frame_thickness }}px solid {{ block.settings.frame_color }};
    border-radius: {{ block.settings.frame_border_radius }}px;
  }

  .ai-speaker-hero-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    {% if block.settings.button_italic %}
      font-style: italic;
    {% endif %}
  }

  .ai-speaker-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-speaker-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}px;
    }

    .ai-speaker-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.6 }}px;
    }

    .ai-speaker-hero-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size | times: 0.8 }}px;
    }

    .ai-speaker-hero-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-speaker-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.hero_image %}
    <img
      src="{{ block.settings.hero_image | image_url: width: 2000 }}"
      alt="{{ block.settings.hero_image.alt | escape }}"
      class="ai-speaker-hero-image-{{ ai_gen_id }}"
      loading="lazy"
      width="{{ block.settings.hero_image.width }}"
      height="{{ block.settings.hero_image.height }}"
    >
  {% else %}
    <div class="ai-speaker-hero-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  <div class="ai-speaker-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-speaker-hero-content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow_text != blank %}
      <div class="ai-speaker-hero-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow_text }}
      </div>
    {% endif %}

    {% if block.settings.title_text != blank %}
      <h1 class="ai-speaker-hero-title-{{ ai_gen_id }}">
        {{ block.settings.title_text }}
      </h1>
    {% endif %}

    {% if block.settings.subtext_text != blank %}
      <div class="ai-speaker-hero-subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext_text }}
      </div>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <div class="ai-speaker-hero-cta-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_link }}" class="ai-speaker-hero-cta-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Speaker hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Desktop height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Mobile height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "select",
      "id": "overlay_color",
      "label": "Overlay color",
      "options": [
        {
          "value": "black",
          "label": "Black"
        },
        {
          "value": "white",
          "label": "White"
        }
      ],
      "default": "black"
    },
    {
      "type": "range",
      "id": "overlay_strength",
      "label": "Overlay strength",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.4
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Book Nancy Vuu"
    },
    {
      "type": "font_picker",
      "id": "eyebrow_font",
      "label": "Font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Font size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "range",
      "id": "eyebrow_spacing",
      "label": "Bottom spacing",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title_text",
      "label": "Title text",
      "default": "Inspire Your Audience"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Font size",
      "min": 30,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "title_italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Bottom spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Subtext"
    },
    {
      "type": "textarea",
      "id": "subtext_text",
      "label": "Subtext",
      "default": "Award-winning speaker available for keynotes, workshops, and corporate events"
    },
    {
      "type": "font_picker",
      "id": "subtext_font",
      "label": "Font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Font size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "subtext_italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "range",
      "id": "subtext_spacing",
      "label": "Bottom spacing",
      "min": 15,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 35
    },
    {
      "type": "header",
      "content": "CTA button"
    },
    {
      "type": "text",
