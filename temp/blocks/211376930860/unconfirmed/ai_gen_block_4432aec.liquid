{% doc %}
  @prompt
    recreate a duplicate of teh luxury split hero section and add a built in link to the cta that links to the commission request form at the bottom #commission-request-form
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-split-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    background-color: {{ block.settings.background_color }};
  }

  .ai-luxury-split-hero__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ block.settings.section_height }}vh;
    width: 100%;
  }

  .ai-luxury-split-hero__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.content_bg_color }};
  }

  .ai-luxury-split-hero__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_spacing }}em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 {{ block.settings.eyebrow_margin }}px 0;
  }

  .ai-luxury-split-hero__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px 0;
  }

  .ai-luxury-split-hero__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_margin }}px 0;
    max-width: {{ block.settings.text_max_width }}ch;
  }

  .ai-luxury-split-hero__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_padding_v }}px {{ block.settings.cta_padding_h }}px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.cta_size }}px;
    letter-spacing: {{ block.settings.cta_spacing }}em;
    text-transform: uppercase;
    text-decoration: none;
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-luxury-split-hero__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg }};
    color: {{ block.settings.cta_hover_text }};
    border-color: {{ block.settings.cta_hover_border }};
  }

  .ai-luxury-split-hero__image-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.image_bg_color }};
  }

  .ai-luxury-split-hero__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    object-position: {{ block.settings.image_position }};
  }

  .ai-luxury-split-hero__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-luxury-split-hero__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-split-hero__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ai-luxury-split-hero__content-{{ ai_gen_id }} {
      {% if block.settings.mobile_content_first %}
        order: 1;
      {% else %}
        order: 2;
      {% endif %}
      padding: {{ block.settings.mobile_padding }}px;
    }

    .ai-luxury-split-hero__image-{{ ai_gen_id }} {
      {% if block.settings.mobile_content_first %}
        order: 2;
      {% else %}
        order: 1;
      {% endif %}
      min-height: {{ block.settings.mobile_image_height }}vh;
    }

    .ai-luxury-split-hero__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-luxury-split-hero__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }
  }
{% endstyle %}

<luxury-split-hero-{{ ai_gen_id }} class="ai-luxury-split-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-split-hero__container-{{ ai_gen_id }}">
    <div class="ai-luxury-split-hero__content-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-luxury-split-hero__eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-luxury-split-hero__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-luxury-split-hero__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.cta_text != blank %}
        <a 
          href="#commission-request-form" 
          class="ai-luxury-split-hero__cta-{{ ai_gen_id }}"
        >
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-luxury-split-hero__image-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1500 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-luxury-split-hero__image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>
</luxury-split-hero-{{ ai_gen_id }}>

<script>
(function() {
  class LuxurySplitHero{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.setupSmoothScroll();
    }

    setupSmoothScroll() {
      const ctaLink = this.querySelector('.ai-luxury-split-hero__cta-{{ ai_gen_id }}');
      if (!ctaLink) return;

      ctaLink.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          const targetId = href.substring(1);
          const targetElement = document.getElementById(targetId);
          
          if (targetElement) {
            targetElement.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        }
      });
    }
  }

  customElements.define('luxury-split-hero-{{ ai_gen_id }}', LuxurySplitHero{{ ai_gen_id }});
})();
</script>

