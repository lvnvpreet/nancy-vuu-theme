{% doc %}
  @prompt
    Create a custom section titled 'Selection Gallery' with a clean, high-fashion grid layout. I need 5 image cards in total. The layout should be a 3-column row followed by a 2-column row centered below it. Each card must have a full-bleed background image, a title in an elegant serif font overlay, and a 'Learn More' button. Ensure the layout is mobile-responsive, switching to a single column on small screens. Include settings for each card to link to a custom URL or Page Anchor (#ID).", make the 5 image cards the same size, give this section an eyebrow, title and subtext and make it two rows to space it out more. keep the photo box the same size, give me the option to adjust the photo box sizes. , Each card should NOT use an image. Instead, use a very light, airy solid background color (choose a warm champagne or light oatmeal color) to create large, minimalist buttons.
    
    The text on each card must be centered with generous white space (padding). The primary title must be a prominent  bodini Moda serif font, followed by a smaller subtext in a lightweight  manrope sans-serif font.
    
    Make the entire card clickable and include a subtle hover effect, such as the background color softly darkening or the title subtly rising, to signify interactivity. The layout must switch to a single column on mobile."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-selection-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-selection-gallery__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-selection-gallery__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, sans-serif;
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 {{ block.settings.eyebrow_spacing }}px;
  }

  .ai-selection-gallery__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, serif;
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    letter-spacing: 0.02em;
  }

  .ai-selection-gallery__subtext-{{ ai_gen_id }} {
    font-family: {{ block.settings.subtext_font.family }}, sans-serif;
    font-weight: {{ block.settings.subtext_font.weight }};
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ai-selection-gallery__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.row_spacing }}px;
  }

  .ai-selection-gallery__grid-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-selection-gallery__row-2-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: calc(66.666% + {{ block.settings.grid_gap }}px);
    margin: 0 auto;
  }

  .ai-selection-gallery__card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: {{ block.settings.card_padding }}px;
    text-decoration: none;
    background-color: {{ block.settings.card_bg_color }};
    min-height: {{ block.settings.card_height }}px;
    transition: background-color 0.4s ease;
    cursor: pointer;
  }

  .ai-selection-gallery__card-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_hover_bg_color }};
  }

  .ai-selection-gallery__card-content-{{ ai_gen_id }} {
    text-align: center;
    width: 100%;
    transition: transform 0.4s ease;
  }

  .ai-selection-gallery__card-{{ ai_gen_id }}:hover .ai-selection-gallery__card-content-{{ ai_gen_id }} {
    transform: translateY(-8px);
  }

  .ai-selection-gallery__card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_title_font.family }}, serif;
    font-weight: {{ block.settings.card_title_font.weight }};
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
    letter-spacing: 0.03em;
  }

  .ai-selection-gallery__card-subtext-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_subtext_font.family }}, sans-serif;
    font-weight: {{ block.settings.card_subtext_font.weight }};
    font-size: {{ block.settings.card_subtext_size }}px;
    color: {{ block.settings.card_subtext_color }};
    margin: 0;
    line-height: 1.6;
    max-width: 400px;
    margin: 0 auto;
  }

  @media screen and (max-width: 1024px) {
    .ai-selection-gallery__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-selection-gallery__row-2-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 768px) {
    .ai-selection-gallery__grid-{{ ai_gen_id }},
    .ai-selection-gallery__row-2-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-selection-gallery__eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_size }}px * 0.85);
    }

    .ai-selection-gallery__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-selection-gallery__subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtext_size }}px * 0.9);
    }

    .ai-selection-gallery__card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.8);
    }

    .ai-selection-gallery__card-subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_subtext_size }}px * 0.9);
    }

    .ai-selection-gallery__card-{{ ai_gen_id }} {
      min-height: {{ block.settings.card_height_mobile }}px;
    }
  }
{% endstyle %}

<selection-gallery-{{ ai_gen_id }} class="ai-selection-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-selection-gallery__header-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-selection-gallery__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}
    {% if block.settings.section_title != blank %}
      <h2 class="ai-selection-gallery__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}
    {% if block.settings.subtext != blank %}
      <div class="ai-selection-gallery__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
    {% endif %}
  </div>

  <div class="ai-selection-gallery__grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign card_enabled_key = 'card_' | append: i | append: '_enabled'
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_subtext_key = 'card_' | append: i | append: '_subtext'
        assign card_link_key = 'card_' | append: i | append: '_link'

        assign card_enabled = block.settings[card_enabled_key]
        assign card_title = block.settings[card_title_key]
        assign card_subtext = block.settings[card_subtext_key]
        assign card_link = block.settings[card_link_key]
      %}

      {% if card_enabled %}
        <a href="{{ card_link }}" class="ai-selection-gallery__card-{{ ai_gen_id }}">
          <div class="ai-selection-gallery__card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-selection-gallery__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}
            {% if card_subtext != blank %}
              <p class="ai-selection-gallery__card-subtext-{{ ai_gen_id }}">{{ card_subtext }}</p>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-selection-gallery__row-2-{{ ai_gen_id }}">
    {% for i in (4..5) %}
      {% liquid
        assign card_enabled_key = 'card_' | append: i | append: '_enabled'
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_subtext_key = 'card_' | append: i | append: '_subtext'
        assign card_link_key = 'card_' | append: i | append: '_link'

        assign card_enabled = block.settings[card_enabled_key]
        assign card_title = block.settings[card_title_key]
        assign card_subtext = block.settings[card_subtext_key]
        assign card_link = block.settings[card_link_key]
      %}

      {% if card_enabled %}
        <a href="{{ card_link }}" class="ai-selection-gallery__card-{{ ai_gen_id }}">
          <div class="ai-selection-gallery__card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-selection-gallery__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}
            {% if card_subtext != blank %}
              <p class="ai-selection-gallery__card-subtext-{{ ai_gen_id }}">{{ card_subtext }}</p>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</selection-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class SelectionGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-selection-gallery__card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'link');
        });
      }
    }

    customElements.define('selection-gallery-{{ ai_gen_id }}', SelectionGallery{{ ai_gen_id }});
  })();
</script>

