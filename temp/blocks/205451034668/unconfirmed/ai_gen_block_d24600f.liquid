{% doc %}
  @prompt
    Add a "Custom Liquid" block with this code: <div id="masterpiece-bride"></div>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-liquid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }
{% endstyle %}

<div class="ai-custom-liquid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {{ block.settings.custom_liquid }}
</div>

{% schema %}
{
  "name": "Custom liquid",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Custom Liquid code",
      "default": "<div id=\"masterpiece-bride\"></div>"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Custom liquid"
    }
  ]
}
{% endschema %}
