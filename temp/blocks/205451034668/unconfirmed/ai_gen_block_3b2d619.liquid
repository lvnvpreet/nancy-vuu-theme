{% doc %}
  @prompt
    Build a new homepage section using the "Image with Text" layout (50% image, 50% text). Please apply the following structural and design instructions to match a high-end, quiet luxury editorial aesthetic:
    
    1. Layout & Styling:
    
        Image Placement: Place one large, high-resolution portrait or square image on the left side. The image should be borderless.
    
        Text Alignment: Align all text to the left within the right-side block.
    
        Spacing: Add generous padding (white space) above and below this entire section so it breathes. Add significant padding between the image and the text block.
    
        Typography: Keep fonts strictly consistent with the site's global theme. Use a small, clean sans-serif for the eyebrow and button. Use the elegant global serif font for the Main Title.
    
        Colors: Use a minimalist color palette. White or very light neutral background, dark charcoal or black text for high contrast and luxury feel.
    
    2. Insert the following exact content into the text block:
    
        Eyebrow/Subheading (Small, uppercase, wide letter-spacing): ELEVATION OF PRESENCE | GRACE | LEGACY
    
        Main Title (Large, Serif, Bodoni Moda Elegant): NANCY VUU Bridal Immersions
    
        Body Text / Paragraph (Standard body font, Manrope, 1.5 line height for readability): A wedding is a singular event; a marriage is a lasting covenant. Our Bridal Immersions in Napa Valley are private sanctuaries designed to transition you from the exhaustion of wedding planning into a state of profound peace and preparation. Step away from the noise to cultivate your inner grace. As an exquisite enhancement to your immersion, you are invited into the private Design Atelier to co-design your bespoke bridal gown—ensuring you walk down the aisle not just in a breathtaking masterpiece, but clothed in unshakeable presence, radiant confidence, and profound inner alignment.
    
        Button / Call to Action: * Button Text: INQUIRE FOR SELECTION →
    
            Button Style: Outline button Keep it sleek.
    
            Button Link: [Insert link to Bridal Immersion inquiry page], provide the option to make font bold and give option to increase space between lines and letters in the body text.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .ai-image-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: {{ block.settings.color_greige }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #999;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    padding: {{ block.settings.text_padding }}px;
  }

  .ai-image-text-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_spacing }}em;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.eyebrow_margin }}px 0;
    line-height: 1.4;
  }

  .ai-image-text-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.title_margin }}px 0;
    line-height: 1.2;
  }

  .ai-image-text-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    {% if block.settings.body_bold %}
      font-weight: 700;
    {% else %}
      font-weight: {{ block.settings.body_font.weight }};
    {% endif %}
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    letter-spacing: {{ block.settings.body_letter_spacing }}em;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.body_margin }}px 0;
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    letter-spacing: {{ block.settings.button_spacing }}em;
    text-transform: uppercase;
    color: {{ block.settings.button_text_color }};
    background-color: transparent;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_text_color }};
    background-color: {{ block.settings.button_hover_bg_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-image-text-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-image-text-container-{{ ai_gen_id }} {
      padding: 0 24px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-image-text-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-image-text-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }

    .ai-image-text-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-grid-{{ ai_gen_id }}">
      <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-text-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
              Add your portrait or square image here
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-image-text-content-{{ ai_gen_id }}">
        {% if block.settings.eyebrow != blank %}
          <div class="ai-image-text-eyebrow-{{ ai_gen_id }}">
            {{ block.settings.eyebrow }}
          </div>
        {% endif %}

        {% if block.settings.title != blank %}
          <h2 class="ai-image-text-title-{{ ai_gen_id }}">
            {{ block.settings.title }}
          </h2>
        {% endif %}

        {% if block.settings.body_text != blank %}
          <div class="ai-image-text-body-{{ ai_gen_id }}">
            {{ block.settings.body_text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-image-text-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "ELEVATION OF PRESENCE | GRACE | LEGACY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "NANCY VUU Bridal Immersions"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "A wedding is a singular event; a marriage is a lasting covenant. Our Bridal Immersions in Napa Valley are private sanctuaries designed to transition you from the exhaustion of wedding planning into a state of profound peace and preparation. Step away from the noise to cultivate your inner grace. As an exquisite enhancement to your immersion, you are invited into the private Design Atelier to co-design your bespoke bridal gown—ensuring you walk down the aisle not just in a breathtaking masterpiece, but clothed in unshakeable presence, radiant confidence, and profound inner alignment."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "INQUIRE FOR SELECTION →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Space between image and text",
      "min": 40,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section padding top",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "text_padding",
      "label": "Text block padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Title font",
      "default": "bodoni_moda_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "manrope_n4"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "eyebrow_spacing",
      "label": "Eyebrow letter spacing",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "default": 0.2
    },
    {
      "type": "range",
      "id": "eyebrow_margin",
      "label": "Eyebrow bottom margin",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
