{% doc %}
  @prompt
    recreate the manifesto quote section with exact verbiage but give it an eyebrow that says: The Nancy Vuu Atelier". and link the words "San Jose anctuary" to my homepage nancyvuu.com.  also give me control access to adjust font size  and top and bottom padding. also include a cTA button that says "begin the commission" and link it to the inquiry form on the botton of the page. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-manifesto-quote-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-manifesto-quote__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
    text-align: center;
  }

  .ai-manifesto-quote__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-style: {{ block.settings.eyebrow_font.style }};
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }

  .ai-manifesto-quote__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};
    font-weight: {{ block.settings.quote_font.weight }};
    font-style: {{ block.settings.quote_font.style }};
    font-size: {{ block.settings.quote_font_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    margin-bottom: 40px;
  }

  .ai-manifesto-quote__text-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    border-bottom: 1px solid {{ block.settings.link_color }};
    transition: opacity 0.3s ease;
  }

  .ai-manifesto-quote__text-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  .ai-manifesto-quote__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_font_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-manifesto-quote__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-manifesto-quote__eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_font_size }}px * 0.85);
    }

    .ai-manifesto-quote__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.quote_font_size }}px * 0.85);
    }

    .ai-manifesto-quote__cta-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_font_size }}px * 0.9);
      padding: 14px 32px;
    }
  }
{% endstyle %}

<div class="ai-manifesto-quote-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-manifesto-quote__container-{{ ai_gen_id }}">
    <div class="ai-manifesto-quote__eyebrow-{{ ai_gen_id }}">
      The Nancy Vuu Atelier
    </div>
    
    <div class="ai-manifesto-quote__text-{{ ai_gen_id }}">
      Each gown is a singular work of art, conceived in our <a href="https://nancyvuu.com">San Jose sanctuary</a> and brought to life through weeks of meticulous hand-work. We do not mass-produce. We do not replicate. Every bride who walks through our doors receives a garment that exists nowhere else on earth—tailored to her form, her story, her vision. This is couture in its truest sense: bespoke, intentional, and utterly irreplaceable.
    </div>

    <a href="#inquiry-form" class="ai-manifesto-quote__cta-{{ ai_gen_id }}">
      Begin the Commission
    </a>
  </div>
</div>

