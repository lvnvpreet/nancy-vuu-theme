{% doc %}
  @prompt
    Please create a "Custom Liquid" Hero section for a high-end luxury website. The aesthetic must be extremely elegant, editorial, and minimalist.
    
    Please build the code using modular CSS Variables (Custom Properties) placed at the top of the <style> block. Add clear comments calling this the "USER CONTROL PANEL" so I can easily adjust the hero height, image split widths, text box opacity, font sizes, and all CTA button design elements (background color, border, text color, spacing).
    
    Layout & Imagery:
    
    Background: A 50/50 split-screen layout.
    
    Left Side: Image placeholder for the Groom (Sartorial).
    
    Right Side: Image placeholder for the Bride (Bridal).
    
    Both images must cover their respective halves perfectly (object-fit: cover) and span the full width of the screen.
    
    Center Text Overlay Box:
    
    Place an elegant, opaque box absolutely centered over the middle of the screen, overlapping the split between the two images.
    
    The box should have a semi-transparent white background (e.g., rgba(255, 255, 255, 0.85)) and a subtle blur effect to ensure the text is highly readable while still feeling light and airy.
    
    Add generous padding inside the box so the text has room to breathe.
    
    Add a very thin, subtle border to the box (e.g., 1px solid rgba(212, 175, 55, 0.2)).
    
    Typography (Inside the Box):
    
    Center all text.
    
    Headline (H1): "Bespoke Bridal & Sartorial Commissions Crafted for Flawless Coordination." (Format in an elegant, thin Serif font like Cormorant Garamond, dark grey).
    
    Subheadline (H2): "From the boardroom to the sanctuary, we architect synchronized wardrobe legacies." (Format in a thin Sans-serif font like Montserrat, ALL CAPS, wide letter spacing, smaller size, muted grey).
    
    Call to Action Button:
    
    Text: "REQUEST A PRIVATE CONSULTATION"
    
    give the cta a functional link and link it to the #commission-request-form at the bottom of this page. 
    
    Initial Style: Transparent background, dark grey text, thin dark grey border, wide letter spacing, uppercase, thin Sans-serif font. (Make sure I can change these exact properties easily via the CSS variables at the top).
    
    Please generate the complete HTML and CSS for this section, ensuring the "USER CONTROL PANEL" variables are clearly marked at the top of the style section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-hero-{{ ai_gen_id }} {
    /* ========================================
       USER CONTROL PANEL - CSS VARIABLES
       ======================================== */
    
    /* Hero Dimensions */
    --hero-height: 100vh;
    --hero-min-height: 600px;
    
    /* Split Image Widths */
    --left-image-width: 50%;
    --right-image-width: 50%;
    
    /* Center Text Box */
    --text-box-bg-color: rgba(255, 255, 255, 0.85);
    --text-box-blur: 10px;
    --text-box-padding: 60px 80px;
    --text-box-max-width: 800px;
    --text-box-border: 1px solid rgba(212, 175, 55, 0.2);
    --text-box-border-radius: 0px;
    
    /* Typography - Headline */
    --headline-font-family: 'Cormorant Garamond', serif;
    --headline-font-size: 48px;
    --headline-font-weight: 300;
    --headline-color: #2c2c2c;
    --headline-line-height: 1.3;
    --headline-letter-spacing: 0.5px;
    
    /* Typography - Subheadline */
    --subheadline-font-family: 'Montserrat', sans-serif;
    --subheadline-font-size: 13px;
    --subheadline-font-weight: 300;
    --subheadline-color: #6b6b6b;
    --subheadline-letter-spacing: 3px;
    --subheadline-text-transform: uppercase;
    --subheadline-margin-top: 20px;
    
    /* CTA Button Design */
    --cta-bg-color: transparent;
    --cta-text-color: #2c2c2c;
    --cta-border: 1px solid #2c2c2c;
    --cta-border-radius: 0px;
    --cta-padding: 16px 40px;
    --cta-font-family: 'Montserrat', sans-serif;
    --cta-font-size: 11px;
    --cta-font-weight: 400;
    --cta-letter-spacing: 2.5px;
    --cta-text-transform: uppercase;
    --cta-margin-top: 40px;
    
    /* CTA Button Hover */
    --cta-hover-bg-color: #2c2c2c;
    --cta-hover-text-color: #ffffff;
    --cta-hover-border: 1px solid #2c2c2c;
    
    /* ======================================== */
    
    display: block;
    position: relative;
    width: 100%;
    height: var(--hero-height);
    min-height: var(--hero-min-height);
    overflow: hidden;
  }
  
  .ai-luxury-hero__split-container-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    height: 100%;
    position: relative;
  }
  
  .ai-luxury-hero__image-half-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    overflow: hidden;
  }
  
  .ai-luxury-hero__image-half--left-{{ ai_gen_id }} {
    width: var(--left-image-width);
  }
  
  .ai-luxury-hero__image-half--right-{{ ai_gen_id }} {
    width: var(--right-image-width);
  }
  
  .ai-luxury-hero__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .ai-luxury-hero__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ai-luxury-hero__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }
  
  .ai-luxury-hero__text-box-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: var(--text-box-bg-color);
    backdrop-filter: blur(var(--text-box-blur));
    -webkit-backdrop-filter: blur(var(--text-box-blur));
    padding: var(--text-box-padding);
    max-width: var(--text-box-max-width);
    width: 90%;
    text-align: center;
    border: var(--text-box-border);
    border-radius: var(--text-box-border-radius);
    z-index: 10;
  }
  
  .ai-luxury-hero__headline-{{ ai_gen_id }} {
    font-family: var(--headline-font-family);
    font-size: var(--headline-font-size);
    font-weight: var(--headline-font-weight);
    color: var(--headline-color);
    line-height: var(--headline-line-height);
    letter-spacing: var(--headline-letter-spacing);
    margin: 0;
  }
  
  .ai-luxury-hero__subheadline-{{ ai_gen_id }} {
    font-family: var(--subheadline-font-family);
    font-size: var(--subheadline-font-size);
    font-weight: var(--subheadline-font-weight);
    color: var(--subheadline-color);
    letter-spacing: var(--subheadline-letter-spacing);
    text-transform: var(--subheadline-text-transform);
    margin: var(--subheadline-margin-top) 0 0 0;
  }
  
  .ai-luxury-hero__cta-{{ ai_gen_id }} {
    display: inline-block;
    background-color: var(--cta-bg-color);
    color: var(--cta-text-color);
    border: var(--cta-border);
    border-radius: var(--cta-border-radius);
    padding: var(--cta-padding);
    font-family: var(--cta-font-family);
    font-size: var(--cta-font-size);
    font-weight: var(--cta-font-weight);
    letter-spacing: var(--cta-letter-spacing);
    text-transform: var(--cta-text-transform);
    text-decoration: none;
    margin-top: var(--cta-margin-top);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .ai-luxury-hero__cta-{{ ai_gen_id }}:hover {
    background-color: var(--cta-hover-bg-color);
    color: var(--cta-hover-text-color);
    border: var(--cta-hover-border);
  }
  
  @media screen and (max-width: 768px) {
    .ai-luxury-hero-{{ ai_gen_id }} {
      --hero-height: 80vh;
      --hero-min-height: 500px;
      --text-box-padding: 40px 30px;
      --headline-font-size: 32px;
      --subheadline-font-size: 11px;
      --cta-padding: 14px 30px;
      --cta-font-size: 10px;
    }
    
    .ai-luxury-hero__split-container-{{ ai_gen_id }} {
      flex-direction: column;
    }
    
    .ai-luxury-hero__image-half--left-{{ ai_gen_id }},
    .ai-luxury-hero__image-half--right-{{ ai_gen_id }} {
      width: 100%;
      height: 50%;
    }
  }
{% endstyle %}

<luxury-hero-{{ ai_gen_id }} class="ai-luxury-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-hero__split-container-{{ ai_gen_id }}">
    <div class="ai-luxury-hero__image-half-{{ ai_gen_id }} ai-luxury-hero__image-half--left-{{ ai_gen_id }}">
      {% if block.settings.left_image %}
        <img
          src="{{ block.settings.left_image | image_url: width: 2000 }}"
          alt="{{ block.settings.left_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.left_image.width }}"
          height="{{ block.settings.left_image.height }}"
          class="ai-luxury-hero__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-luxury-hero__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    
    <div class="ai-luxury-hero__image-half-{{ ai_gen_id }} ai-luxury-hero__image-half--right-{{ ai_gen_id }}">
      {% if block.settings.right_image %}
        <img
          src="{{ block.settings.right_image | image_url: width: 2000 }}"
          alt="{{ block.settings.right_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.right_image.width }}"
          height="{{ block.settings.right_image.height }}"
          class="ai-luxury-hero__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-luxury-hero__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    
    <div class="ai-luxury-hero__text-box-{{ ai_gen_id }}">
      <h1 class="ai-luxury-hero__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
      <h2 class="ai-luxury-hero__subheadline-{{ ai_gen_id }}">
        {{ block.settings.subheadline }}
      </h2>
      <a href="{{ block.settings.cta_link }}" class="ai-luxury-hero__cta-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </a>
    </div>
  </div>
</luxury-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustHeroHeight();
        window.addEventListener('resize', () => this.adjustHeroHeight());
      }

      adjustHeroHeight() {
        const vh = window.innerHeight * 0.01;
        this.style.setProperty('--vh', `${vh}px`);
      }
    }

    customElements.define('luxury-hero-{{ ai_gen_id }}', LuxuryHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Luxury split hero",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image (Sartorial)"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image (Bridal)"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Bespoke Bridal & Sartorial Commissions Crafted for Flawless Coordination"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "From the boardroom to the sanctuary, we architect synchronized wardrobe legacies"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "REQUEST A PRIVATE CONSULTATION"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Luxury split hero"
    }
  ]
}
{% endschema %}
