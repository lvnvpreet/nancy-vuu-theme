{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-hero-{{ ai_gen_id }} {
    grid-column: 1 / 13;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
  }

  .ai-editorial-hero-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.color_greige }};
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 40px;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
    width: 100%;
  }

  .ai-editorial-hero-category-{{ ai_gen_id }} {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.hero_text_color }};
    margin-bottom: 12px;
    font-weight: 600;
  }

  .ai-editorial-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    line-height: 1.1;
    color: {{ block.settings.hero_text_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
    max-width: 800px;
  }

  .ai-editorial-hero-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_excerpt_size }}px;
    line-height: 1.6;
    color: {{ block.settings.hero_text_color }};
    margin: 0 0 20px 0;
    max-width: 600px;
  }

  .ai-editorial-hero-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 28px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: background-color 0.3s ease;
  }

  .ai-editorial-hero-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-editorial-secondary-{{ ai_gen_id }} {
    grid-column: 1 / 7;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    min-height: 400px;
    display: flex;
    align-items: flex-end;
  }

  .ai-editorial-secondary-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-secondary-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.color_greige }};
  }

  .ai-editorial-secondary-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-secondary-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 30px;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    width: 100%;
  }

  .ai-editorial-secondary-category-{{ ai_gen_id }} {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ block.settings.secondary_text_color }};
    margin-bottom: 10px;
    font-weight: 600;
  }

  .ai-editorial-secondary-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.secondary_title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.secondary_text_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-editorial-secondary-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
  }

  .ai-editorial-tertiary-{{ ai_gen_id }} {
    grid-column: 7 / 13;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    min-height: 400px;
    display: flex;
    align-items: flex-end;
  }

  .ai-editorial-tertiary-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-tertiary-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.color_greige }};
  }

  .ai-editorial-tertiary-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-tertiary-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 30px;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    width: 100%;
  }

  .ai-editorial-tertiary-category-{{ ai_gen_id }} {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ block.settings.tertiary_text_color }};
    margin-bottom: 10px;
    font-weight: 600;
  }

  .ai-editorial-tertiary-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.tertiary_title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.tertiary_text_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-editorial-tertiary-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
  }

  .ai-editorial-small-{{ ai_gen_id }} {
    grid-column: span 4;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    min-height: 300px;
    display: flex;
    align-items: flex-end;
  }

  .ai-editorial-small-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-small-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.color_greige }};
  }

  .ai-editorial-small-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-small-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 24px;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    width: 100%;
  }

  .ai-editorial-small-category-{{ ai_gen_id }} {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ block.settings.small_text_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-editorial-small-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.small_title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.small_text_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-editorial-small-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-editorial-hero-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-editorial-hero-content-{{ ai_gen_id }} {
      padding: 30px;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.7 }}px;
    }

    .ai-editorial-secondary-{{ ai_gen_id }},
    .ai-editorial-tertiary-{{ ai_gen_id }} {
      grid-column: 1 / 13;
      min-height: 350px;
    }

    .ai-editorial-small-{{ ai_gen_id }} {
      grid-column: span 6;
      min-height: 280px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px;
    }

    .ai-editorial-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap | times: 0.5 }}px;
    }

    .ai-editorial-hero-{{ ai_gen_id }} {
      min-height: 350px;
    }

    .ai-editorial-hero-content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.5 }}px;
    }

    .ai-editorial-hero-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_excerpt_size | times: 0.9 }}px;
    }

    .ai-editorial-secondary-{{ ai_gen_id }},
    .ai-editorial-tertiary-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-editorial-secondary-content-{{ ai_gen_id }},
    .ai-editorial-tertiary-content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-editorial-small-{{ ai_gen_id }} {
      grid-column: 1 / 13;
      min-height: 250px;
    }

    .ai-editorial-small-content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<editorial-layout-{{ ai_gen_id }} class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <article class="ai-editorial-hero-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 1600 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
          class="ai-editorial-hero-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-editorial-hero-content-{{ ai_gen_id }}">
        {% if block.settings.hero_category != blank %}
          <div class="ai-editorial-hero-category-{{ ai_gen_id }}">{{ block.settings.hero_category }}</div>
        {% endif %}
        {% if block.settings.hero_title != blank %}
          <h2 class="ai-editorial-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h2>
        {% endif %}
        {% if block.settings.hero_excerpt != blank %}
          <div class="ai-editorial-hero-excerpt-{{ ai_gen_id }}">{{ block.settings.hero_excerpt }}</div>
        {% endif %}
        {% if block.settings.hero_link != blank and block.settings.hero_link_text != blank %}
          <a href="{{ block.settings.hero_link }}" class="ai-editorial-hero-link-{{ ai_gen_id }}">
            {{ block.settings.hero_link_text }}
          </a>
        {% endif %}
      </div>
    </article>

    <article class="ai-editorial-secondary-{{ ai_gen_id }}">
      {% if block.settings.secondary_image %}
        <img
          src="{{ block.settings.secondary_image | image_url: width: 800 }}"
          alt="{{ block.settings.secondary_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.secondary_image.width }}"
          height="{{ block.settings.secondary_image.height }}"
          class="ai-editorial-secondary-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-secondary-placeholder-{{ ai_gen_id }}">
          {{ 'collection-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-editorial-secondary-content-{{ ai_gen_id }}">
        {% if block.settings.secondary_category != blank %}
          <div class="ai-editorial-secondary-category-{{ ai_gen_id }}">{{ block.settings.secondary_category }}</div>
        {% endif %}
        {% if block.settings.secondary_title != blank %}
          <h3 class="ai-editorial-secondary-title-{{ ai_gen_id }}">{{ block.settings.secondary_title }}</h3>
        {% endif %}
      </div>
      {% if block.settings.secondary_link != blank %}
        <a href="{{ block.settings.secondary_link }}" class="ai-editorial-secondary-link-{{ ai_gen_id }}" aria-label="{{ block.settings.secondary_title | escape }}"></a>
      {% endif %}
    </article>

    <article class="ai-editorial-tertiary-{{ ai_gen_id }}">
      {% if block.settings.tertiary_image %}
        <img
          src="{{ block.settings.tertiary_image | image_url: width: 800 }}"
          alt="{{ block.settings.tertiary_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.tertiary_image.width }}"
          height="{{ block.settings.tertiary_image.height }}"
          class="ai-editorial-tertiary-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-tertiary-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-editorial-tertiary-content-{{ ai_gen_id }}">
        {% if block.settings.tertiary_category != blank %}
          <div class="ai-editorial-tertiary-category-{{ ai_gen_id }}">{{ block.settings.tertiary_category }}</div>
        {% endif %}
        {% if block.settings.tertiary_title != blank %}
          <h3 class="ai-editorial-tertiary-title-{{ ai_gen_id }}">{{ block.settings.tertiary_title }}</h3>
        {% endif %}
      </div>
      {% if block.settings.tertiary_link != blank %}
        <a href="{{ block.settings.tertiary_link }}" class="ai-editorial-tertiary-link-{{ ai_gen_id }}" aria-label="{{ block.settings.tertiary_title | escape }}"></a>
      {% endif %}
    </article>

    {% for i in (1..3) %}
      {% liquid
        assign small_image_key = 'small_' | append: i | append: '_image'
        assign small_category_key = 'small_' | append: i | append: '_category'
        assign small_title_key = 'small_' | append: i | append: '_title'
        assign small_link_key = 'small_' | append: i | append: '_link'

        assign small_image = block.settings[small_image_key]
        assign small_category = block.settings[small_category_key]
        assign small_title = block.settings[small_title_key]
        assign small_link = block.settings[small_link_key]
      %}

      <article class="ai-editorial-small-{{ ai_gen_id }}">
        {% if small_image %}
          <img
            src="{{ small_image | image_url: width: 600 }}"
            alt="{{ small_image.alt | escape }}"
            loading="lazy"
            width="{{ small_image.width }}"
            height="{{ small_image.height }}"
            class="ai-editorial-small-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-editorial-small-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-editorial-small-content-{{ ai_gen_id }}">
          {% if small_category != blank %}
            <div class="ai-editorial-small-category-{{ ai_gen_id }}">{{ small_category }}</div>
          {% endif %}
          {% if small_title != blank %}
            <h4 class="ai-editorial-small-title-{{ ai_gen_id }}">{{ small_title }}</h4>
          {% endif %}
        </div>
        {% if small_link != blank %}
          <a href="{{ small_link }}" class="ai-editorial-small-link-{{ ai_gen_id }}" aria-label="{{ small_title | escape }}"></a>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</editorial-layout-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialLayout{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('editorial-layout-{{ ai_gen_id }}', EditorialLayout{{ai_gen_id}});
  })();
</script>

{% schema %}
