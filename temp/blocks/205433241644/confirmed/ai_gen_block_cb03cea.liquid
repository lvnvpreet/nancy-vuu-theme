{% doc %}
  @prompt
    Create a three-column layout section block with two portrait photo holders on each end and centered text/wording in the middle. The left and right columns should each have a portrait-oriented image placeholder (taller than wide, roughly 2:3 aspect ratio) that merchants can upload images to. The center column should have editable heading text and body text/description. The layout should be visually balanced with equal spacing, and the text in the center should be vertically centered between the two portrait images. Include customizable settings for the heading, body text, and both images.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-column-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-three-column-layout__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-three-column-layout__image-column-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-three-column-layout__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-three-column-layout__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-three-column-layout__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-three-column-layout__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-three-column-layout__text-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 {{ block.settings.text_padding }}px;
  }

  .ai-three-column-layout__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-three-column-layout__body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-three-column-layout__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-three-column-layout__text-column-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_text_position }};
      padding: {{ block.settings.mobile_text_padding }}px 0;
    }

    .ai-three-column-layout__image-column-{{ ai_gen_id }}:first-child {
      order: 1;
    }

    .ai-three-column-layout__image-column-{{ ai_gen_id }}:last-child {
      order: 3;
    }
  }
{% endstyle %}

<div class="ai-three-column-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-column-layout__container-{{ ai_gen_id }}">
    <div class="ai-three-column-layout__image-column-{{ ai_gen_id }}">
      <div class="ai-three-column-layout__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.left_image %}
          <img
            src="{{ block.settings.left_image | image_url: width: 800 }}"
            alt="{{ block.settings.left_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.left_image.width }}"
            height="{{ block.settings.left_image.height }}"
          >
        {% else %}
          <div class="ai-three-column-layout__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-three-column-layout__text-column-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-three-column-layout__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}
      {% if block.settings.body_text != blank %}
        <div class="ai-three-column-layout__body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </div>
      {% endif %}
    </div>

    <div class="ai-three-column-layout__image-column-{{ ai_gen_id }}">
      <div class="ai-three-column-layout__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.right_image %}
          <img
            src="{{ block.settings.right_image | image_url: width: 800 }}"
            alt="{{ block.settings.right_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.right_image.width }}"
            height="{{ block.settings.right_image.height }}"
          >
        {% else %}
          <div class="ai-three-column-layout__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Three column layout",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "placeholder_bg_color",
      "label": "Placeholder background",
      "default": "#ece9e3"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your Heading Here</p>"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Add your description or body text here. This content will be centered between the two portrait images.</p>"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0f0f0f"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#0f0f0f"
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Spacing between heading and body",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#faf8f5"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "text_padding",
      "label": "Text column padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "select",
      "id": "mobile_text_position",
      "label": "Text position on mobile",
      "options": [
        {
          "value": "-1",
          "label": "Top"
        },
        {
          "value": "2",
          "label": "Middle"
        },
        {
          "value": "4",
          "label": "Bottom"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Mobile gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_text_padding",
      "label": "Mobile text padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Three column layout"
    }
  ]
}
{% endschema %}
