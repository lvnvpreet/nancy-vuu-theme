      "blocks": {
        "ai_gen_block_c6b2e95_893ztb": {
          "type": "ai_gen_block_c6b2e95",
          "settings": {
            "desktop_width_percent": 100,
            "section_height": 80,
            "max_width": 900,
            "background_color": "#faf8f5",
            "eyebrow": "The SANCTUARY Manifesto",
            "eyebrow_size": 12,
            "eyebrow_color": "#0f0f0f",
            "title": "",
            "title_size": 48,
            "title_color": "#0f0f0f",
