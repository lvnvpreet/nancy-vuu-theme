    "booknv_hero": {
      "type": "booknv-hero",
      "settings": {
        "eyebrow": "The Presence",
        "title_line_1": "Authentic",
        "title_italic": "Truth",
        "description": "Nancy Vuu serves as the creative heart and strategic architect behind The House of Nancy Vuu and Maison Arise. As a bespoke designer, she has spent years observing how a restored sense of identity can profoundly dictate one’s influence.\n\nToday, Nancy is deeply committed to supporting the dreamers and builders who carry the weight of shaping our world. She understands the quiet responsibility of leadership and provides the structural grace needed for visionaries to occupy their 'True Appointment' with unshakeable peace and strategic clarity.\n\nAs a speaker, Nancy moves beyond the stage to meet her audience where they are—combining raw authenticity with high-level strategy. She doesn't just share a message; she creates a sacred space for leaders to transform complex visions into a realized, lasting legacy.",
        "cta_primary_label": "inquire for strategic engagement",
        "cta_primary_link": "#booking",
        "cta_secondary_label": "Elite Mentorship",
        "cta_secondary_link": "#mentorship",
