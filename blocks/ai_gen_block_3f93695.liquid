    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Solid hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_outline_color",
      "label": "Outline border and text",
      "default": "#0f0f0f"
    }
  ],
  "presets": [
