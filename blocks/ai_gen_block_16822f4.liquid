{% doc %}
  @prompt
    The Global Resonance Section
    
    1. Layout & Architecture:
    
        Create a two-column custom section.
    
        Left Column: Strategic narrative and accolades.
    
        Right Column: A high-resolution media block with a decorative border (resembling a gallery frame).
    
        Mobile Behavior: Columns must stack vertically on mobile, with the image appearing first to establish the visual "Mantle."
    
    2. Content & Copywriting (Initial Population):
    
        Eyebrow: GLOBAL RECOGNITION & RESONANCE (Manrope, All-Caps).
    
        Title: Women Who Lead: The Global Impact (Bodoni Moda).
    
        Quote Block: "True authority is the visible alignment of internal magnitude and external mantle." — Nancy Vuu (Italicized, with a thin left accent border).
    
        Body Copy: "Featured on KTVU Fox 2 as a 'Woman Who Leads with Global Impact,' Nancy Vuu’s presence on the platform is a catalytic intervention designed to recalibrate leadership narratives and restore the Sovereign Authority of her audience."
    
        Accolade Bar (The Footer of Authority): Add a small-text row at the base of the text column: "Recipient: Big Ben Award for Global Relations | World Relief Courage Award."
    
    3. Mandatory Customization Schema (Merchant Controls):
    
        Editable Content: Provide text fields for the Eyebrow, Title, Quote, Body, and Accolade Bar.
    
        Typography Controls: Individual selectors for Bodoni Moda (Headings) and Manrope (Body/Accolades).
    
        Font Styling: Sliders for font size, weight, and line-height for each text element.
    
        Color Palette: Color pickers for Background, Text, and the Quote Accent Border.
    
        Media Settings: An image-picker with an adjustable "Border Width" and "Border Color" setting to maintain the editorial look.
    
    4. Design Logic:
    
        Ensure generous padding (80px top/bottom) to maintain the "Quiet Luxury" feel.
    
        The "Accolade Bar" should be 30% smaller than the body text and set to a slightly muted color (e.g., #666666) to act as a "Footnote of Authority.", Make the words in the title "The Global Impact" the color gray #8D8D8D. break the title to two different lines with the option for me to adjust color. and give control option to increase spacing below and on top of each text section. , Add Sovereign CTA Button
    
    1. Button Placement:
    
        Add a single Button at the bottom of the left-hand text column, positioned below the awards/accolade text.
    
        Button Text: "REQUEST A SPEAKING ENGAGEMENT"
    
    2. Visual Styling (House of Vuu Aesthetic):
    
        Style: Ghost / Outline (Transparent background with a thin 1px black border).
    
        Shape: Sharp Rectangular corners (0px border-radius).
    
        Typography:
    
            Font: Manrope (Sans-Serif).
    
            Transform: All-Caps.
    
            Size: 14px.
    
            Letter-Spacing: 2px (for a luxurious, airy feel).
    
    3. Spatial Calibration:
    
        Top Margin: Add 50px of space above the button to separate it from the text above.
    
        Alignment: * Desktop: Left-aligned (aligned with the text column).
    
            Mobile: Center-aligned.
    
    4. Functionality:
    
        Connect the button to your Contact or Speaker Inquiry page URL.
    
        Ensure the button has a subtle hover effect (e.g., the background fills with a very light grey or the border thickens slightly) to signal it is interactive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-global-resonance-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-global-resonance-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
  }

  .ai-global-resonance-text-column-{{ ai_gen_id }} {
    padding-right: 40px;
  }

  .ai-global-resonance-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font_weight }};
    font-size: {{ block.settings.eyebrow_font_size }}px;
    line-height: {{ block.settings.eyebrow_line_height }};
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-top: {{ block.settings.eyebrow_margin_top }}px;
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
  }

  .ai-global-resonance-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.title_font_weight }};
    font-size: {{ block.settings.title_font_size }}px;
    line-height: {{ block.settings.title_line_height }};
    margin-top: {{ block.settings.title_margin_top }}px;
    margin-bottom: {{ block.settings.title_margin_bottom }}px;
  }

  .ai-global-resonance-title-line1-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.title_line1_color }};
  }

  .ai-global-resonance-title-line2-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.title_line2_color }};
  }

  .ai-global-resonance-quote-{{ ai_gen_id }} {
    border-left: {{ block.settings.quote_border_width }}px solid {{ block.settings.quote_border_color }};
    padding-left: {{ block.settings.quote_padding_left }}px;
    margin-top: {{ block.settings.quote_margin_top }}px;
    margin-bottom: {{ block.settings.quote_margin_bottom }}px;
  }

  .ai-global-resonance-quote-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.quote_font_weight }};
    font-size: {{ block.settings.quote_font_size }}px;
    line-height: {{ block.settings.quote_line_height }};
    font-style: italic;
    color: {{ block.settings.quote_color }};
    margin: 0;
  }

  .ai-global-resonance-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font_weight }};
    font-size: {{ block.settings.body_font_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin-top: {{ block.settings.body_margin_top }}px;
    margin-bottom: {{ block.settings.body_margin_bottom }}px;
  }

  .ai-global-resonance-accolade-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.accolade_font_weight }};
    font-size: {{ block.settings.accolade_font_size }}px;
    line-height: {{ block.settings.accolade_line_height }};
    color: {{ block.settings.accolade_color }};
    margin-top: {{ block.settings.accolade_margin_top }}px;
    margin-bottom: 0;
  }

  .ai-global-resonance-cta-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_margin_top }}px;
    text-align: left;
  }

  .ai-global-resonance-cta-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-global-resonance-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-width: {{ block.settings.button_hover_border_width }}px;
  }

  .ai-global-resonance-media-column-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-global-resonance-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border: {{ block.settings.image_border_width }}px solid {{ block.settings.image_border_color }};
    padding: {{ block.settings.image_border_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-global-resonance-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-global-resonance-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: {{ block.settings.color_greige }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-global-resonance-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .ai-global-resonance-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: 14px;
    color: #666666;
    text-align: center;
    padding: 12px 24px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  @media screen and (max-width: 989px) {
    .ai-global-resonance-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-global-resonance-media-column-{{ ai_gen_id }} {
      order: -1;
    }

    .ai-global-resonance-text-column-{{ ai_gen_id }} {
      padding-right: 0;
    }

    .ai-global-resonance-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px 20px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-global-resonance-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.75 }}px;
    }

    .ai-global-resonance-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size | times: 0.85 }}px;
    }

    .ai-global-resonance-quote-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_font_size | times: 0.85 }}px;
    }

    .ai-global-resonance-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_font_size | times: 0.95 }}px;
    }

    .ai-global-resonance-cta-wrapper-{{ ai_gen_id }} {
      text-align: center;
    }

    .ai-global-resonance-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-global-resonance-{{ ai_gen_id }} class="ai-global-resonance-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-global-resonance-container-{{ ai_gen_id }}">
    <div class="ai-global-resonance-text-column-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-global-resonance-eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow }}
        </div>
      {% endif %}

      {% if block.settings.title_line1 != blank or block.settings.title_line2 != blank %}
        <h2 class="ai-global-resonance-title-{{ ai_gen_id }}">
          {% if block.settings.title_line1 != blank %}
            <span class="ai-global-resonance-title-line1-{{ ai_gen_id }}">{{ block.settings.title_line1 }}</span>
          {% endif %}
          {% if block.settings.title_line2 != blank %}
            <span class="ai-global-resonance-title-line2-{{ ai_gen_id }}">{{ block.settings.title_line2 }}</span>
          {% endif %}
        </h2>
      {% endif %}

      {% if block.settings.quote != blank %}
        <div class="ai-global-resonance-quote-{{ ai_gen_id }}">
          <p class="ai-global-resonance-quote-text-{{ ai_gen_id }}">
            {{ block.settings.quote }}
          </p>
        </div>
      {% endif %}

      {% if block.settings.body != blank %}
        <div class="ai-global-resonance-body-{{ ai_gen_id }}">
          {{ block.settings.body }}
        </div>
      {% endif %}

      {% if block.settings.accolade_bar != blank %}
        <div class="ai-global-resonance-accolade-{{ ai_gen_id }}">
          {{ block.settings.accolade_bar }}
        </div>
      {% endif %}

      {% if block.settings.show_button %}
        <div class="ai-global-resonance-cta-wrapper-{{ ai_gen_id }}">
          <a 
            href="{{ block.settings.button_url }}" 
            class="ai-global-resonance-cta-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>

    <div class="ai-global-resonance-media-column-{{ ai_gen_id }}">
      <div class="ai-global-resonance-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-global-resonance-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-global-resonance-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-global-resonance-empty-state-{{ ai_gen_id }}">
              Add your featured image to establish the visual "Mantle"
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</ai-global-resonance-{{ ai_gen_id }}>

<script>
  (function() {
    class AIGlobalResonance{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }
            });
          },
          { threshold: 0.1 }
        );

        const textColumn = this.querySelector('.ai-global-resonance-text-column-{{ ai_gen_id }}');
        if (textColumn) {
          textColumn.style.opacity = '0';
          textColumn.style.transform = 'translateY(20px)';
          textColumn.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
          observer.observe(textColumn);
        }
      }
    }

    customElements.define('ai-global-resonance-{{ ai_gen_id }}', AIGlobalResonance{{ ai_gen_id }});
  })();
</script>

