{% doc %}
  @prompt
    Add a Custom Liquid block to the very top of this 'Awaken Your Highest Self' section.
    
    Inside the block, insert this exact HTML code:
    <div id='alignment-application' style='scroll-margin-top: 120px;'></div>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<div class="ai-custom-liquid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div id='alignment-application' style='scroll-margin-top: 120px;'></div>
</div>

{% schema %}
{
  "name": "Custom liquid",
  "settings": [],
  "presets": [
    {
      "name": "Custom liquid"
    }
  ]
}
{% endschema %}
