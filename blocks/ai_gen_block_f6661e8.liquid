{% doc %}
  @prompt
    "Create a two-column, full-width section with a white or light grey background. It is critical that the image and text are in separate, equal-width (50%) columns, and their order (left-to-right) can be exchanged. One column must be a flexible image block (like image_3.png style). The other column is a clean, precisely-padded text container with a white background and content flowing top-down. This text column must contain:
    
    A small, spaced sans-serif kicker text at the top (light gold color).
    
    A large, bold, elegant serif headline (e.g., image_1.png style).
    
    A readable sans-serif descriptive paragraph with paragraph spacing.
    
    A responsively-spaced sans-serif bulleted list, with a small, filled gold sphere mark (like image_3.png detail) for each point.
    
    An optional outlined CTA button with spacing below the list.
    Specify serif font for the main headline and sans-serif font for all other text elements. Spacing between all elements is crucial for a clean, editorial look.", I want to add the option for the description part to be able to have multiple paragraphs as needed and to be able to change font type, font size and bolden it if needed and italicized as an option. I would also like to have the list section to be able to have the option of adding more list points and the list points to have their own subtitle with option to have different fonts options (the two matching this section) and to be able to make the subtitles bold if needed. or Italicized as an option too. I want the photo holder to be slightly smaller providing white space around teh photo in the section to be more airy like editorial style. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-editorial-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-two-column-editorial__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {% if block.settings.layout == 'image_left' %}row{% else %}row-reverse{% endif %};
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-two-column-editorial__image-column-{{ ai_gen_id }} {
    flex: 0 0 50%;
    width: 50%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.image_padding }}px;
  }

  .ai-two-column-editorial__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
  }

  .ai-two-column-editorial__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-two-column-editorial__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-two-column-editorial__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-two-column-editorial__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-two-column-editorial__text-column-{{ ai_gen_id }} {
    flex: 0 0 50%;
    width: 50%;
    background-color: {{ block.settings.text_column_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.text_column_padding }}px;
  }

  .ai-two-column-editorial__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-two-column-editorial__kicker-{{ ai_gen_id }} {
    font-family: {{ block.settings.sans_serif_font.family }}, {{ block.settings.sans_serif_font.fallback_families }};
    font-weight: {{ block.settings.sans_serif_font.weight }};
    font-style: {{ block.settings.sans_serif_font.style }};
    font-size: {{ block.settings.kicker_font_size }}px;
    color: {{ block.settings.kicker_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.kicker_letter_spacing }}px;
    margin: 0 0 {{ block.settings.kicker_spacing }}px 0;
    display: block;
  }

  .ai-two-column-editorial__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.serif_font.family }}, {{ block.settings.serif_font.fallback_families }};
    font-weight: {{ block.settings.serif_font.weight }};
    font-style: {{ block.settings.serif_font.style }};
    font-size: {{ block.settings.headline_font_size }}px;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px 0;
  }

  .ai-two-column-editorial__description-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.description_spacing }}px 0;
  }

  .ai-two-column-editorial__description-{{ ai_gen_id }} p {
    font-family: {% if block.settings.description_font_type == 'serif' %}{{ block.settings.serif_font.family }}, {{ block.settings.serif_font.fallback_families }}{% else %}{{ block.settings.sans_serif_font.family }}, {{ block.settings.sans_serif_font.fallback_families }}{% endif %};
    font-size: {{ block.settings.description_font_size }}px;
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
    font-weight: {% if block.settings.description_bold %}700{% else %}normal{% endif %};
    font-style: {% if block.settings.description_italic %}italic{% else %}normal{% endif %};
  }

  .ai-two-column-editorial__description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-two-column-editorial__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 {{ block.settings.list_spacing }}px 0;
  }

  .ai-two-column-editorial__list-item-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.list_item_spacing }}px;
    padding-left: {{ block.settings.bullet_spacing }}px;
    position: relative;
  }

  .ai-two-column-editorial__list-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-two-column-editorial__list-item-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    left: 0;
    top: {{ block.settings.bullet_vertical_position }}px;
    width: {{ block.settings.bullet_size }}px;
    height: {{ block.settings.bullet_size }}px;
    background-color: {{ block.settings.bullet_color }};
    border-radius: 50%;
  }

  .ai-two-column-editorial__list-subtitle-{{ ai_gen_id }} {
    font-family: {% if block.settings.list_subtitle_font_type == 'serif' %}{{ block.settings.serif_font.family }}, {{ block.settings.serif_font.fallback_families }}{% else %}{{ block.settings.sans_serif_font.family }}, {{ block.settings.sans_serif_font.fallback_families }}{% endif %};
    font-size: {{ block.settings.list_subtitle_font_size }}px;
    color: {{ block.settings.list_subtitle_color }};
    font-weight: {% if block.settings.list_subtitle_bold %}700{% else %}normal{% endif %};
    font-style: {% if block.settings.list_subtitle_italic %}italic{% else %}normal{% endif %};
    display: block;
    margin-bottom: {{ block.settings.list_subtitle_spacing }}px;
  }

  .ai-two-column-editorial__list-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.sans_serif_font.family }}, {{ block.settings.sans_serif_font.fallback_families }};
    font-weight: {{ block.settings.sans_serif_font.weight }};
    font-style: {{ block.settings.sans_serif_font.style }};
    font-size: {{ block.settings.list_font_size }}px;
    line-height: {{ block.settings.list_line_height }};
    color: {{ block.settings.list_color }};
  }

  .ai-two-column-editorial__button-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.sans_serif_font.family }}, {{ block.settings.sans_serif_font.fallback_families }};
    font-weight: {{ block.settings.sans_serif_font.weight }};
    font-style: {{ block.settings.sans_serif_font.style }};
    font-size: {{ block.settings.button_font_size }}px;
    color: {{ block.settings.button_text_color }};
    background-color: transparent;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    text-align: center;
  }

  .ai-two-column-editorial__button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_text_color }};
    background-color: {{ block.settings.button_hover_background }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-two-column-editorial__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-two-column-editorial__image-column-{{ ai_gen_id }},
    .ai-two-column-editorial__text-column-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    .ai-two-column-editorial__image-column-{{ ai_gen_id }} {
      padding: {{ block.settings.image_padding_mobile }}px;
    }

    .ai-two-column-editorial__image-wrapper-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-two-column-editorial__text-column-{{ ai_gen_id }} {
      padding: {{ block.settings.text_column_padding_mobile }}px;
    }

    .ai-two-column-editorial__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_font_size_mobile }}px;
    }
  }
{% endstyle %}

<two-column-editorial-{{ ai_gen_id }} class="ai-two-column-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-editorial__container-{{ ai_gen_id }}">
    <div class="ai-two-column-editorial__image-column-{{ ai_gen_id }}">
      <div class="ai-two-column-editorial__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-two-column-editorial__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-two-column-editorial__empty-state-{{ ai_gen_id }}">
              Add an image to complete this section
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-two-column-editorial__text-column-{{ ai_gen_id }}">
      <div class="ai-two-column-editorial__content-{{ ai_gen_id }}">
        {% if block.settings.kicker != blank %}
          <span class="ai-two-column-editorial__kicker-{{ ai_gen_id }}">{{ block.settings.kicker }}</span>
        {% endif %}

        {% if block.settings.headline != blank %}
          <h2 class="ai-two-column-editorial__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-two-column-editorial__description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.show_list %}
          <ul class="ai-two-column-editorial__list-{{ ai_gen_id }}">
            {% if block.settings.list_item_1 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_1 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_1 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_1 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_2 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_2 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_2 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_2 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_3 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_3 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_3 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_3 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_4 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_4 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_4 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_4 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_5 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_5 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_5 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_5 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_6 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_6 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_6 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_6 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_7 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_7 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_7 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_7 }}</span>
              </li>
            {% endif %}
            {% if block.settings.list_item_8 != blank %}
              <li class="ai-two-column-editorial__list-item-{{ ai_gen_id }}">
                {% if block.settings.list_subtitle_8 != blank %}
                  <span class="ai-two-column-editorial__list-subtitle-{{ ai_gen_id }}">{{ block.settings.list_subtitle_8 }}</span>
                {% endif %}
                <span class="ai-two-column-editorial__list-text-{{ ai_gen_id }}">{{ block.settings.list_item_8 }}</span>
              </li>
            {% endif %}
          </ul>
        {% endif %}

        {% if block.settings.show_button and block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-two-column-editorial__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</two-column-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoColumnEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('two-column-editorial-{{ ai_gen_id }}', TwoColumnEditorial{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Two column editorial",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "image_left",
          "label": "Image left, text right"
        },
        {
          "value": "image_right",
          "label": "Image right, text left"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "text_column_background",
      "label": "Text column background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_column_padding",
      "label": "Text column padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_column_padding_mobile",
      "label": "Text column padding (mobile)",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 300,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_padding",
      "label": "Image padding",
