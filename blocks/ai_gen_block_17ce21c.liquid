    {
      "type": "range",
      "id": "subtext_weight",
      "label": "Weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "checkbox",
      "id": "subtext_italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Color",
      "default": "#ffffff"
