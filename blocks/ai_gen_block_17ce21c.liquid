      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500
    },
    {
      "type": "checkbox",
      "id": "cta_italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Color",
      "default": "#ffffff"
