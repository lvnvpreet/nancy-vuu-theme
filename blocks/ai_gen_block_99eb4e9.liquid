{% doc %}
  @prompt
    Please create an "Image with Text" section (a 50/50 side-by-side layout). Use a soft off-white background (#FAFAFA) to blend seamlessly with the rest of the luxury page, and include massive vertical padding (white space) above and below the section.
    
    Left Side (Image):
    
    Add a large, vertical placeholder image. 
    
    Right Side (Text Block):
    
    Vertical Alignment: Middle/Center.
    
    Horizontal Alignment: Left-aligned text, but with generous padding on the left so it doesn't touch the image.
    
    Tagline/Overline: "THE ATELIER CONCIERGE" (Format in a thin Sans-serif font, ALL CAPS, wide letter spacing, muted champagne gold).
    
    Main Heading: "The Private Estate Experience" (Format in a thin, elegant Serif font like Cormorant Garamond, dark grey).
    
    Body Text: "For our most discerning clientele, time and discretion are the ultimate luxuries. We extend the sanctuary of the Atelier directly to your private residence, vineyard estate, or executive boardroom. Experience the entirety of our bespoke fitting and curation process in the absolute privacy of your own domain, exclusively serving Silicon Valley and Napa Wine Country." (Format in a thin Sans-serif font like Montserrat, light grey/charcoal, with a tall, airy line height).
    
    No Buttons: Do not include a button in this section, as it leads directly into the intake form below it.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-image-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    padding-left: {{ block.settings.content_padding_left }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-tagline-{{ ai_gen_id }} {
    font-family: {{ block.settings.tagline_font.family }}, {{ block.settings.tagline_font.fallback_families }};
    font-weight: {{ block.settings.tagline_font.weight }};
    font-size: {{ block.settings.tagline_size }}px;
    color: {{ block.settings.tagline_color }};
    letter-spacing: {{ block.settings.tagline_letter_spacing }}em;
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.tagline_margin_bottom }}px 0;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: {{ block.settings.heading_line_height }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
  }

  .ai-image-text-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: {{ block.settings.body_line_height }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_vertical_padding }}px 0;
    }

    .ai-image-text-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_grid_gap }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      padding-left: 0;
      text-align: {{ block.settings.mobile_text_alignment }};
    }

    .ai-image-text-tagline-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_tagline_size }}px;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-image-text-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_body_size }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-grid-{{ ai_gen_id }}">
      <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-text-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-image-text-content-{{ ai_gen_id }}">
        {% if block.settings.tagline != blank %}
          <div class="ai-image-text-tagline-{{ ai_gen_id }}">
            {{ block.settings.tagline }}
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.body_text != blank %}
          <div class="ai-image-text-body-{{ ai_gen_id }}">
            {{ block.settings.body_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

