    padding-bottom: {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-engage-visionary-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-engage-visionary-image-side-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: {{ block.settings.image_width }}%;
    height: {{ block.settings.image_height }}px;
  }

  .ai-engage-visionary-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-engage-visionary-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-engage-visionary-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-engage-visionary-fade-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: {{ block.settings.fade_height }}%;
    background: linear-gradient(to bottom, transparent, {{ block.settings.fade_color }});
    pointer-events: none;
  }

  .ai-engage-visionary-form-side-{{ ai_gen_id }} {
    background-color: {{ block.settings.form_background_color }};
    padding: {{ block.settings.form_padding_top }}px {{ block.settings.form_padding_horizontal }}px {{ block.settings.form_padding_bottom }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-engage-visionary-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: {{ block.settings.eyebrow_spacing }}px;
  }

  .ai-engage-visionary-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    line-height: 1.2;
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-engage-visionary-subheader-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheader_font.family }}, {{ block.settings.subheader_font.fallback_families }};
    font-weight: {{ block.settings.subheader_font.weight }};
    font-size: {{ block.settings.subheader_size }}px;
    color: {{ block.settings.subheader_color }};
    line-height: 1.6;
    margin-bottom: {{ block.settings.subheader_spacing }}px;
  }

  .ai-engage-visionary-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.form_field_spacing }}px;
  }

  .ai-engage-visionary-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-engage-visionary-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
  }

  .ai-engage-visionary-helper-{{ ai_gen_id }} {
    font-family: {{ block.settings.helper_font.family }}, {{ block.settings.helper_font.fallback_families }};
    font-weight: {{ block.settings.helper_font.weight }};
    font-size: {{ block.settings.helper_size }}px;
    color: {{ block.settings.helper_color }};
    font-style: italic;
    margin-top: -4px;
  }

  .ai-engage-visionary-input-{{ ai_gen_id }},
  .ai-engage-visionary-select-{{ ai_gen_id }},
  .ai-engage-visionary-textarea-{{ ai_gen_id }} {
    font-family: {{ block.settings.input_font.family }}, {{ block.settings.input_font.fallback_families }};
    font-weight: {{ block.settings.input_font.weight }};
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background_color }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
