<engage-visionary-{{ ai_gen_id }}
  class="ai-engage-visionary-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-engage-visionary-container-{{ ai_gen_id }}">
    <div class="ai-engage-visionary-image-side-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-engage-visionary-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-engage-visionary-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.enable_fade %}
        <div class="ai-engage-visionary-fade-overlay-{{ ai_gen_id }}"></div>
      {% endif %}
    </div>

    <div class="ai-engage-visionary-form-side-{{ ai_gen_id }}">
      {%- if block.settings.eyebrow != blank -%}
        <div class="ai-engage-visionary-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {%- endif -%}

      {%- if block.settings.title != blank -%}
        <h2 class="ai-engage-visionary-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {%- endif -%}

      {%- if block.settings.subheader != blank -%}
        <div class="ai-engage-visionary-subheader-{{ ai_gen_id }}">{{ block.settings.subheader }}</div>
      {%- endif -%}

      {%- form 'contact' -%}
        <input type="hidden" name="contact[form_type]" value="media_inquiry">
        
        <div class="ai-engage-visionary-form-{{ ai_gen_id }}">
          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-name-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              Full Name & Title
            </label>
            <input
              type="text"
              id="ai-engage-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-engage-visionary-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-organization-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              Organization / Media Outlet
            </label>
            <input
              type="text"
              id="ai-engage-organization-{{ ai_gen_id }}"
              name="contact[organization]"
              class="ai-engage-visionary-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-email-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              Professional Contact Email
            </label>
            <input
              type="email"
              id="ai-engage-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-engage-visionary-input-{{ ai_gen_id }}"
              autocomplete="email"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-engage-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-engage-success-{{ ai_gen_id }}"
              {% endif %}
              required
            >
          </div>

          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-phone-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              Direct Liaison Number (Optional)
            </label>
            <input
              type="tel"
              id="ai-engage-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-engage-visionary-input-{{ ai_gen_id }}"
            >
          </div>

          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-engagement-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              Engagement Type
            </label>
            <select
              id="ai-engage-engagement-{{ ai_gen_id }}"
              name="contact[engagement_type]"
              class="ai-engage-visionary-select-{{ ai_gen_id }}"
              required
            >
              <option value="">Select an option</option>
              <option value="broadcast_feature">Broadcast Feature</option>
              <option value="editorial_cover">Editorial / Cover Story</option>
              <option value="keynote_dialogue">Keynote Dialogue</option>
              <option value="documentary_film">Documentary / Film Collaboration</option>
            </select>
          </div>

          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-vision-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              The Vision
            </label>
            <div class="ai-engage-visionary-helper-{{ ai_gen_id }}">
              Describe the narrative you wish for Nancy Vuu to deliver.
            </div>
            <textarea
              id="ai-engage-vision-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-engage-visionary-textarea-{{ ai_gen_id }}"
              required
            ></textarea>
          </div>

          <div class="ai-engage-visionary-field-{{ ai_gen_id }}">
            <label for="ai-engage-timeline-{{ ai_gen_id }}" class="ai-engage-visionary-label-{{ ai_gen_id }}">
              Proposed Timeline
            </label>
            <input
              type="date"
              id="ai-engage-timeline-{{ ai_gen_id }}"
              name="contact[timeline]"
              class="ai-engage-visionary-input-{{ ai_gen_id }}"
            >
          </div>

          {%- if form.errors -%}
            <div
              id="ai-engage-error-{{ ai_gen_id }}"
              class="ai-engage-visionary-error-{{ ai_gen_id }}"
            >
              {{ form.errors.messages.email }}
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div
              id="ai-engage-success-{{ ai_gen_id }}"
              class="ai-engage-visionary-success-{{ ai_gen_id }}"
            >
              {{ block.settings.success_message }}
            </div>
          {%- endif -%}

          <button
            type="submit"
            class="ai-engage-visionary-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</engage-visionary-{{ ai_gen_id }}>

<script>
  (function() {
    class EngageVisionary{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.setupFormValidation();
        }
      }

      setupFormValidation() {
        this.form.addEventListener('submit', (e) => {
          const inputs = this.form.querySelectorAll('input[required], textarea[required], select[required]');
          let isValid = true;

          inputs.forEach((input) => {
            if (!input.value.trim()) {
              isValid = false;
              input.setAttribute('aria-invalid', 'true');
            } else {
              input.removeAttribute('aria-invalid');
            }
          });

          if (!isValid) {
            e.preventDefault();
          }
        });
      }
    }

    customElements.define('engage-visionary-{{ ai_gen_id }}', EngageVisionary{{ ai_gen_id }});
  })();
</script>

