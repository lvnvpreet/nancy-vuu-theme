{% doc %}
  @prompt
    create a segment for a photo or video to be full bleed with optional eyebrow, headline, and subheadline. give me full access control to adjust font size, font style, and segment height with no restrictions or retrainsts. also give me the option to have overlay of white or dark opaque over the entire segment with adjustable opague strength. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullbleed-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.segment_height }}px;
    overflow: hidden;
    display: block;
  }

  .ai-fullbleed-hero__media-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-fullbleed-hero__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    {% if block.settings.overlay_color == 'white' %}
      background-color: rgba(255, 255, 255, {{ block.settings.overlay_opacity }});
    {% else %}
      background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    {% endif %}
    pointer-events: none;
  }

  .ai-fullbleed-hero__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    padding: {{ block.settings.content_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 1;
  }

  .ai-fullbleed-hero__eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-style: {{ block.settings.eyebrow_font.style }};
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 {{ block.settings.eyebrow_spacing }}px 0;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    text-transform: {{ block.settings.eyebrow_text_transform }};
  }

  .ai-fullbleed-hero__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-style: {{ block.settings.headline_font.style }};
    font-size: {{ block.settings.headline_font_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px 0;
    line-height: {{ block.settings.headline_line_height }};
    letter-spacing: {{ block.settings.headline_letter_spacing }}px;
  }

  .ai-fullbleed-hero__subheadline-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheadline_font.family }}, {{ block.settings.subheadline_font.fallback_families }};
    font-weight: {{ block.settings.subheadline_font.weight }};
    font-style: {{ block.settings.subheadline_font.style }};
    font-size: {{ block.settings.subheadline_font_size }}px;
    color: {{ block.settings.subheadline_color }};
    margin: 0;
    line-height: {{ block.settings.subheadline_line_height }};
    letter-spacing: {{ block.settings.subheadline_letter_spacing }}px;
    max-width: {{ block.settings.subheadline_max_width }}px;
  }

  .ai-fullbleed-hero__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-fullbleed-hero__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-fullbleed-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-fullbleed-hero-{{ ai_gen_id }} {
      height: {{ block.settings.segment_height_mobile }}px;
    }

    .ai-fullbleed-hero__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_mobile }}px;
    }

    .ai-fullbleed-hero__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_font_size_mobile }}px;
    }

    .ai-fullbleed-hero__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_font_size_mobile }}px;
    }

    .ai-fullbleed-hero__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }
  }
{% endstyle %}

<full-bleed-hero-{{ ai_gen_id }} class="ai-fullbleed-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.media_type == 'image' %}
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2400 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-fullbleed-hero__media-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-fullbleed-hero__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-fullbleed-hero__empty-state-{{ ai_gen_id }}">
          Add an image or video to get started
        </div>
      </div>
    {% endif %}
  {% else %}
    {% if block.settings.video %}
      <video
        class="ai-fullbleed-hero__media-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        {% if block.settings.video_poster %}
          poster="{{ block.settings.video_poster | image_url: width: 2400 }}"
        {% endif %}
      >
        <source src="{{ block.settings.video }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-fullbleed-hero__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-fullbleed-hero__empty-state-{{ ai_gen_id }}">
          Add an image or video to get started
        </div>
      </div>
    {% endif %}
  {% endif %}

  {% if block.settings.enable_overlay %}
    <div class="ai-fullbleed-hero__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-fullbleed-hero__content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-fullbleed-hero__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h2 class="ai-fullbleed-hero__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <div class="ai-fullbleed-hero__subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</div>
    {% endif %}
  </div>
</full-bleed-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class FullBleedHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('video');
        if (video) {
          video.play().catch(function() {});
        }
      }
    }

    customElements.define('full-bleed-hero-{{ ai_gen_id }}', FullBleedHero{{ ai_gen_id }});
  })();
</script>

