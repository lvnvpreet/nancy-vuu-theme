{% doc %}
  @prompt
    i need to create a segment with a very short height just enough to put an eyebrow and subtext using manrope font and to put a CTA button with link. The CTA button needs to say "Request a Consultation". , give me control access to add more white space above the eyebrow and below the CTA button to be more airy
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-cta-banner__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    gap: {{ block.settings.content_gap }}px;
    max-width: 100%;
    padding-top: {{ block.settings.eyebrow_top_spacing }}px;
    padding-bottom: {{ block.settings.button_bottom_spacing }}px;
  }

  .ai-cta-banner__eyebrow-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: {{ block.settings.eyebrow_weight }};
    color: {{ block.settings.eyebrow_color }};
    text-transform: {{ block.settings.eyebrow_transform }};
    letter-spacing: {{ block.settings.eyebrow_spacing }}em;
    margin: 0;
  }

  .ai-cta-banner__subtext-{{ ai_gen_id }} {
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.subtext_size }}px;
    font-weight: {{ block.settings.subtext_weight }};
    color: {{ block.settings.subtext_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-cta-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    font-family: 'Manrope', sans-serif;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-cta-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-cta-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding | times: 0.7 }}px {{ block.settings.horizontal_padding | times: 0.7 }}px;
    }

    .ai-cta-banner__content-{{ ai_gen_id }} {
      padding-top: {{ block.settings.eyebrow_top_spacing | times: 0.7 }}px;
      padding-bottom: {{ block.settings.button_bottom_spacing | times: 0.7 }}px;
    }

    .ai-cta-banner__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }

    .ai-cta-banner__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-cta-banner__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-cta-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-banner__content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <p class="ai-cta-banner__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</p>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-cta-banner__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    {% if block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-cta-banner__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% else %}
      <span class="ai-cta-banner__button-{{ ai_gen_id }}" style="cursor: default;">
        {{ block.settings.button_text }}
      </span>
    {% endif %}
  </div>
</div>

