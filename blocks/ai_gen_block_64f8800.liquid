{% doc %}
  @prompt
    To get the best result from the Shopify AI (or a developer), you should copy everything from "Segment Intent" down to the "CTA Button." This gives the AI the context of the brand, the exact wording, and the specific "Sovereign" styling instructions.
    
    Copy from here:
    Segment Intent: Create a high-impact, minimalist "Collective Call to Action" segment that concludes the Three Phases of Restoration.
    Aesthetic: Sovereign Luxury. Use a palette of Cream (#F5F5F1), Charcoal Black (#1A1A1A), and Muted Gold.
    
    1. Layout & Separator:
    
    Spacing: Center all elements. Use 100px vertical padding (top and bottom).
    
    Top Separator: Add a 1px thin, Muted Gold horizontal line (100px width) above the header.
    
    2. The Collective Heading:
    
    Text: ONE HOUSE. ONE MISSION. TOTAL RESTORATION.
    
    Style: All Caps, Serif font (Bodoni Moda or Montserrat Light). Letter spacing: 0.4em. Font size: 2rem.
    
    3. The Narrative Connector:
    
    Text: "We do not just heal; we house. We do not just protect; we propel. Your investment fuels the complete cycle—from the restoration of worth to the elevation of dreams realized."
    
    Style: Italicized Serif font, max-width 750px. Font size: 1.1rem. Line height: 1.8.
    
    4. The Sovereign CTA Button:
    
    Button Text: JOIN THE ALLIANCE
    
    Link: [Insert Your PayPal Alliance Link Here]
    
    Style: Sharp-edged rectangle (no rounded corners). Solid Charcoal Black background with White text. Letter spacing: 0.2em.
    
    5. Animation:
    
    Apply a gentle 'Upward Slide' fade-in animation as the user scrolls to this segment. give me control access to modify padding for top and bottom of segment, and control access to edit all content. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collective-cta-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ai-collective-cta__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-collective-cta__separator-{{ ai_gen_id }} {
    width: 100px;
    height: 1px;
    background-color: {{ block.settings.separator_color }};
    margin-bottom: 40px;
  }

  .ai-collective-cta__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-transform: uppercase;
    letter-spacing: 0.4em;
    margin: 0 0 40px 0;
    line-height: 1.3;
  }

  .ai-collective-cta__narrative-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, serif;
    font-weight: {{ block.settings.body_font.weight }};
    font-style: italic;
    font-size: {{ block.settings.narrative_size }}px;
    color: {{ block.settings.narrative_color }};
    max-width: 750px;
    line-height: 1.8;
    margin: 0 0 50px 0;
  }

  .ai-collective-cta__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 18px 50px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    font-weight: 500;
    font-size: {{ block.settings.button_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-collective-cta__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-collective-cta__content-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-collective-cta__content-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  @media screen and (max-width: 749px) {
    .ai-collective-cta__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      letter-spacing: 0.2em;
    }

    .ai-collective-cta__narrative-{{ ai_gen_id }} {
      font-size: {{ block.settings.narrative_size | times: 0.9 }}px;
    }

    .ai-collective-cta__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size | times: 0.9 }}px;
      padding: 15px 35px;
    }
  }
{% endstyle %}

<collective-cta-{{ ai_gen_id }} class="ai-collective-cta-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collective-cta__container-{{ ai_gen_id }}">
    <div class="ai-collective-cta__content-{{ ai_gen_id }}">
      <div class="ai-collective-cta__separator-{{ ai_gen_id }}"></div>
      
      <h2 class="ai-collective-cta__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
      
      <div class="ai-collective-cta__narrative-{{ ai_gen_id }}">
        {{ block.settings.narrative }}
      </div>
      
      <a href="{{ block.settings.button_link }}" class="ai-collective-cta__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    </div>
  </div>
</collective-cta-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectiveCta{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.content = this.querySelector('.ai-collective-cta__content-{{ ai_gen_id }}');
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.content.classList.add('ai-visible-{{ ai_gen_id }}');
              observer.unobserve(entry.target);
            }
          });
        }, options);

        observer.observe(this);
      }
    }

    customElements.define('collective-cta-{{ ai_gen_id }}', CollectiveCta{{ ai_gen_id }});
  })();
</script>

