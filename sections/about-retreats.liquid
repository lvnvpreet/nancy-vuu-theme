{%- comment -%} About — The Dream Retreats (split layout) {%- endcomment -%}

<section class="about-retreats" data-section-id="{{ section.id }}" style="background:#fff; padding: 8rem 1.5rem;">
  <div class="about-retreats__inner">
    <div class="about-retreats__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow about-retreats__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="about-retreats__heading serif-font">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="about-retreats__body">
        {%- if section.settings.paragraph_1 != blank -%}
          <p>{{ section.settings.paragraph_1 }}</p>
        {%- endif -%}
        {%- if section.settings.paragraph_2 != blank -%}
          <p>{{ section.settings.paragraph_2 }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="about-retreats__cta">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="about-retreats__media">
      {%- assign retreats_img_url = section.settings.image_url | strip -%}
      {%- if retreats_img_url != blank -%}
        <div class="about-retreats__img-frame">
          <img src="{{ retreats_img_url }}" class="about-retreats__img" loading="lazy" alt="{{ section.settings.heading }}">
        </div>
      {%- elsif section.settings.image != blank -%}
        <div class="about-retreats__img-frame">
          {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'about-retreats__img', loading: 'lazy', alt: section.settings.heading }}
        </div>
      {%- else -%}
        <div class="about-retreats__img-frame">
          <div class="img-placeholder" style="aspect-ratio:1/1;">
            <span>Upload retreat image in Theme Editor</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .about-retreats__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .about-retreats__img-frame {
    background: var(--greige);
    padding: 1rem;
    height: 100%;
  }
  .about-retreats__img {
    width: 100%;
    height: 100%;
    max-height: 520px;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .about-retreats__eyebrow {
    color: var(--gold);
    font-size: .625rem;
    letter-spacing: .6em;
  }
  .about-retreats__heading {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-style: italic;
    margin-bottom: 2rem;
  }
  .about-retreats__body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .about-retreats__body p {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    color: #555;
    line-height: 1.85;
  }
  .about-retreats__cta {
    font-family: var(--font-sans);
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .5em;
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--gold);
    padding-bottom: .25rem;
    display: inline-block;
    transition: color .3s ease;
  }
  .about-retreats__cta:hover {
    color: var(--gold);
  }
  @media (max-width: 768px) {
    .about-retreats__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-retreats__text { order: 1; }
    .about-retreats__media { order: 2; }
  }
</style>

{% schema %}
{
  "name": "About — Retreats",
  "settings": [
    {
      "type": "text",
      "id": "image_url",
      "label": "Retreat Image URL",
      "info": "Paste a direct image URL (https://...). This takes priority over the image picker below."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Retreat Image (Shopify Upload)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Restoration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Dream Retreats"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Because a visionary cannot lead from depletion, our Dream Retreats offer a sanctuary for the spirit."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "We gather in places of profound beauty to silence the noise of the world and remember why we were called. These are curated spaces of quiet luxury, designed for visualization, restoration, and the architecting of your next decade."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "View Upcoming Sanctuaries"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "About — Retreats"
    }
  ]
}
{% endschema %}
