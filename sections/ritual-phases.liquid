{%- comment -%} The Atelier Ritual — 3 phase grid {%- endcomment -%}
<section class="ritual-section reveal">
  <div class="ritual-section__inner">
    {% if section.settings.eyebrow != blank %}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h3 class="ritual-section__title serif-font">{{ section.settings.title | default: "The Atelier Ritual" }}</h3>

    <div class="ritual-grid">
      {% for block in section.blocks %}
        <div class="ritual-grid__item reveal delay-{{ forloop.index }}00" {{ block.shopify_attributes }}>
          <h4 class="ritual-grid__heading serif-font">{{ block.settings.heading }}</h4>
          <p class="ritual-grid__desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ritual Phases",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow",  "default": "The Private Experience" },
    { "type": "text", "id": "title",   "label": "Title",    "default": "The Atelier Ritual" }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "Phase",
      "settings": [
        { "type": "text",     "id": "heading",     "label": "Heading",     "default": "Phase Title" },
        { "type": "textarea", "id": "description",  "label": "Description", "default": "Phase description goes here." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ritual Phases",
      "blocks": [
        { "type": "phase", "settings": { "heading": "Sanctuary Arrival", "description": "Step into a private sanctuary where the world falls away, beginning with a ceremonial tea and vision alignment." } },
        { "type": "phase", "settings": { "heading": "Architectural Sketching", "description": "Nancy captures the geometry of your spirit on paper, creating an original blueprint exclusive to your legacy." } },
        { "type": "phase", "settings": { "heading": "The Crowning Fitting", "description": "A final coronation in our San Jose atelier, where master tailors ensure the gown becomes a second skin." } }
      ]
    }
  ]
}
{% endschema %}
