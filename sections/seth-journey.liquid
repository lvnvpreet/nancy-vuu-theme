<section class="seth-journey" data-section-id="{{ section.id }}">
  <div class="seth-journey__inner reveal">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow" style="color: var(--seth-gold);">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h3 class="seth-journey__title serif">{{ section.settings.heading }}</h3>

    <div class="seth-journey__steps">
      {%- for block in section.blocks -%}
        <div class="seth-journey__step" {{ block.shopify_attributes }}>
          <span class="seth-journey__step-num serif"><em>{{ block.settings.number }}</em></span>
          <h4 class="seth-journey__step-heading">{{ block.settings.heading }}</h4>
          <p class="seth-journey__step-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-bespoke seth-journey__cta">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Seth Journey",
  "class": "seth-section-journey",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Journey"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Vision to Vesting."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Begin Your Appointment"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The Reveal"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Explore our atelier inspirations in Napa or San Jose—the visual foundations of your identity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seth Journey",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01.",
            "heading": "The Reveal",
            "text": "Explore our atelier inspirations in Napa or San Jose—the visual foundations of your identity."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02.",
            "heading": "The Consultation",
            "text": "Collaborate with our designers to customize your mandated silhouette, choosing textures that reflect your unique calling."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03.",
            "heading": "The Appointing",
            "text": "Your final fitting—the moment where your garment and your identity are unified in a bespoke appointment."
          }
        }
      ]
    }
  ]
}
{% endschema %}
