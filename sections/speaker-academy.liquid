{% comment %} sections/speaker-academy.liquid {% endcomment %}
<section id="{{ section.settings.section_id | default: 'speaker' }}" class="section-speaker">
  <div class="section-speaker__inner">

    {%- comment -%} Left: Nancy Vuu Profile {%- endcomment -%}
    <div class="section-speaker__profile reveal">
      <div class="section-speaker__profile-grid">
        <div class="section-speaker__portrait">
          {%- render 'image',
              image: section.settings.portrait,
              sizes: '(max-width:768px) 100vw, 30vw',
              placeholder_text: 'Nancy Vuu Portrait'
          -%}
        </div>
        <div class="section-speaker__bio">
          <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Founder' }}</span>

          {%- for block in section.blocks -%}
            {%- if block.type == 'title_line' -%}
              <h2 class="serif-font section-speaker__title {% if block.settings.italic %}section-speaker__title--italic{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </h2>
            {%- endif -%}
          {%- endfor -%}

          <div class="divider"></div>
          <p class="body-copy">{{ section.settings.bio | default: 'Author of "Let There Be Fashion". Nancy Vuu bridges the gap between the marketplace and ministry &mdash; redefining what it means to lead with purpose.' }}</p>

          <div class="section-speaker__links">
            {%- for block in section.blocks -%}
              {%- if block.type == 'link' -%}
                <a href="{{ block.settings.url | default: '#' }}" class="section-speaker__link" {{ block.shopify_attributes }}>
                  → {{ block.settings.label }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} Right: Dream Academy {%- endcomment -%}
    <div id="{{ section.settings.academy_id | default: 'academy' }}" class="section-speaker__academy bg-greige reveal delay-100">
      <span class="eyebrow" style="color:#888;">{{ section.settings.academy_eyebrow | default: 'Education' }}</span>
      <h3 class="serif-font section-speaker__academy-title">{{ section.settings.academy_title | default: 'Dream Academy' }}</h3>
      <div class="divider"></div>
      <p class="body-copy" style="max-width:100%;">{{ section.settings.academy_description | default: 'Vuu Publishing. Women&rsquo;s CEO. Media Marketing. We equip the next generation of kingdom leaders to build with vision and authenticity.' }}</p>
      <a href="{{ section.settings.academy_link | default: '#' }}" class="btn-editorial">{{ section.settings.academy_cta | default: 'Join The Academy' }}</a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Speaker & Academy",
  "max_blocks": 10,
  "settings": [
    { "type": "text",         "id": "section_id",          "label": "Section anchor ID",      "default": "speaker" },
    { "type": "image_picker", "id": "portrait",            "label": "Portrait image" },
    { "type": "text",         "id": "eyebrow",             "label": "Eyebrow text",           "default": "The Founder" },
    { "type": "richtext",     "id": "bio",                 "label": "Bio paragraph" },
    { "type": "header",       "content": "Dream Academy" },
    { "type": "text",         "id": "academy_id",          "label": "Academy anchor ID",      "default": "academy" },
    { "type": "text",         "id": "academy_eyebrow",     "label": "Academy eyebrow",        "default": "Education" },
    { "type": "text",         "id": "academy_title",       "label": "Academy title",          "default": "Dream Academy" },
    { "type": "textarea",     "id": "academy_description", "label": "Academy description",    "default": "Vuu Publishing. Women's CEO. Media Marketing. We equip the next generation of kingdom leaders to build with vision and authenticity." },
    { "type": "text",         "id": "academy_cta",         "label": "Academy button text",    "default": "Join The Academy" },
    { "type": "url",          "id": "academy_link",        "label": "Academy button link" }
  ],
  "blocks": [
    {
      "type": "title_line",
      "name": "Title Line",
      "settings": [
        { "type": "text",     "id": "text",   "label": "Text",   "default": "Speaker." },
        { "type": "checkbox", "id": "italic", "label": "Italic", "default": false }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Book for Speaking" },
        { "type": "url",  "id": "url",   "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Speaker & Academy",
      "blocks": [
        { "type": "title_line", "settings": { "text": "Speaker.", "italic": false } },
        { "type": "title_line", "settings": { "text": "Mentor.",  "italic": true } },
        { "type": "title_line", "settings": { "text": "Author.",  "italic": false } },
        { "type": "link", "settings": { "label": "Book for Speaking" } },
        { "type": "link", "settings": { "label": "Mentorship Program" } },
        { "type": "link", "settings": { "label": "Buy The Book" } }
      ]
    }
  ]
}
{% endschema %}
