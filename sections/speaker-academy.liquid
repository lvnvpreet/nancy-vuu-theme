{% comment %} sections/speaker-academy.liquid {% endcomment %}
<section id="{{ section.settings.section_id | default: 'speaker' }}" class="section-speaker">
  <div class="section-speaker__inner">

    {%- comment -%} Left: Nancy Vuu Profile {%- endcomment -%}
    <div class="section-speaker__profile reveal">
      <div class="section-speaker__profile-grid">
        <div class="section-speaker__portrait">
          {%- render 'image',
              image: section.settings.portrait,
              sizes: '(max-width:768px) 100vw, 30vw',
              placeholder_text: 'Nancy Vuu Portrait'
          -%}
        </div>
        <div class="section-speaker__bio">
          <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Founder' }}</span>

          {%- for block in section.blocks -%}
            {%- if block.type == 'title_line' -%}
              <h2 class="serif-font section-speaker__title {% if block.settings.italic %}section-speaker__title--italic{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </h2>
            {%- endif -%}
          {%- endfor -%}

          <div class="divider"></div>
          <div class="body-copy">{{ section.settings.bio | default: 'Author of "Let There Be Fashion". Nancy Vuu bridges the gap between the marketplace and ministry &mdash; redefining what it means to lead with purpose.' }}</div>

          <div class="section-speaker__links">
            {%- for block in section.blocks -%}
              {%- if block.type == 'link' -%}
                <a href="{{ block.settings.url | default: '#' }}" class="section-speaker__link" {{ block.shopify_attributes }}>
                  → {{ block.settings.label }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} Right: Press {%- endcomment -%}
    <div id="{{ section.settings.press_id | default: 'press' }}" class="section-speaker__academy bg-greige reveal delay-100">
      <span class="eyebrow" style="color:#888;">{{ section.settings.press_eyebrow | default: 'Press & Media' }}</span>
      <h3 class="serif-font section-speaker__academy-title">{{ section.settings.press_title | default: 'As Seen In' }}</h3>
      <div class="divider"></div>
      <p class="body-copy" style="max-width:100%;">{{ section.settings.press_description | default: 'Nancy Vuu has been featured in leading publications, film festivals, and media outlets worldwide.' }}</p>
      <a href="{{ section.settings.press_link | default: '#' }}" class="btn-editorial">{{ section.settings.press_cta | default: 'View Press' }}</a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Speaker & Press",
  "max_blocks": 10,
  "settings": [
    { "type": "text",         "id": "section_id",          "label": "Section anchor ID",      "default": "speaker" },
    { "type": "image_picker", "id": "portrait",            "label": "Portrait image" },
    { "type": "text",         "id": "eyebrow",             "label": "Eyebrow text",           "default": "The Founder" },
    { "type": "richtext",     "id": "bio",                 "label": "Bio paragraph" },
    { "type": "header",       "content": "Press" },
    { "type": "text",         "id": "press_id",          "label": "Press anchor ID",      "default": "press" },
    { "type": "text",         "id": "press_eyebrow",     "label": "Press eyebrow",        "default": "Press & Media" },
    { "type": "text",         "id": "press_title",       "label": "Press title",          "default": "As Seen In" },
    { "type": "textarea",     "id": "press_description", "label": "Press description",    "default": "Nancy Vuu has been featured in leading publications, film festivals, and media outlets worldwide." },
    { "type": "text",         "id": "press_cta",         "label": "Press button text",    "default": "View Press" },
    { "type": "url",          "id": "press_link",        "label": "Press button link" }
  ],
  "blocks": [
    {
      "type": "title_line",
      "name": "Title Line",
      "settings": [
        { "type": "text",     "id": "text",   "label": "Text",   "default": "Speaker." },
        { "type": "checkbox", "id": "italic", "label": "Italic", "default": false }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Book for Speaking" },
        { "type": "url",  "id": "url",   "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Speaker & Press",
      "blocks": [
        { "type": "title_line", "settings": { "text": "Speaker.", "italic": false } },
        { "type": "title_line", "settings": { "text": "Mentor.",  "italic": true } },
        { "type": "title_line", "settings": { "text": "Author.",  "italic": false } },
        { "type": "link", "settings": { "label": "Book for Speaking" } },
        { "type": "link", "settings": { "label": "Mentorship Program" } },
        { "type": "link", "settings": { "label": "Buy The Book" } }
      ]
    }
  ]
}
{% endschema %}
