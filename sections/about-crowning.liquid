{%- comment -%} About — The Crowning (dark cinematic section) {%- endcomment -%}

<section class="about-crowning" data-section-id="{{ section.id }}">
  {%- assign crowning_img_url = section.settings.image_url | strip -%}
  {%- if crowning_img_url != blank -%}
    <div class="about-crowning__bg">
      <img src="{{ crowning_img_url }}" class="about-crowning__bg-img" loading="lazy" alt="">
      <div class="about-crowning__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
  {%- elsif section.settings.image != blank -%}
    <div class="about-crowning__bg">
      {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'about-crowning__bg-img', loading: 'lazy', alt: '' }}
      <div class="about-crowning__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
  {%- else -%}
    <div class="about-crowning__bg about-crowning__bg--solid"></div>
  {%- endif -%}

  <div class="about-crowning__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow about-crowning__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="about-crowning__heading serif-font">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="about-crowning__body">
      {%- if section.settings.paragraph_1 != blank -%}
        <p>{{ section.settings.paragraph_1 }}</p>
      {%- endif -%}
      {%- if section.settings.paragraph_2 != blank -%}
        <p>{{ section.settings.paragraph_2 }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .about-crowning {
    position: relative;
    padding: 10rem 1.5rem;
    overflow: hidden;
    background: var(--ink);
    color: #fff;
  }
  .about-crowning__bg {
    position: absolute;
    inset: 0;
  }
  .about-crowning__bg--solid {
    background: var(--ink);
  }
  .about-crowning__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .about-crowning__overlay {
    position: absolute;
    inset: 0;
    background: #000;
  }
  .about-crowning__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .about-crowning__eyebrow {
    color: var(--gold);
    font-size: .625rem;
    letter-spacing: .6em;
  }
  .about-crowning__heading {
    font-size: clamp(3rem, 7vw, 5rem);
    font-style: italic;
    color: #fff;
    margin-bottom: 2.5rem;
  }
  .about-crowning__body {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .about-crowning__body p {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.9;
    color: #bbb;
  }
</style>

{% schema %}
{
  "name": "About — Crowning",
  "settings": [
    {
      "type": "text",
      "id": "image_url",
      "label": "Background Image URL",
      "info": "Paste a direct image URL (https://...). This takes priority over the image picker below."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image (Shopify Upload)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark Overlay",
      "min": 40, "max": 95, "step": 5, "default": 70, "unit": "%"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "The Threshold"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Crowning"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "The Crowning is the moment the garment and the soul align. It is a sacred threshold where you stop seeing the fabric and start seeing your Appointment."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "As the final adjustment is made, there is a shift in the room. It is the moment you accept the mantle you were born to carry."
    }
  ],
  "presets": [
    {
      "name": "About — Crowning"
    }
  ]
}
{% endschema %}
