{%- comment -%} Dream Academy — two-column split: left text + CTA, right image, light background {%- endcomment -%}
<section class="atelier-academy" data-section-id="{{ section.id }}">
  <div class="atelier-academy__inner">

    <div class="atelier-academy__text reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow atelier-academy__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="atelier-academy__title serif-font">
        {%- if section.settings.title_line_1 != blank -%}{{ section.settings.title_line_1 }}{%- endif -%}
        {%- if section.settings.title_line_2 != blank -%}<br>{{ section.settings.title_line_2 }}{%- endif -%}
      </h2>
      <div class="divider"></div>
      {%- if section.settings.body != blank -%}
        <p class="atelier-academy__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="atelier-academy__cta">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="atelier-academy__media reveal delay-100">
      {%- if section.settings.image != blank -%}
        {%- render 'image',
            image: section.settings.image,
            sizes: '(max-width:768px) 100vw, 50vw',
            placeholder_text: 'Dream Academy'
        -%}
      {%- else -%}
        <div class="atelier-academy__img-placeholder"></div>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Atelier Academy Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right column image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Future of Craft"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title — Line 1",
      "default": "The Dream Academy"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title — Line 2",
      "default": "Conservatory."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "The Master Atelier is designed to be more than a house of commerce; it is an incubator for human potential. As part of our humanitarian mandate, this physical space serves as the future training ground for The Dream Academy—teaching marginalized communities the lost, highly-valued trade of garment construction, empowering them to weave their own destinies."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Inquire about The Academy"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Atelier Academy Banner",
      "settings": {
        "eyebrow": "The Future of Craft",
        "title_line_1": "The Dream Academy",
        "title_line_2": "Conservatory.",
        "cta_label": "Inquire about The Academy"
      }
    }
  ]
}
{% endschema %}
