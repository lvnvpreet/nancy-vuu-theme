{% comment %} sections/crowns.liquid — "The Crowning" full-screen dark feature section {% endcomment %}

<section id="crowns" class="crowns-section" data-dark>

  <div class="crowns-section__bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 2000 }}"
        srcset="{{ section.settings.bg_image | image_url: width: 800 }} 800w,
                {{ section.settings.bg_image | image_url: width: 1400 }} 1400w,
                {{ section.settings.bg_image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt="{{ section.settings.bg_image.alt | default: 'The Crowning' | escape }}"
        loading="lazy"
        class="crowns-section__img">
    {%- else -%}
      <div class="img-placeholder dark" style="width:100%;height:100%;">
        <span>{{ section.settings.placeholder_label | default: 'Macro Shot: Diamonds / Gold — Upload in Theme Editor' }}</span>
      </div>
    {%- endif -%}
  </div>

  <div class="crowns-section__overlay" style="background:rgba(0,0,0,{{ section.settings.overlay_opacity | default: 60 | divided_by: 100.0 }});"></div>

  <div class="crowns-section__content reveal">
    <span class="eyebrow crowns-section__eyebrow">
      {{- section.settings.eyebrow | default: 'Jewelry & Headpieces' -}}
    </span>
    <h2 class="serif-font crowns-section__title">
      {{- section.settings.title | default: 'The Crowning' -}}
    </h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="crowns-section__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <a href="{{ section.settings.cta_link | default: '/collections/crowns-jewelry' }}"
       class="btn-editorial on-dark crowns-section__cta">
      {{- section.settings.cta_label | default: 'Adorn Yourself' -}}
    </a>
  </div>

</section>

{% schema %}
{
  "name": "The Crowning",
  "settings": [
    { "type": "image_picker", "id": "bg_image",          "label": "Background image",        "info": "Best: macro shot of diamonds, gold, or crown." },
    { "type": "text",         "id": "placeholder_label", "label": "Placeholder text",         "default": "Macro Shot: Diamonds / Gold" },
    { "type": "range",        "id": "overlay_opacity",   "label": "Dark overlay",             "min": 20, "max": 85, "step": 5, "default": 60, "unit": "%" },
    { "type": "text",         "id": "eyebrow",           "label": "Eyebrow",                  "default": "Jewelry & Headpieces" },
    { "type": "text",         "id": "title",             "label": "Title",                    "default": "The Crowning" },
    { "type": "text",         "id": "subtitle",          "label": "Subtitle (optional)" },
    { "type": "text",         "id": "cta_label",         "label": "Button text",              "default": "Adorn Yourself" },
    { "type": "url",          "id": "cta_link",          "label": "Button link" }
  ],
  "presets": [{ "name": "The Crowning", "settings": { "eyebrow": "Jewelry & Headpieces", "title": "The Crowning", "cta_label": "Adorn Yourself" } }]
}
{% endschema %}
