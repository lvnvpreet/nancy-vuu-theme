{%- comment -%} Press Page — Accolades: 3-column grid of border-left award cards {%- endcomment -%}
<section id="accolades" class="press-accolades" data-section-id="{{ section.id }}">
  <div class="press-accolades__inner">

    <div class="press-accolades__header reveal">
      <span class="press-gold-label">{{ section.settings.eyebrow | default: 'Distinction & Impact' }}</span>
      <h2 class="press-accolades__title serif-font">{{ section.settings.heading | default: 'Global Accolades' }}</h2>
    </div>

    <div class="press-accolades__grid reveal">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <div class="press-accolade-card" {{ block.shopify_attributes }}>
            <span class="press-gold-label press-accolade-card__label">{{ block.settings.label }}</span>
            <h3 class="press-accolade-card__title serif-font">{{ block.settings.title }}</h3>
            <p class="press-accolade-card__body">{{ block.settings.body }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Press — Accolades",
  "class": "press-section-accolades",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow",  "default": "Distinction & Impact" },
    { "type": "text", "id": "heading", "label": "Heading",  "default": "Global Accolades" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Accolade Card",
      "settings": [
        { "type": "text",     "id": "label", "label": "Gold Label",  "default": "Cinematic Excellence" },
        { "type": "text",     "id": "title", "label": "Card Title",  "default": "\"Unto Me\" Film Honors" },
        { "type": "richtext", "id": "body",  "label": "Description", "default": "<p>Recipient of 4 prestigious film awards, highlighted by <strong>Best Short Fashion Film</strong> at the Global Short Film Awards in Cannes, alongside three domestic honors for creative excellence.</p>" }
      ]
    }
  ],
  "presets": [
