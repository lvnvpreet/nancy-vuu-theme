{%- comment -%}
  Grid of numbered detail cards for events/expos.
{%- endcomment -%}

<section class="expo-details{% if section.settings.bg_tint %} expo-details--tinted{% endif %}" data-section-id="{{ section.id }}">
  <div class="expo-details__inner reveal">
    {%- if section.settings.heading != blank -%}
      <h2 class="expo-details__title serif"><em>{{ section.settings.heading }}</em></h2>
    {%- endif -%}

    <div class="expo-details__grid">
      {%- for block in section.blocks -%}
        <div class="expo-detail-card" {{ block.shopify_attributes }}>
          <span class="expo-detail-card__num serif"><em>{{ block.settings.number }}</em></span>
          <h3 class="expo-detail-card__heading">{{ block.settings.heading }}</h3>
          <p class="expo-detail-card__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Expo Details",
  "class": "expo-section-details",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Key Event Details"
    },
    {
      "type": "checkbox",
      "id": "bg_tint",
      "label": "Light background tint",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail Card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Date"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Friday, April 24, 2026\nStarting at 12 PM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expo Details",
      "blocks": [
        { "type": "detail", "settings": { "number": "01", "heading": "Date", "text": "Friday, April 24, 2026\nStarting at 12 PM" } },
        { "type": "detail", "settings": { "number": "02", "heading": "Location", "text": "South Pacific Ballroom\nHilton Hawaiian Village\nHonolulu, Hawaiʻi" } },
        { "type": "detail", "settings": { "number": "03", "heading": "Audience", "text": "Open to public — nonprofits, students, business leaders, creatives & media professionals" } },
        { "type": "detail", "settings": { "number": "04", "heading": "Goal", "text": "Ignite dreams, foster connections & provide resources for transformative growth" } }
      ]
    }
  ]
}
{% endschema %}
