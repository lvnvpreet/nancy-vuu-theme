{%- comment -%} Audience Modal — 2-column overlay (image + form) for retreats / bridal {%- endcomment -%}
<style>
  /* ── NV Alignment Application Modal ────────────────────── */

  /* Remove outer modal padding so inner fills edge-to-edge */
  #audience-modal {
    padding: 0;
  }

  .nv-align-inner {
    width: 100%;
    align-self: stretch;
    background: #1a1a1a;
    position: relative;
    overflow-y: auto;
    padding: 5rem 1.5rem 4rem;
  }

  .nv-align-box {
    max-width: 860px;
    margin: 0 auto;
    background: #111111;
    padding: 3rem 4rem;
  }

  /* Close button — visible on dark background */
  #audience-modal .audience-modal__close {
    color: rgba(255, 255, 255, 0.45);
  }
  #audience-modal .audience-modal__close:hover {
    color: #c5a059;
  }

  /* Form fields */
  .nv-align-input,
  .nv-align-select,
  .nv-align-textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(196, 160, 89, 0.3);
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 1rem 0;
    width: 100%;
    outline: none;
    letter-spacing: 0.1em;
    transition: border-color 0.3s ease;
    display: block;
  }

  .nv-align-select {
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    background-color: transparent;
  }

  .nv-align-select option {
    background: #1a1a1a;
    color: #ffffff;
  }

  .nv-align-textarea {
    resize: none;
  }

  .nv-align-input:focus,
  .nv-align-select:focus,
  .nv-align-textarea:focus {
    border-bottom-color: #c5a059;
  }

  .nv-align-input::placeholder,
  .nv-align-textarea::placeholder {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
  }

  /* Phase field labels */
  .nv-align-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    display: block;
    margin-bottom: 1rem;
  }

  /* Checkbox and radio option labels */
  .nv-align-check-label,
  .nv-align-radio-label {
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 0.75rem;
    cursor: pointer;
  }

  /* Submit button */
  .nv-align-submit {
    background: #c5a059;
    color: #111111;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    padding: 1.5rem 3.5rem;
    border: none;
    cursor: pointer;
    display: block;
    margin: 0 auto;
    width: 100%;
    transition: background 0.4s ease, opacity 0.4s ease;
  }

  .nv-align-submit:hover {
    background: rgba(196, 160, 89, 0.8);
  }

  /* Success message */
  .nv-align-success {
    background: rgba(196, 160, 89, 0.06);
    border: 1px solid rgba(196, 160, 89, 0.3);
    padding: 2.5rem;
    text-align: center;
    color: #c5a059;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    line-height: 2;
  }
</style>

<div class="audience-modal" id="audience-modal" aria-hidden="true" aria-modal="true" role="dialog">
  <div class="nv-align-inner">

    <button class="audience-modal__close" data-audience-close aria-label="Close">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <div class="nv-align-box">

      <!-- HEADER -->
      <div style="text-align:center;">
        <div style="width:10px;height:10px;background:#c5a059;border-radius:50%;margin:0 auto 1.5rem;"></div>
        <h2 style="font-family:var(--font-sans);font-size:0.65rem;letter-spacing:0.5em;text-transform:uppercase;color:#c5a059;margin-bottom:0.5rem;">APPLICATION FOR ALIGNMENT</h2>
        <h3 style="font-family:var(--font-sans);font-size:0.55rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:2rem;">INITIATING YOUR STRATEGIC RESET.</h3>
        <p style="font-family:var(--font-sans);font-size:0.8rem;color:rgba(255,255,255,0.7);line-height:1.9;max-width:640px;margin:0 auto 3rem;text-align:center;">Thank you for seeking to don your Mantle of Authority. This is not a request for generic inspiration; it is an application for a Selective Alignment Audit. We are identifying the bedrock of your profound purpose to determine mutual resonance with The Nancy Vuu Blueprint of Honor. To protect your high-status investment and maintain extreme scarcity, please answer with absolute transparency.</p>
      </div>

      <!-- FORM -->
      {%- form 'contact', id: 'nv-alignment-form' -%}
        <input type="hidden" name="contact[tags]" value="alignment-application">

        {%- if form.posted_successfully? -%}

          <div class="nv-align-success">
            Your Application for Alignment has been received. Our team will conduct your Selective Alignment Audit and contact you within 48 hours.
          </div>

        {%- else -%}

          <!-- PHASE I — STRATEGIC ALIGNMENT -->
          <p style="font-family:var(--font-sans);font-size:0.5rem;letter-spacing:0.5em;text-transform:uppercase;color:#c5a059;margin-bottom:2rem;">PHASE I — STRATEGIC ALIGNMENT</p>

          <!-- Q1: Primary Objective -->
          <div style="margin-bottom:2rem;">
            <label class="nv-align-label">1. Primary Objective for this Immersion?</label>
            <label class="nv-align-check-label">
              <input type="checkbox" name="contact[objective]" value="Silence Echo - Phase I"> Silence the &#8220;Echo&#8221; &amp; Reclaim Vision. (Phase I)
            </label>
            <label class="nv-align-check-label">
              <input type="checkbox" name="contact[objective]" value="Build Authority - Phase II"> Architect my Visible Authority &amp; Build my Legacy. (Phase II)
            </label>
            <label class="nv-align-check-label">
              <input type="checkbox" name="contact[objective]" value="Sovereign Couples"> Forge a Sovereign Legacy Alliance (Couple).
            </label>
          </div>

          <!-- Q2: Leadership Frequency -->
          <div style="margin-bottom:2rem;">
            <label class="nv-align-label">2. Your Current Leadership Frequency?</label>
            <select name="contact[leadership_frequency]" class="nv-align-select">
              <option value="" disabled selected style="color:rgba(255,255,255,0.35);">Select Your Alignment</option>
              <option value="Invisible Giant">Successful but Unseen. (Invisible Giant)</option>
              <option value="The Echo">Reactive &amp; Stuck. (The Echo)</option>
              <option value="Fragmented Strategist">Strategic but Fragmented.</option>
            </select>
          </div>

          <!-- Q3: Single Barrier -->
          <div style="margin-bottom:2rem;">
            <label class="nv-align-label">3. The Single Barrier to your Sovereignty?</label>
            <textarea name="contact[single_barrier]" class="nv-align-textarea" placeholder="Describe in 250 characters or less..." maxlength="250" rows="2"></textarea>
          </div>

          <!-- Q4: Implementation Fund -->
          <div style="margin-bottom:2rem;">
            <label class="nv-align-label">4. Anticipated Implementation Fund?</label>
            <label class="nv-align-radio-label">
              <input type="radio" name="contact[implementation_fund]" value="25k-50k"> {{ section.settings.price_tier_1 }}
            </label>
            <label class="nv-align-radio-label">
              <input type="radio" name="contact[implementation_fund]" value="50k-75k"> {{ section.settings.price_tier_2 }}
            </label>
            <label class="nv-align-radio-label">
              <input type="radio" name="contact[implementation_fund]" value="75k-100k+"> {{ section.settings.price_tier_3 }}
            </label>
          </div>

          <!-- Q5: True Appointment -->
          <div style="margin-bottom:2rem;">
            <label class="nv-align-label">5. Describe your True Appointment in one word.</label>
            <input type="text" name="contact[true_appointment]" class="nv-align-input" placeholder="VISIONARY. REDEEMED. SOVEREIGN..." maxlength="50">
          </div>

          <!-- Divider -->
          <div style="width:40px;height:1px;background:rgba(196,160,89,0.3);margin:2.5rem auto;"></div>

          <!-- PHASE II — EXECUTIVE PROFILE -->
          <p style="font-family:var(--font-sans);font-size:0.5rem;letter-spacing:0.5em;text-transform:uppercase;color:#c5a059;margin-bottom:2rem;">PHASE II — EXECUTIVE PROFILE</p>

          <div style="margin-bottom:2rem;">
            <input type="text" name="contact[name]" class="nv-align-input" placeholder="FULL NAME" required>
          </div>
          <div style="margin-bottom:2rem;">
            <input type="text" name="contact[organization]" class="nv-align-input" placeholder="TITLE / ORGANIZATION">
          </div>
          <div style="margin-bottom:2rem;">
            <input type="text" name="contact[industry]" class="nv-align-input" placeholder="GLOBAL FIELD (INDUSTRY)">
          </div>
          <div style="margin-bottom:2rem;">
            <input type="email" name="contact[email]" class="nv-align-input" placeholder="WORK EMAIL ADDRESS" required>
          </div>
          <div style="margin-bottom:2rem;">
            {%- render 'phone-field' -%}
          </div>

          <!-- Divider -->
          <div style="width:40px;height:1px;background:rgba(196,160,89,0.3);margin:2.5rem auto;"></div>

          <!-- PHASE III — ALIGNMENT DECLARATION -->
          <p style="font-family:var(--font-sans);font-size:0.5rem;letter-spacing:0.5em;text-transform:uppercase;color:#c5a059;margin-bottom:2rem;">PHASE III — ALIGNMENT DECLARATION</p>

          <div style="background:rgba(196,160,89,0.04);border:1px solid rgba(196,160,89,0.25);padding:2rem;margin-bottom:2.5rem;">
            <label for="nv-legal-agree" style="display:flex;align-items:flex-start;">
              <input type="checkbox" id="nv-legal-agree" name="contact[legal_agreement]" required style="margin-right:1rem;margin-top:3px;flex-shrink:0;">
              <span style="font-family:var(--font-sans);font-size:0.7rem;color:rgba(255,255,255,0.65);line-height:1.85;letter-spacing:0.04em;">By submitting this application, I acknowledge that the Nancy Vuu Immersions are high-level strategic consultations and mentorship programs. I explicitly understand that Nancy Vuu is not a licensed attorney, marriage counselor, psychologist, therapist, or medical professional, and that these intensives are not a substitute for clinical therapy, legal advice, or professional counseling. I am prepared to explore the ruthless deconstruction of my leadership narrative in pursuit of Sovereign Distinction. My submission confirms my Selective Alignment for this process.</span>
            </label>
          </div>

          <button type="submit" class="nv-align-submit">INITIATE ALIGNMENT AUDIT</button>

        {%- endif -%}
      {%- endform -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Alignment Application Modal",
  "settings": [
    {
      "type": "header",
      "content": "Investment Tiers (Editable)"
    },
    {
      "type": "text",
      "id": "price_tier_1",
      "label": "Investment Tier 1",
      "default": "$25,000 \u2013 $50,000"
    },
    {
      "type": "text",
      "id": "price_tier_2",
      "label": "Investment Tier 2",
      "default": "$50,000 \u2013 $75,000"
    },
    {
      "type": "text",
      "id": "price_tier_3",
      "label": "Investment Tier 3",
      "default": "$75,000 \u2013 $100,000+"
    }
  ],
  "blocks": []
}
{% endschema %}

