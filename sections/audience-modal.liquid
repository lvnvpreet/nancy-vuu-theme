{%- comment -%} Audience Modal — Shopify contact form overlay for bridal / retreats {%- endcomment -%}
<div class="audience-modal" id="audience-modal" aria-hidden="true" aria-modal="true" role="dialog">
  <div class="audience-modal__overlay" data-audience-close></div>
  <div class="audience-modal__panel">
    <button class="audience-modal__close" data-audience-close aria-label="Close">&times;</button>
    <div class="audience-modal__header">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="audience-modal__title serif-font">{{ section.settings.title | default: "Begin Your Journey" }}</h2>
      {% if section.settings.description != blank %}
        <p class="body-copy">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    {%- form 'contact', id: 'audience-form' -%}
      <input type="hidden" name="contact[tags]" value="{{ section.settings.form_tag | default: 'audience-inquiry' }}">

      <div class="audience-modal__field">
        <label for="audience-name">{{ 'general.form.name' | t | default: 'Name' }}</label>
        <input type="text" id="audience-name" name="contact[name]" placeholder="Full Name" required>
      </div>

      <div class="audience-modal__field">
        <label for="audience-email">{{ 'general.form.email' | t | default: 'Email' }}</label>
        <input type="email" id="audience-email" name="contact[email]" placeholder="Email Address" required>
      </div>

      {% if section.settings.show_dropdown %}
        <div class="audience-modal__field">
          <label for="audience-category">{{ section.settings.dropdown_label | default: 'Category' }}</label>
          <select id="audience-category" name="contact[category]">
            <option value="">Select…</option>
            {% for block in section.blocks %}
              {% if block.type == 'dropdown_option' %}
                <option value="{{ block.settings.value }}">{{ block.settings.label }}</option>
              {% endif %}
            {% endfor %}
          </select>
        </div>
      {% endif %}

      {% if section.settings.show_date %}
        <div class="audience-modal__field">
          <label for="audience-date">{{ section.settings.date_label | default: 'Preferred Date' }}</label>
          <input type="text" id="audience-date" name="contact[date]" placeholder="e.g. Spring 2026">
        </div>
      {% endif %}

      {% if section.settings.show_textarea %}
        <div class="audience-modal__field">
          <label for="audience-vision">{{ section.settings.textarea_label | default: 'Your Vision' }}</label>
          <textarea id="audience-vision" name="contact[body]" rows="4" placeholder="{{ section.settings.textarea_placeholder | default: 'Tell us about your vision…' }}"></textarea>
        </div>
      {% endif %}

      <button type="submit" class="btn-editorial btn-editorial--full">{{ section.settings.submit_label | default: 'Submit' }}</button>
    {%- endform -%}

    <div class="audience-modal__success" style="display:none;">
      <h3 class="serif-font">{{ section.settings.success_title | default: "Thank You" }}</h3>
      <p class="body-copy">{{ section.settings.success_message | default: "We'll be in touch within 48 hours." }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Audience Modal",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "eyebrow",               "label": "Eyebrow" },
    { "type": "text",     "id": "title",                  "label": "Modal Title",          "default": "Begin Your Journey" },
    { "type": "textarea", "id": "description",            "label": "Description" },
    { "type": "text",     "id": "form_tag",               "label": "Form Tag",             "default": "audience-inquiry" },
    { "type": "checkbox", "id": "show_dropdown",          "label": "Show Dropdown Field",  "default": true },
    { "type": "text",     "id": "dropdown_label",         "label": "Dropdown Label",       "default": "Category" },
    { "type": "checkbox", "id": "show_date",              "label": "Show Date Field",      "default": true },
    { "type": "text",     "id": "date_label",             "label": "Date Label",           "default": "Preferred Date" },
    { "type": "checkbox", "id": "show_textarea",          "label": "Show Textarea",        "default": true },
    { "type": "text",     "id": "textarea_label",         "label": "Textarea Label",       "default": "Your Vision" },
    { "type": "text",     "id": "textarea_placeholder",   "label": "Textarea Placeholder", "default": "Tell us about your vision…" },
    { "type": "text",     "id": "submit_label",           "label": "Submit Button Text",   "default": "Submit Inquiry" },
    { "type": "text",     "id": "success_title",          "label": "Success Title",        "default": "Thank You" },
    { "type": "text",     "id": "success_message",        "label": "Success Message",      "default": "We'll be in touch within 48 hours." }
  ],
  "blocks": [
    {
      "type": "dropdown_option",
      "name": "Dropdown Option",
      "settings": [
        { "type": "text", "id": "label", "label": "Option Label" },
        { "type": "text", "id": "value", "label": "Option Value" }
      ]
    }
  ]
}
{% endschema %}
