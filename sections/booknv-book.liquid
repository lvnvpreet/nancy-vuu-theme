{%- comment -%} BookNV Mentorship — two-column, image+floating quote left, text+checklist right, stone-100 bg {%- endcomment -%}
<section id="mentorship" class="booknv-mentorship" data-section-id="{{ section.id }}">
  <div class="booknv-mentorship__inner">

    <div class="booknv-mentorship__media order-2 reveal">
      <div class="booknv-mentorship__img-wrap">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1000 }} 1000w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: 'The Mentorship Process' }}"
            class="booknv-mentorship__img"
            loading="lazy">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'booknv-mentorship__img placeholder' }}
        {%- endif -%}
      </div>
      {%- if section.settings.float_quote != blank -%}
        <div class="booknv-mentorship__float-quote">
          <p class="serif-font">{{ section.settings.float_quote }}</p>
        </div>
      {%- endif -%}
    </div>

    <div class="booknv-mentorship__text order-1 reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow booknv-mentorship__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="booknv-mentorship__title serif-font">
        {{ section.settings.title_line_1 }}<br>
        <em class="booknv-mentorship__title-italic">{{ section.settings.title_italic }}</em>
      </h2>
      {%- if section.settings.body != blank -%}
        <p class="booknv-mentorship__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <ul class="booknv-mentorship__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'point' -%}
              <li class="booknv-mentorship__list-item" {{ block.shopify_attributes }}>
                <span class="booknv-mentorship__check">&#10003;</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#booking' }}" class="booknv-mentorship__cta">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "BookNV Mentorship",
  "class": "booknv-section-mentorship",
  "settings": [
    { "type": "image_picker", "id": "image",        "label": "Image" },
    { "type": "textarea",     "id": "float_quote",  "label": "Floating Quote",          "default": "\"Legacy is not what you leave, but who you lead.\"" },
    { "type": "text",         "id": "eyebrow",      "label": "Eyebrow",                 "default": "Exclusive Access" },
    { "type": "text",         "id": "title_line_1", "label": "Heading — Line 1",        "default": "The Visionary" },
    { "type": "text",         "id": "title_italic", "label": "Heading — Italic Line 2", "default": "Mentorship Circle." },
    { "type": "textarea",     "id": "body",         "label": "Body Text",               "default": "Direct proximity to the creative mind behind the global Nancy Vuu brand. This is a bespoke advisory partnership designed for emerging visionaries, C-suite executives, and creative leaders seeking to architect their own legacy of honor and excellence." },
    { "type": "text",         "id": "cta_label",    "label": "CTA Label",               "default": "Inquire for Mentorship" },
    { "type": "url",          "id": "cta_link",     "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "List Point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Brand Identity & Narrative Architecture" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BookNV Mentorship",
      "blocks": [
        { "type": "point", "settings": { "text": "Brand Identity & Narrative Architecture" } },
        { "type": "point", "settings": { "text": "Executive Creative Direction Advisory" } },
        { "type": "point", "settings": { "text": "Humanitarian Impact Strategy" } }
      ]
    }
  ]
}
{% endschema %}
