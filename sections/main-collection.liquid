{% comment %} sections/main-collection.liquid {% endcomment %}

<section class="collection-page">
  <div class="collection-page__header">
    {%- if collection.image -%}
      <div class="collection-hero">
        <img src="{{ collection.image | image_url: width: 2000 }}" alt="{{ collection.image.alt | default: collection.title | escape }}" loading="eager" class="collection-hero__img">
        <div class="collection-hero__overlay"></div>
        <div class="collection-hero__content">
          <h1 class="serif-font collection-hero__title">{{ collection.title }}</h1>
        </div>
      </div>
    {%- else -%}
      <div class="collection-header-text">
        <span class="eyebrow">{{ collection.products_count }} {{ 'collection.products_count' | t: default: 'pieces' }}</span>
        <h1 class="serif-font collection-title">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p class="body-copy collection-description">{{ collection.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- paginate collection.products by section.settings.products_per_page -%}

    {%- if section.settings.group_by_type and collection.products.size > 0 -%}
      {%- comment -%} Build a deduplicated list of product types {%- endcomment -%}
      {%- assign all_types = '' -%}
      {%- for product in collection.products -%}
        {%- if product.type != blank -%}
          {%- assign all_types = all_types | append: product.type | append: '|' -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign types_array = all_types | split: '|' | uniq -%}

      {%- comment -%} If no product has a type (all blank), fall back to flat grid {%- endcomment -%}
      {%- if types_array.size > 0 -%}
        {%- for type in types_array -%}
          {%- if type != blank -%}
            <div class="collection-group" id="group-{{ type | handle }}">
              <h2 class="collection-group__heading serif-font">{{ type }}</h2>
              <div class="product-grid">
                {%- for product in collection.products -%}
                  {%- if product.type == type -%}
                    {%- render 'product-card', product: product, lazy_load: true -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Products with no type — show in a fallback group {%- endcomment -%}
        {%- assign has_untyped = false -%}
        {%- for product in collection.products -%}
          {%- if product.type == blank -%}{%- assign has_untyped = true -%}{%- endif -%}
        {%- endfor -%}
        {%- if has_untyped -%}
          <div class="collection-group" id="group-other">
            <h2 class="collection-group__heading serif-font">Other</h2>
            <div class="product-grid">
              {%- for product in collection.products -%}
                {%- if product.type == blank -%}
                  {%- render 'product-card', product: product, lazy_load: true -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="product-grid" id="product-grid">
          {%- for product in collection.products -%}
            {%- render 'product-card', product: product, lazy_load: true -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="product-grid" id="product-grid">
        {%- for product in collection.products -%}
          {%- render 'product-card', product: product, lazy_load: true -%}
        {%- else -%}
          <div class="collection-empty">
            <p class="body-copy">{{ 'collection.empty' | t: default: 'No products found in this collection.' }}</p>
            <a href="/collections/all" class="btn-editorial">{{ 'collection.shop_all' | t: default: 'Shop All' }}</a>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- render 'pagination', paginate: paginate -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8, "max": 48, "step": 4, "default": 24
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Grid columns (desktop)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "checkbox",
      "id": "group_by_type",
      "label": "Group products by collection name (Product Type)",
      "info": "Groups products under headings based on their Product Type field set in Shopify Admin. Requires products to have a Product Type assigned.",
      "default": false
    }
  ]
}
{% endschema %}
