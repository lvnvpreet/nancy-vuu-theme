{%- comment -%} BookNV Accolades Marquee — infinite scrolling ticker with press/accolade names {%- endcomment -%}
<div class="booknv-marquee" data-section-id="{{ section.id }}">
  <div class="booknv-marquee__track">
    <div class="booknv-marquee__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <span class="booknv-marquee__item serif-font" {{ block.shopify_attributes }}>{{ block.settings.name }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="booknv-marquee__inner" aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <span class="booknv-marquee__item serif-font">{{ block.settings.name }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "BookNV Accolades Marquee",
  "class": "booknv-section-press",
  "blocks": [
    {
      "type": "item",
      "name": "Accolade",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Vogue Italia" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BookNV Accolades Marquee",
      "blocks": [
        { "type": "item", "settings": { "name": "Vogue Italia" } },
        { "type": "item", "settings": { "name": "NYFW" } },
        { "type": "item", "settings": { "name": "Elle Magazine" } },
        { "type": "item", "settings": { "name": "Cannes Film Festival" } },
        { "type": "item", "settings": { "name": "Big Ben Award" } },
        { "type": "item", "settings": { "name": "Harper's Bazaar" } }
      ]
    }
  ]
}
{% endschema %}
