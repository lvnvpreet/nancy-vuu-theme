{%- comment -%} About — Letter from Nancy {%- endcomment -%}

<section class="about-letter section-padding bg-white" data-section-id="{{ section.id }}">
  <div class="about-letter__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow about-letter__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="about-letter__heading serif-font">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="about-letter__body body-copy">
      {%- if section.settings.paragraph_1 != blank -%}
        <p>{{ section.settings.paragraph_1 }}</p>
      {%- endif -%}
      {%- if section.settings.paragraph_2 != blank -%}
        <p>{{ section.settings.paragraph_2 }}</p>
      {%- endif -%}
      {%- if section.settings.pullquote != blank -%}
        <blockquote class="about-letter__pullquote serif-font">{{ section.settings.pullquote }}</blockquote>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .about-letter {
    padding: 8rem 1.5rem;
  }
  .bg-white {
    background: #fff;
  }
  .about-letter__inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .about-letter__eyebrow {
    color: var(--gold);
    font-size: .625rem;
    letter-spacing: .6em;
  }
  .about-letter__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    margin-bottom: 3rem;
    line-height: 1.15;
  }
  .about-letter__body p {
    font-size: 1.15rem;
    font-weight: 300;
    color: #4a4a4a;
    line-height: 1.9;
    margin-bottom: 2rem;
  }
  .about-letter__pullquote {
    font-size: 1.4rem;
    font-style: italic;
    color: var(--ink);
    padding: 1.5rem 0;
    margin: 0 0 2rem;
    border: none;
  }
</style>

{% schema %}
{
  "name": "About — Letter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Historical Context"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Letter from Nancy"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "In 1979, the story of Nancy Vuu did not begin in a studio; it began on the open sea. I was a one-year-old baby, carried into the unknown by parents who possessed the rarest kind of wealth: the courage to dream."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Leaving the shores of Vietnam as refugees, they sacrificed their lineage to secure my freedom. They traded the only world they knew for a promise they couldn't see—so that forty-four years later, I could return with a dream."
    },
    {
      "type": "text",
      "id": "pullquote",
      "label": "Pull Quote",
      "default": "\"This is the foundation of our house.\""
    }
  ],
  "presets": [
    {
      "name": "About — Letter"
    }
  ]
}
{% endschema %}
