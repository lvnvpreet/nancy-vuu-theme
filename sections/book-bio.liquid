{%- comment -%} Book author bio — dark bg, portrait image left, bio text right {%- endcomment -%}
<section class="book-bio" data-section-id="{{ section.id }}">
  <div class="book-bio__inner">
    <div class="book-bio__portrait">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                  {{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 800 }} 800w"
          sizes="(max-width: 900px) 100vw, 40vw"
          alt="{{ section.settings.image.alt | default: 'Author Portrait' }}"
          class="book-bio__img"
          loading="lazy">
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'book-bio__img placeholder' }}
      {%- endif -%}
    </div>
    <div class="book-bio__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow book-bio__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="book-bio__title serif-font">
        {%- if section.settings.heading_1 != blank -%}{{ section.settings.heading_1 }}{%- endif -%}
        {%- if section.settings.heading_2 != blank -%}<br>{{ section.settings.heading_2 }}{%- endif -%}
      </h2>
      {%- if section.settings.intro != blank -%}
        <p class="book-bio__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
      {%- if section.settings.body_1 != blank -%}<p class="book-bio__body">{{ section.settings.body_1 }}</p>{%- endif -%}
      {%- if section.settings.body_2 != blank -%}<p class="book-bio__body">{{ section.settings.body_2 }}</p>{%- endif -%}
      {%- if section.settings.body_3 != blank -%}<p class="book-bio__body">{{ section.settings.body_3 }}</p>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Book Author Bio",
  "class": "book-section-bio",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Author Portrait"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About the Author"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading — Line 1",
      "default": "The Identity"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading — Line 2",
      "default": "Architect."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro (bold, white)",
      "default": "Nancy Vuu is a multi-hyphenate visionary—a Creative Director, Philanthropist, and Global Advisor."
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Body Paragraph 1",
      "default": "Her work transcends the traditional boundaries of fashion. Recognized by Vogue, Harper's Bazaar, and Elle, Nancy is trusted with styling the world's most visible figures, from NBA and NFL elite to global Royalty and dignitaries."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Body Paragraph 2",
      "default": "Yet, her most profound work happens off the runway. As the founder of the House of Vuu Foundation, she utilizes her global platform to combat human trafficking and empower marginalized communities through the Dream Academy."
    },
    {
      "type": "textarea",
      "id": "body_3",
      "label": "Body Paragraph 3",
      "default": "Nancy does not just create garments; she restores human dignity. She is a sought-after speaker, advisor, and mentor, teaching leaders worldwide how to dress their purpose in grace and architect a legacy of lasting impact."
    }
  ],
  "presets": [
    {
      "name": "Book Author Bio",
      "settings": {
        "eyebrow": "About the Author",
        "heading_1": "The Identity",
        "heading_2": "Architect.",
        "intro": "Nancy Vuu is a multi-hyphenate visionary—a Creative Director, Philanthropist, and Global Advisor.",
        "body_1": "Her work transcends the traditional boundaries of fashion. Recognized by Vogue, Harper's Bazaar, and Elle, Nancy is trusted with styling the world's most visible figures, from NBA and NFL elite to global Royalty and dignitaries.",
        "body_2": "Yet, her most profound work happens off the runway. As the founder of the House of Vuu Foundation, she utilizes her global platform to combat human trafficking and empower marginalized communities through the Dream Academy.",
        "body_3": "Nancy does not just create garments; she restores human dignity. She is a sought-after speaker, advisor, and mentor, teaching leaders worldwide how to dress their purpose in grace and architect a legacy of lasting impact."
      }
    }
  ]
}
{% endschema %}
