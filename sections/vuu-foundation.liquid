{% comment %} sections/vuu-foundation.liquid {% endcomment %}
<style>
  .foundation-section {
    background: #111111;
    color: #ffffff;
    padding: 100px 5% 80px;
  }
  .foundation-section .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
  }
  .foundation-section .footer-foundation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding-bottom: 80px;
    border-bottom: 1px solid #222;
  }
  .foundation-section .footer-foundation__text .eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #555 !important;
    display: block;
    margin-bottom: 20px;
  }
  .foundation-section .footer-title {
    font-family: 'Bodoni Moda', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 24px 0;
    line-height: 1.1;
  }
  .foundation-section .divider {
    width: 40px;
    height: 1px;
    background: #333 !important;
    margin-bottom: 28px;
  }
  .foundation-section .body-copy {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    color: #aaa !important;
    margin-bottom: 40px;
    font-weight: 300;
  }
  .foundation-section .btn-editorial.on-dark {
    display: inline-block;
    padding: 16px 32px;
    border: 1px solid #555;
    color: #ffffff;
    text-decoration: none;
    font-family: 'Manrope', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 700;
    transition: background 0.3s, color 0.3s;
  }
  .foundation-section .btn-editorial.on-dark:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }
  .foundation-section .footer-chart {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
    .foundation-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  .foundation-section .chart-legend {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .foundation-section .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .foundation-section .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }
  .foundation-section .legend-item .eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #555 !important;
    margin: 0 !important;
  }
  @media (max-width: 768px) {
    .foundation-section .footer-foundation { grid-template-columns: 1fr; gap: 60px; }
  }
</style>

<section id="foundation" class="foundation-section" data-dark>
  <div class="footer-inner">
    <div class="footer-foundation">
      <div class="footer-foundation__text reveal">
        <span class="eyebrow" style="color:#555;">{{ section.settings.eyebrow | default: 'Give Back' }}</span>
        <h2 class="serif-font footer-title">{{ section.settings.title | default: 'House of Vuu Foundation' }}</h2>
        <div class="divider" style="background:#333;"></div>
        <p class="body-copy" style="color:#aaa;">{{ section.settings.description | default: 'We exist to empower humanity. Our foundation supports global initiatives for the marginalized and the voiceless — one stitch, one life at a time.' }}</p>
        <a href="{{ section.settings.donate_link | default: '#' }}" class="btn-editorial on-dark">{{ section.settings.donate_label | default: 'Donate / Get Involved' }}</a>
      </div>
      <div class="footer-chart reveal delay-100">
        {%- if section.settings.foundation_image != blank -%}
          <img src="{{ section.settings.foundation_image | image_url: width: 800 }}" alt="Foundation image" class="foundation-img">
        {%- else -%}
          <div class="img-placeholder dark" style="width:100%;aspect-ratio:4/3;background:#222;display:flex;align-items:center;justify-content:center;color:#555;font-family:'Manrope',sans-serif;font-size:1rem;">No image selected</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vuu Foundation",
  "settings": [
    { "type": "text",     "id": "eyebrow",          "label": "Eyebrow",              "default": "Give Back" },
    { "type": "text",     "id": "title",             "label": "Foundation title",     "default": "House of Vuu Foundation" },
    { "type": "textarea", "id": "description",       "label": "Description" },
    { "type": "text",     "id": "donate_label",      "label": "Donate button text",   "default": "Donate / Get Involved" },
    { "type": "url",      "id": "donate_link",       "label": "Donate link" },
    { "type": "header",   "content": "Foundation Image" },
    { "type": "image_picker", "id": "foundation_image", "label": "Foundation image" },
    { "type": "header",   "content": "Social Links" },
    { "type": "url",      "id": "social_instagram",  "label": "Instagram URL" },
    { "type": "url",      "id": "social_linkedin",   "label": "LinkedIn URL" },
    { "type": "url",      "id": "social_pinterest",  "label": "Pinterest URL" }
  ]
}
{% endschema %}
