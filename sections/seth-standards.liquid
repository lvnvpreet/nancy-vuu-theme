{%- comment -%} Seth Eden — Sartorial Standards 3-card grid {%- endcomment -%}
<section class="seth-standards" data-section-id="{{ section.id }}">
  <div class="seth-standards__inner">
    {%- if section.settings.heading != blank -%}
      <div class="seth-standards__header reveal">
        <h2 class="seth-standards__title serif">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="seth-standards__grid">
      {%- for block in section.blocks -%}
        <div class="seth-standards__card reveal" style="transition-delay: {{ forloop.index0 | times: 150 }}ms;" {{ block.shopify_attributes }}>
          <div class="seth-standards__card-media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(min-width: 768px) 33vw, 100vw"
                alt="{{ block.settings.image.alt | default: block.settings.title }}"
                loading="lazy"
                class="seth-standards__card-img">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'seth-standards__card-img placeholder' }}
            {%- endif -%}
          </div>
          <div class="seth-standards__card-body">
            <h4 class="seth-standards__card-title serif">{{ block.settings.title }}</h4>
            {%- if block.settings.description != blank -%}
              <p class="seth-standards__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
            {%- if block.settings.footer_text != blank -%}
              <span class="seth-standards__card-footer">{{ block.settings.footer_text }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Seth Standards",
  "class": "seth-section-standards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Signature Seth Eden Suits"
    }
  ],
  "blocks": [
    {
      "type": "standard",
      "name": "Standard Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hand Stitched Construction"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "All Seth Eden Custom Suits are made with a hand stitched full-canvas construction and hand-stitched \"Milanese\" buttonholes."
        },
        {
          "type": "text",
          "id": "footer_text",
          "label": "Footer Label",
          "default": "Our Craftsmanship"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seth Standards",
      "blocks": [
        {
          "type": "standard",
          "settings": {
            "title": "Hand Stitched Construction",
            "description": "All Seth Eden Custom Suits are made with a hand stitched full-canvas construction and hand-stitched \"Milanese\" buttonholes.",
            "footer_text": "Our Craftsmanship"
          }
        },
        {
          "type": "standard",
          "settings": {
            "title": "Luxury Designer Fabrics",
            "description": "Select from Silicon Valley's largest trove of Designer Fabric Swatches including Ermenegildo Zegna, Loro Piana, Lanificio Cerruti, and Reda.",
            "footer_text": "Our Mills"
          }
        },
        {
          "type": "standard",
          "settings": {
            "title": "Designed for You",
            "description": "Select every last detail of your suit—from the lining to the stitching—and have your personal name custom embroidered inside.",
            "footer_text": "Our Tailoring"
          }
        }
      ]
    }
  ]
}
{% endschema %}
