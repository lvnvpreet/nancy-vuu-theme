{%- comment -%} About — Cinematic hero section {%- endcomment -%}

<section class="about-hero" data-section-id="{{ section.id }}">
  <div class="about-hero__bg">
    {%- if section.settings.image != blank -%}
      <div class="about-hero__img-wrap">
        {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'about-hero__img', loading: 'eager', fetchpriority: 'high' }}
      </div>
    {%- else -%}
      <div class="about-hero__img-wrap about-hero__img-wrap--placeholder"></div>
    {%- endif -%}
    <div class="about-hero__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <div class="about-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow about-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="about-hero__title serif-font">
      {{ section.settings.title_line_1 }}
      {%- if section.settings.title_line_2 != blank -%}<br>{{ section.settings.title_line_2 }}{%- endif -%}
    </h1>
    <div class="about-hero__rule"></div>
  </div>
</section>

<style>
  .about-hero {
    position: relative;
    height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--greige);
  }
  .about-hero__bg {
    position: absolute;
    inset: 0;
  }
  .about-hero__img-wrap {
    position: absolute;
    inset: 0;
    opacity: 0.2;
  }
  .about-hero__img-wrap--placeholder {
    background: var(--greige);
  }
  .about-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .about-hero__overlay {
    position: absolute;
    inset: 0;
    background: #000;
  }
  .about-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 1.5rem;
    max-width: 900px;
  }
  .about-hero__eyebrow {
    color: var(--gold);
    font-size: .625rem;
    letter-spacing: .6em;
    margin-bottom: 1.5rem;
  }
  .about-hero__title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-style: italic;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 2rem;
  }
  .about-hero__rule {
    width: 1px;
    height: 80px;
    background: var(--gold);
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .about-hero__title { font-size: 3rem; }
  }
</style>

{% schema %}
{
  "name": "About — Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark Overlay",
      "min": 0, "max": 80, "step": 5, "default": 15, "unit": "%"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "The Legacy"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title — Line 1",
      "default": "The Architecture"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title — Line 2",
      "default": "of Distinction"
    }
  ],
  "presets": [
    {
      "name": "About — Hero"
    }
  ]
}
{% endschema %}
