{%- comment -%}
  Split section with numbered highlights list + image.
{%- endcomment -%}

<section class="expo-highlights" data-section-id="{{ section.id }}">
  <div class="expo-highlights__inner reveal">
    <div class="expo-highlights__grid">
      <div class="expo-highlights__text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow" style="color: #a1a1aa;">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="expo-highlights__title serif"><em>{{ section.settings.heading }}</em></h2>
        {%- if section.settings.body != blank -%}
          <p class="expo-highlights__body">{{ section.settings.body }}</p>
        {%- endif -%}

        <ul class="expo-highlights__list">
          {%- for block in section.blocks -%}
            <li class="expo-highlights__item" {{ block.shopify_attributes }}>
              <span class="expo-highlights__item-num serif"><em>{{ block.settings.number }}</em></span>
              <div>
                <p class="expo-highlights__item-title">{{ block.settings.title }}</p>
                <p class="expo-highlights__item-desc">{{ block.settings.description }}</p>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-luxury">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>
      <div class="expo-highlights__media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            loading="lazy"
            class="expo-highlights__img">
        {%- else -%}
          <img
            src="{{ section.settings.fallback_image_url | default: 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&w=800&q=80' }}"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="expo-highlights__img">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Expo Highlights",
  "class": "expo-section-highlights",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Experience"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Connect. Dream. Build Together."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "View Schedule"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "fallback_image_url",
      "label": "Fallback image URL (if no image uploaded)"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Keynote & Panel Sessions"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expo Highlights",
      "blocks": [
        { "type": "highlight", "settings": { "number": "01", "title": "Keynote & Panel Sessions", "description": "Industry leaders share actionable blueprints for vision-to-reality journeys." } },
        { "type": "highlight", "settings": { "number": "02", "title": "Live Exhibitions", "description": "Discover local & global brands, creative showcases, and curated experiences." } },
        { "type": "highlight", "settings": { "number": "03", "title": "Networking & Mentorship", "description": "Connect with changemakers from every sphere of influence across Hawaiʻi." } }
      ]
    }
  ]
}
{% endschema %}
