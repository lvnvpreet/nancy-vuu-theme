{%- comment -%} Press Page — Museum: 3-col editorial photo grid with grayscale hover {%- endcomment -%}
<section id="museum" class="press-museum" data-section-id="{{ section.id }}">
  <div class="press-museum__inner">

    <div class="press-museum__header reveal">
      <div>
        <span class="press-gold-label">{{ section.settings.eyebrow | default: 'The Archive' }}</span>
        <h2 class="press-museum__title serif-font">{{ section.settings.heading | default: 'Museum of Editorials' }}</h2>
      </div>
      {%- if section.settings.archive_link != blank -%}
        <a href="{{ section.settings.archive_link }}" class="press-museum__link">View Archive</a>
      {%- else -%}
        <a href="#" class="press-museum__link">View Archive</a>
      {%- endif -%}
    </div>

    <div class="press-museum__grid reveal">

      <!-- Image 1 -->
      <div class="press-museum__item">
        {%- if section.settings.image_1 != blank -%}
          <img
            src="{{ section.settings.image_1 | image_url: width: 1000 }}"
            srcset="{{ section.settings.image_1 | image_url: width: 600 }} 600w, {{ section.settings.image_1 | image_url: width: 1000 }} 1000w"
            sizes="(max-width: 768px) 100vw, 33vw"
            alt="{{ section.settings.image_1.alt | default: 'Editorial' }}"
            class="press-museum__img"
            loading="lazy">
        {%- else -%}
          <img
            src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&q=80&w=1000"
            alt="Editorial"
            class="press-museum__img"
            loading="lazy">
        {%- endif -%}
      </div>

      <!-- Image 2 -->
      <div class="press-museum__item">
        {%- if section.settings.image_2 != blank -%}
          <img
            src="{{ section.settings.image_2 | image_url: width: 1000 }}"
            srcset="{{ section.settings.image_2 | image_url: width: 600 }} 600w, {{ section.settings.image_2 | image_url: width: 1000 }} 1000w"
            sizes="(max-width: 768px) 100vw, 33vw"
            alt="{{ section.settings.image_2.alt | default: 'Editorial' }}"
            class="press-museum__img"
            loading="lazy">
        {%- else -%}
          <img
            src="https://images.unsplash.com/photo-1539109132304-3912446184a1?auto=format&fit=crop&q=80&w=1000"
            alt="Editorial"
            class="press-museum__img"
            loading="lazy">
        {%- endif -%}
      </div>

      <!-- Image 3 -->
      <div class="press-museum__item">
        {%- if section.settings.image_3 != blank -%}
          <img
            src="{{ section.settings.image_3 | image_url: width: 1000 }}"
            srcset="{{ section.settings.image_3 | image_url: width: 600 }} 600w, {{ section.settings.image_3 | image_url: width: 1000 }} 1000w"
            sizes="(max-width: 768px) 100vw, 33vw"
            alt="{{ section.settings.image_3.alt | default: 'Editorial' }}"
            class="press-museum__img"
            loading="lazy">
        {%- else -%}
          <img
            src="https://images.unsplash.com/photo-1496217590455-aa63a8350eea?auto=format&fit=crop&q=80&w=1000"
            alt="Editorial"
            class="press-museum__img"
            loading="lazy">
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press — Museum",
  "class": "press-section-museum",
  "settings": [
    { "type": "text",         "id": "eyebrow",     "label": "Eyebrow",       "default": "The Archive" },
    { "type": "text",         "id": "heading",     "label": "Heading",       "default": "Museum of Editorials" },
    { "type": "url",          "id": "archive_link","label": "Archive Link" },
    { "type": "image_picker", "id": "image_1",     "label": "Editorial Image 1" },
    { "type": "image_picker", "id": "image_2",     "label": "Editorial Image 2" },
    { "type": "image_picker", "id": "image_3",     "label": "Editorial Image 3" }
  ],
  "presets": [
    { "name": "Press — Museum" }
  ]
}
{% endschema %}
