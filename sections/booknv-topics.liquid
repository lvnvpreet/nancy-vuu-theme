{%- comment -%} BookNV Keynote Pillars — 3-col grid of 6 pillars, white bg, strategic perspectives {%- endcomment -%}
<section id="keynotes" class="booknv-pillars" data-section-id="{{ section.id }}">
  <div class="booknv-pillars__inner">

    <div class="booknv-pillars__header reveal">
      <div class="booknv-pillars__header-left">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow booknv-pillars__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="booknv-pillars__heading serif-font">
          {{ section.settings.heading_pre_italic }} <em>{{ section.settings.heading_italic }}</em>
        </h2>
      </div>
      {%- if section.settings.heading_sub != blank -%}
        <span class="booknv-pillars__sub">{{ section.settings.heading_sub }}</span>
      {%- endif -%}
    </div>

    <div class="booknv-pillars__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'pillar' -%}
          <div class="booknv-pillar reveal" {{ block.shopify_attributes }}>
            {%- if block.settings.number != blank -%}
              <span class="booknv-pillar__num">{{ block.settings.number }}</span>
            {%- endif -%}
            <h3 class="booknv-pillar__title serif-font">{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}
              <p class="booknv-pillar__body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "BookNV Keynote Pillars",
  "class": "booknv-section-pillars",
  "settings": [
    { "type": "text", "id": "eyebrow",           "label": "Eyebrow",                  "default": "Core Framework" },
    { "type": "text", "id": "heading_pre_italic", "label": "Heading — Before Italic",  "default": "Strategic" },
    { "type": "text", "id": "heading_italic",     "label": "Heading — Italic Word",    "default": "Perspectives." },
    { "type": "text", "id": "heading_sub",        "label": "Right Sub-label",          "default": "Six Pillars of Excellence" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text",     "id": "number", "label": "Number Label", "default": "01 — BUSINESS" },
        { "type": "text",     "id": "title",  "label": "Title",        "default": "Corporate Leadership" },
        { "type": "textarea", "id": "body",   "label": "Description",  "default": "Integrating high-aesthetic standards and creative integrity into corporate ecosystems to drive brand value and leadership purpose." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BookNV Keynote Pillars",
      "blocks": [
        { "type": "pillar", "settings": { "number": "01 — BUSINESS",     "title": "Corporate Leadership", "body": "Integrating high-aesthetic standards and creative integrity into corporate ecosystems to drive brand value and leadership purpose." } },
        { "type": "pillar", "settings": { "number": "02 — CREATIVITY",   "title": "The Creative Ethos",   "body": "Moving from designing content to fulfilling purpose. A masterclass in high-authority storytelling and visionary execution." } },
        { "type": "pillar", "settings": { "number": "03 — PHILANTHROPY", "title": "Social Innovation",    "body": "Utilizing industry platforms to transform human conditions through collaborative mission-driven creative work." } },
        { "type": "pillar", "settings": { "number": "04 — CULTURE",      "title": "Cultural Restoration", "body": "Exploring the divine intersection of beauty, honor, and restoration in modern industry environments." } },
        { "type": "pillar", "settings": { "number": "05 — EMPOWERMENT",  "title": "Visionary Women",      "body": "Empowering women to leverage their unique visionary voice to lead with uncompromising passion for the global good." } },
        { "type": "pillar", "settings": { "number": "06 — EXCELLENCE",   "title": "Architecting Honor",   "body": "The discipline of elite standards and how high-level creative direction transforms internal team culture." } }
      ]
    }
  ]
}
{% endschema %}
