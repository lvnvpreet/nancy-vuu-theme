{% comment %} sections/header.liquid {% endcomment %}

<nav id="navbar" class="site-nav" role="navigation">
  <div class="nav-inner">

    <!-- Menu Toggle -->
    <button
      id="menu-toggle-btn"
      onclick="toggleMenu()"
      aria-expanded="false"
      aria-controls="menu-overlay"
      class="nav-menu-btn">
      {{- section.settings.menu_label | default: 'Menu' -}}
    </button>

    <!-- Logo -->
    <div class="nav-logo">
      <a href="/" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ shop.name }}"
            width="140"
            height="40"
            loading="eager">
        {%- else -%}
          <span class="serif-font nav-logo-text">{{ shop.name | upcase }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Right: CTA + Cart -->
    <div class="nav-right">
      <button class="nav-cta nav-cta--desktop" data-gateway-open aria-haspopup="dialog">
        {{- section.settings.cta_label | default: 'Request An Audience With Nancy Vuu' -}}
      </button>
      <button
        id="cart-toggle-btn"
        onclick="openCart()"
        class="nav-cart-btn"
        aria-label="{{ 'cart.title' | t }} ({{ cart.item_count }})">
        {% render 'icon-cart' %}
        <span class="cart-count{% if cart.item_count == 0 %} cart-count--hidden{% endif %}" id="cart-count">
          {{ cart.item_count }}
        </span>
      </button>
    </div>

  </div>
</nav>

<!-- MENU OVERLAY -->
<div
  id="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
  class="menu-overlay menu-overlay--closed">

  <button id="menu-close-btn" onclick="toggleMenu()" class="menu-close-btn" aria-label="Close menu">✕</button>

  <div class="menu-grid">
    <div class="menu-column">
      <p class="eyebrow" style="color:#ccc;">{{ section.settings.col1_heading | default: 'Fashion House' }}</p>
      <nav>
        {%- for link in linklists[section.settings.menu_fashion].links -%}
          <a href="{{ link.url }}" onclick="toggleMenu()" data-text="{{ link.title }}">
            <span>{{ link.title }}</span>
          </a>
        {%- endfor -%}
      </nav>
    </div>
    <div class="menu-column">
      <p class="eyebrow" style="color:#ccc;">{{ section.settings.col2_heading | default: 'Lifestyle &amp; Legacy' }}</p>
      <nav>
        {%- for link in linklists[section.settings.menu_lifestyle].links -%}
          <a href="{{ link.url }}" onclick="toggleMenu()" data-text="{{ link.title }}">
            <span>{{ link.title }}</span>
          </a>
        {%- endfor -%}
        {%- if section.settings.show_library_link -%}
          <a href="{{ section.settings.library_link | default: '/pages/library' }}" onclick="toggleMenu()" data-text="The Library">
            <span>The Library</span>
          </a>
        {%- endif -%}
      </nav>
    </div>
  </div>

  <div class="menu-footer">
    <span>{{ section.settings.menu_location | default: 'San Jose, CA' }}</span>
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
  </div>
</div>

<!-- Cart Drawer -->
{% render 'cart-drawer' %}

<!-- ═══════════════════════════════════════════════════════════
     LEGACY GATEWAY MODAL
     ═══════════════════════════════════════════════════════════ -->
<style>
  /* ── Gateway Modal ───────────────────────────────────────── */
  .nv-gateway-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 5, 4, 0.97);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 2rem 1.25rem;
    overflow-y: auto;
  }
  .nv-gateway-modal--open {
    opacity: 1;
    visibility: visible;
  }

  /* Close button */
  .nv-gateway-modal__close {
    position: fixed;
    top: 1.75rem;
    right: 2rem;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
    transition: color 0.3s ease, transform 0.3s ease;
    z-index: 10;
  }
  .nv-gateway-modal__close:hover {
    color: #c5a059;
    transform: rotate(90deg);
  }

  /* Inner wrapper — animates up on open */
  .nv-gateway-inner {
    width: 100%;
    max-width: 860px;
    text-align: center;
    padding: 3rem 1rem 2rem;
    transform: translateY(24px);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nv-gateway-modal--open .nv-gateway-inner {
    transform: translateY(0);
  }

  /* Crown ornament */
  .nv-gateway-ornament {
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .nv-gateway-ornament__line {
    width: 40px;
    height: 1px;
    background: rgba(197, 160, 89, 0.4);
  }
  .nv-gateway-ornament__dot {
    width: 6px;
    height: 6px;
    background: #c5a059;
    border-radius: 50%;
  }

  /* Eyebrow */
  .nv-gateway-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.55rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: #c5a059;
    margin: 0 0 1.25rem;
  }

  /* Main heading */
  .nv-gateway-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: #ffffff;
    line-height: 1.25;
    margin: 0 0 1.5rem;
    letter-spacing: -0.01em;
  }

  /* Decorative divider */
  .nv-gateway-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 auto 3rem;
  }
  .nv-gateway-divider::before,
  .nv-gateway-divider::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(to var(--dir, right), transparent, rgba(197,160,89,0.5));
  }
  .nv-gateway-divider::before { --dir: right; }
  .nv-gateway-divider::after  { --dir: left;  }
  .nv-gateway-divider-gem {
    width: 5px;
    height: 5px;
    background: #c5a059;
    transform: rotate(45deg);
  }

  /* 2×2 pathway grid */
  .nv-gateway-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(197, 160, 89, 0.12);
    border: 1px solid rgba(197, 160, 89, 0.12);
    text-align: left;
  }

  /* Individual pathway card */
  .nv-gateway-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem 2rem 2rem;
    background: #0d0c0b;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: background 0.4s ease;
    cursor: pointer;
  }
  .nv-gateway-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #c5a059;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nv-gateway-card:hover {
    background: #141210;
  }
  .nv-gateway-card:hover::before {
    transform: scaleX(1);
  }

  /* Numeral */
  .nv-gateway-card__numeral {
    font-family: var(--font-sans);
    font-size: 0.55rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #c5a059;
    display: block;
    margin-bottom: 1.25rem;
  }

  /* Card title */
  .nv-gateway-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.2vw, 1.45rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.3;
    margin: 0 0 0.85rem;
    letter-spacing: 0.01em;
  }

  /* Card description */
  .nv-gateway-card__desc {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.8;
    letter-spacing: 0.04em;
    margin: 0;
    flex: 1;
  }

  /* Arrow */
  .nv-gateway-card__arrow {
    display: block;
    margin-top: 2rem;
    font-size: 1rem;
    color: rgba(197, 160, 89, 0.4);
    transition: color 0.3s ease, transform 0.3s ease;
    letter-spacing: 0;
  }
  .nv-gateway-card:hover .nv-gateway-card__arrow {
    color: #c5a059;
    transform: translateX(5px);
  }

  /* Footer note */
  .nv-gateway-footer {
    margin-top: 2.5rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .nv-gateway-grid {
      grid-template-columns: 1fr;
    }
    .nv-gateway-card {
      padding: 2rem 1.5rem 1.75rem;
    }
    .nv-gateway-heading {
      font-size: 1.75rem;
    }
    .nv-gateway-modal__close {
      top: 1.25rem;
      right: 1.25rem;
    }
  }
  @media (max-width: 400px) {
    .nv-gateway-card {
      padding: 1.75rem 1.25rem;
    }
  }
</style>

<div
  id="nv-gateway-modal"
  class="nv-gateway-modal"
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
  aria-labelledby="nv-gateway-heading">

  <button class="nv-gateway-modal__close" data-gateway-close aria-label="Close">
    <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="nv-gateway-inner">

    <!-- Ornament -->
    <div class="nv-gateway-ornament" aria-hidden="true">
      <div class="nv-gateway-ornament__line"></div>
      <div class="nv-gateway-ornament__dot"></div>
      <div class="nv-gateway-ornament__line" style="transform:scaleX(-1);"></div>
    </div>

    <!-- Eyebrow -->
    <p class="nv-gateway-eyebrow">{{ section.settings.gateway_eyebrow | default: 'Nancy Vuu — House of Legacy' }}</p>

    <!-- Heading -->
    <h2 id="nv-gateway-heading" class="nv-gateway-heading">
      {{ section.settings.gateway_heading | default: 'How May We Serve<br>Your Legacy?' }}
    </h2>

    <!-- Divider gem -->
    <div class="nv-gateway-divider">
      <div class="nv-gateway-divider-gem"></div>
    </div>

    <!-- 4 Pathways -->
    <div class="nv-gateway-grid">

      <!-- I: Bridal -->
      <a href="/pages/bridal-couture#inquiry" class="nv-gateway-card">
        <span class="nv-gateway-card__numeral">I — Bridal</span>
        <h3 class="nv-gateway-card__title">Bridal Commissions<br>Couture Gowns</h3>
        <p class="nv-gateway-card__desc">For the sovereign bride ready to commission a sacred, one-of-a-kind masterpiece.</p>
        <span class="nv-gateway-card__arrow">&#8594;</span>
      </a>

      <!-- II: Sartorial -->
      <a href="/pages/seth-eden#inquiry" class="nv-gateway-card">
        <span class="nv-gateway-card__numeral">II — Sartorial</span>
        <h3 class="nv-gateway-card__title">Sartorial Commissions<br>Bespoke Executive &amp; Groom Suits</h3>
        <p class="nv-gateway-card__desc">For the man or woman of distinction seeking a fully commissioned wardrobe architecture.</p>
        <span class="nv-gateway-card__arrow">&#8594;</span>
      </a>

      <!-- III: Global -->
      <a href="/pages/book-nancy-vuu#booking" class="nv-gateway-card">
        <span class="nv-gateway-card__numeral">III — Global</span>
        <h3 class="nv-gateway-card__title">Global Engagements<br>Keynotes &amp; Media Appearances</h3>
        <p class="nv-gateway-card__desc">For organizations seeking to engage Nancy Vuu on the world stage.</p>
        <span class="nv-gateway-card__arrow">&#8594;</span>
      </a>

      <!-- IV: Immersions -->
      <a href="/pages/retreats#inquiry" class="nv-gateway-card">
        <span class="nv-gateway-card__numeral">IV — Immersions</span>
        <h3 class="nv-gateway-card__title">Executive Immersions<br>Strategic Retreats &amp; Consulting</h3>
        <p class="nv-gateway-card__desc">For visionary leaders ready for a private alignment intensive.</p>
        <span class="nv-gateway-card__arrow">&#8594;</span>
      </a>

    </div>

    <p class="nv-gateway-footer">Every inquiry is received in confidence &amp; with intention</p>

  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (leave blank for shop name text)"
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Menu button label",
      "default": "Menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button text",
      "default": "Request Consultation"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "text",
      "id": "col1_heading",
      "label": "Menu column 1 heading",
      "default": "Fashion House"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Menu column 2 heading",
      "default": "Lifestyle & Legacy"
    },
    {
      "type": "link_list",
      "id": "menu_fashion",
      "label": "Fashion House links",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "menu_lifestyle",
      "label": "Lifestyle & Legacy links"
    },
    {
      "type": "text",
      "id": "menu_location",
      "label": "Menu footer — location text",
      "default": "San Jose, CA"
    },
    {
      "type": "checkbox",
      "id": "show_library_link",
      "label": "Show 'The Library' in Lifestyle menu",
      "default": true
    },
    {
      "type": "url",
      "id": "library_link",
      "label": "The Library page link"
    },
    {
      "type": "header",
      "content": "Legacy Gateway Modal"
    },
    {
      "type": "text",
      "id": "gateway_eyebrow",
      "label": "Gateway eyebrow text",
      "default": "Nancy Vuu — House of Legacy"
    },
    {
      "type": "text",
      "id": "gateway_heading",
      "label": "Gateway heading",
      "default": "How May We Serve<br>Your Legacy?"
    },
    {
      "type": "url",
      "id": "gateway_bridal_link",
      "label": "Pathway I: Sartorial Bridal Commissions link"
    },
    {
      "type": "url",
      "id": "gateway_suiting_link",
      "label": "Pathway II: Bespoke Seth Eden Suiting link"
    },
    {
      "type": "url",
      "id": "gateway_retreats_link",
      "label": "Pathway III: Strategic Immersions (Retreats) link"
    },
    {
      "type": "url",
      "id": "gateway_speaking_link",
      "label": "Pathway IV: Media & Global Keynotes (Book NV) link"
    }
  ]
}
{% endschema %}
