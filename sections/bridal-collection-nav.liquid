{% comment %} sections/bridal-collection-nav.liquid {% endcomment %}
<section id="bridal-collection-nav" class="bridal-collection-nav section-pad">
  <style>
    #bridal-collection-nav {
      background: {{ section.settings.bg_color | default: '#f8f6f2' }};
      color: {{ section.settings.text_color | default: '#111111' }};
    }
    #bridal-collection-nav .bridal-collection-nav__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: clamp(3rem, 5vw, 5rem) 1.5rem;
      text-align: center;
    }
    #bridal-collection-nav .bridal-collection-nav__eyebrow {
      display: block;
      font-family: var(--font-sans);
      font-size: .62rem;
      letter-spacing: .42em;
      text-transform: uppercase;
      color: #9c8b6a;
      margin-bottom: 1rem;
    }
    #bridal-collection-nav .bridal-collection-nav__title {
      margin: 0 auto 2.5rem;
      max-width: 14ch;
      line-height: 1.02;
    }
    #bridal-collection-nav .bridal-collection-nav__grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.1rem;
    }
    #bridal-collection-nav .bridal-collection-nav__card {
      display: block;
      width: 100%;
      border: 1px solid rgba(17, 17, 17, 0.18);
      background: #ffffff;
      color: #111111;
      text-decoration: none;
      text-align: left;
      overflow: hidden;
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }
    #bridal-collection-nav .bridal-collection-nav__card:hover {
      transform: translateY(-3px);
      border-color: rgba(17, 17, 17, 0.36);
      box-shadow: 0 12px 28px rgba(17, 17, 17, 0.1);
    }
    #bridal-collection-nav .bridal-collection-nav__media {
      position: relative;
      aspect-ratio: 4 / 3;
      background: #f1ece3;
      overflow: hidden;
    }
    #bridal-collection-nav .bridal-collection-nav__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .45s ease;
      display: block;
    }
    #bridal-collection-nav .bridal-collection-nav__card:hover .bridal-collection-nav__img {
      transform: scale(1.04);
    }
    #bridal-collection-nav .bridal-collection-nav__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-sans);
      font-size: .62rem;
      letter-spacing: .28em;
      text-transform: uppercase;
      color: #8f8678;
    }
    #bridal-collection-nav .bridal-collection-nav__content {
      padding: 1rem 1rem 1.1rem;
    }
    #bridal-collection-nav .bridal-collection-nav__name {
      margin: 0 0 .6rem;
      font-family: var(--font-serif);
      font-size: clamp(1rem, 1.4vw, 1.28rem);
      line-height: 1.2;
      color: #111111;
    }
    #bridal-collection-nav .bridal-collection-nav__cta {
      display: inline-block;
      font-family: var(--font-sans);
      font-size: .58rem;
      font-weight: 700;
      letter-spacing: .28em;
      text-transform: uppercase;
      color: #6b5b3f;
    }
    @media (max-width: 900px) {
      #bridal-collection-nav .bridal-collection-nav__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 640px) {
      #bridal-collection-nav .bridal-collection-nav__title {
        max-width: none;
      }
      #bridal-collection-nav .bridal-collection-nav__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="bridal-collection-nav__inner">
    <span class="bridal-collection-nav__eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="serif-font section-title-xl bridal-collection-nav__title">{{ section.settings.title }}</h2>

    <div class="bridal-collection-nav__grid">
      {%- for block in section.blocks -%}
        {%- assign selected_collection = block.settings.collection -%}
        {%- if selected_collection != blank -%}
          {%- assign card_label = block.settings.label | strip -%}
          <a class="bridal-collection-nav__card" href="{{ selected_collection.url }}" {{ block.shopify_attributes }}>
            <div class="bridal-collection-nav__media">
              {%- if selected_collection.featured_image != blank -%}
                <img
                  class="bridal-collection-nav__img"
                  src="{{ selected_collection.featured_image | image_url: width: 900 }}"
                  alt="{{ selected_collection.title | escape }}"
                  loading="lazy"
                  width="450"
                  height="338">
              {%- else -%}
                <div class="bridal-collection-nav__placeholder">Collection</div>
              {%- endif -%}
            </div>
            <div class="bridal-collection-nav__content">
              <h3 class="bridal-collection-nav__name">{{ card_label | default: selected_collection.title }}</h3>
              <span class="bridal-collection-nav__cta">View Collection</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bridal Collection Nav",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore By Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Select A Bridal Collection"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f8f6f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "collection_link",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom label (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Bridal Collection Nav",
      "blocks": [
        { "type": "collection_link" },
        { "type": "collection_link" },
        { "type": "collection_link" },
        { "type": "collection_link" },
        { "type": "collection_link" },
        { "type": "collection_link" }
      ]
    }
  ]
}
{% endschema %}