{%- comment -%}
  Ambassador / Global Collective section for Dream Academy page.
{%- endcomment -%}

<section id="{{ section.settings.anchor_id }}" class="academy-ambassador" data-section-id="{{ section.id }}">
  <div class="academy-ambassador__inner reveal">
    <div class="academy-ambassador__grid">
      <div class="academy-ambassador__text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow" style="color: var(--gold, #c5a059);">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="academy-pillar__editorial-title serif">{{ section.settings.heading }}</h2>

        {%- if section.settings.lead != blank -%}
          <p class="academy-ambassador__lead">{{ section.settings.lead }}</p>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="academy-ambassador__body">{{ section.settings.body }}</p>
        {%- endif -%}

        {%- assign benefit_blocks = section.blocks | where: "type", "benefit" -%}
        {%- if benefit_blocks.size > 0 -%}
          <div class="academy-ambassador__benefits">
            {%- for block in benefit_blocks -%}
              <div class="ambassador-card" {{ block.shopify_attributes }}>
                <p class="ambassador-card__number">{{ block.settings.number }}</p>
                <p class="ambassador-card__title serif"><em>{{ block.settings.title }}</em></p>
                <p class="ambassador-card__desc">{{ block.settings.description }}</p>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          {%- if section.settings.cta_type == 'dossier' -%}
            <button type="button" class="btn-luxury" onclick="nvOpenDossier()">{{ section.settings.cta_text }}</button>
          {%- elsif section.settings.cta_type == 'inquiry' -%}
            <button type="button" class="btn-luxury" onclick="nvOpenInquiry('{{ section.settings.cta_vertical }}')">{{ section.settings.cta_text }}</button>
          {%- else -%}
            <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-luxury">{{ section.settings.cta_text }}</a>
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="academy-ambassador__media">
        {%- if section.settings.image != blank -%}
          <div class="academy-ambassador__img-wrap">
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              alt="{{ section.settings.image.alt | default: section.settings.heading }}"
              loading="lazy"
              class="academy-pillar__img">
          </div>
        {%- else -%}
          <div class="academy-ambassador__img-wrap">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'academy-pillar__img placeholder' }}
          </div>
        {%- endif -%}

        {%- if section.settings.floating_eyebrow != blank or section.settings.floating_quote != blank -%}
          <div class="academy-ambassador__floating">
            {%- if section.settings.floating_eyebrow != blank -%}
              <p class="academy-ambassador__floating-eyebrow">{{ section.settings.floating_eyebrow }}</p>
            {%- endif -%}
            {%- if section.settings.floating_quote != blank -%}
              <p class="academy-ambassador__floating-quote serif"><em>{{ section.settings.floating_quote }}</em></p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Academy Ambassador",
  "class": "academy-section-ambassador",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "ambassador"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Ambassador Program"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Global Collective"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead paragraph",
      "default": "Join the House of Vuu as a brand architect. We are opening our doors to fans and clients to build the future of excellence with us."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Our Brand Ambassadors are more than representatives—they are partners in prosperity. Through a curated commission-based model, you champion the Vuu standard while creating your own financial legacy."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Inquire for Partnership"
    },
    {
      "type": "select",
      "id": "cta_type",
      "label": "CTA Action Type",
      "options": [
        { "value": "link", "label": "Regular Link" },
        { "value": "dossier", "label": "Open Dossier Modal" },
        { "value": "inquiry", "label": "Open Inquiry Modal" }
      ],
      "default": "link"
    },
    {
      "type": "select",
      "id": "cta_vertical",
      "label": "Inquiry Modal Type (if Inquiry selected)",
      "options": [
        { "value": "academy", "label": "Creative Academy" },
        { "value": "womenceo", "label": "Women CEO Collective" }
      ],
      "default": "academy"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "floating_eyebrow",
      "label": "Floating card eyebrow",
      "default": "Shared Growth"
    },
    {
      "type": "text",
      "id": "floating_quote",
      "label": "Floating card quote",
      "default": "\"Your success is woven into the fabric of our house.\""
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Card",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "Benefit 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Commission"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Direct profit participation on every legacy piece you represent."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Academy Ambassador",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "number": "Benefit 01",
            "title": "Commission",
            "description": "Direct profit participation on every legacy piece you represent."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "number": "Benefit 02",
            "title": "Curated Assets",
            "description": "Access to exclusive marketing tools and high-fashion assets."
          }
        }
      ]
    }
  ]
}
{% endschema %}
