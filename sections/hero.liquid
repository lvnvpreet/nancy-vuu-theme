{% comment %} sections/hero.liquid — Cinematic full-bleed hero with image or video {% endcomment %}

<header class="hero" id="hero">
  <div class="hero__bg">
    {%- if section.settings.bg_video != blank -%}
      <video
        class="hero__video"
        autoplay muted loop playsinline
        poster="{%- if section.settings.bg_image -%}{{ section.settings.bg_image | image_url: width: 1920 }}{%- endif -%}">
        <source src="{{ section.settings.bg_video }}" type="video/mp4">
      </video>
    {%- else -%}
      {%- render 'image',
          image: section.settings.bg_image,
          alt: shop.name,
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          class: 'hero__img',
          placeholder_text: 'Upload hero background in Theme Editor'
      -%}
    {%- endif -%}
  </div>

  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="hero__overlay" style="background:rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
  {%- endif -%}

  <div class="hero__content" style="color:{{ section.settings.text_color }};">
    <h1 class="hero__title serif-font">
      <span class="hero-word" style="animation-delay:0.1s;">FASHIONED</span><br>
      <span class="hero-word italic" style="animation-delay:0.35s; font-style:italic; font-weight:300;">{{ section.settings.headline_italic | default: 'for' }}</span>
      <span class="hero-word" style="animation-delay:0.6s;"> {{ section.settings.headline_end | default: 'HEAVEN' }}</span>
    </h1>
    <p class="hero__subtitle">{{ section.settings.subheading | default: 'Tailored for Earth' }}</p>
    {%- if section.settings.cta_label != blank -%}
      <button type="button" class="hero__cta" data-gateway-open>
        {{ section.settings.cta_label }}
      </button>
    {%- endif -%}
  </div>

  <div class="scroll-indicator">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</header>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "bg_video",
      "label": "Background video URL (MP4)",
      "info": "Paste a direct .mp4 URL for cinematic video hero. Leave blank for image-only."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark overlay",
      "min": 0, "max": 80, "step": 5, "default": 0, "unit": "%"
    },
    {
      "type": "text",
      "id": "headline_italic",
      "label": "Italic word (middle)",
      "default": "for"
    },
    {
      "type": "text",
      "id": "headline_end",
      "label": "Last word",
      "default": "HEAVEN"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tailored for Earth"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#111111"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Request A Consultation"
    },
    {
      "type": "text",
      "id": "cta_link",
      "label": "CTA button link",
      "default": "/pages/atelier#inquiry",
      "info": "e.g. /pages/atelier#inquiry"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
