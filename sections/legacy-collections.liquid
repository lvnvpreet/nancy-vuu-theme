{% comment %} sections/legacy-collections.liquid {% endcomment %}
<section id="children" class="section-cards">
  <div class="section-cards__header reveal">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'For the Little Ones' }}</span>
    <h2 class="serif-font section-title-xl">{{ section.settings.title | default: 'The Legacy Collections' }}</h2>
  </div>
  <div class="cards-grid">
    {%- for block in section.blocks -%}
      <div class="card group reveal {% if forloop.index > 1 %}delay-100{% endif %}" {{ block.shopify_attributes }}>
        <div class="card__image-wrap">
          {%- render 'image', image: block.settings.image, class: 'card__img img-zoom', placeholder_text: block.settings.title -%}
        </div>
        <h3 class="serif-font card__title">{{ block.settings.title }}</h3>
        <a href="{{ block.settings.link | default: '#' }}" class="card__link">{{ block.settings.cta }} →</a>
      </div>
    {%- endfor -%}
  </div>
</section>
{% schema %}
{
  "name": "Legacy Collections",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "For the Little Ones" },
    { "type": "text", "id": "title",   "label": "Title",   "default": "The Legacy Collections" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text",         "id": "title", "label": "Title", "default": "Collection" },
        { "type": "text",         "id": "cta",   "label": "Link text", "default": "Shop Now" },
        { "type": "url",          "id": "link",  "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Legacy Collections",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Children's Couture", "cta": "Shop Kids" } },
        { "type": "collection_card", "settings": { "title": "Mommy & Me",         "cta": "Shop Matching Sets" } }
      ]
    }
  ]
}
{% endschema %}
