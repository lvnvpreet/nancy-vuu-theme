{%- comment -%} Reusable CTA Closer — fullscreen bg with heading + button {%- endcomment -%}
<section
  class="cta-closer{% if section.settings.bg_light %} cta-closer--light{% endif %}{% if section.settings.compact %} cta-closer--compact{% endif %}"
  {% unless section.settings.bg_light %}{% if section.settings.image %}style="background-image:url({{ section.settings.image | image_url: width: 2000 }});"{% endif %}{% endunless %}
>
  <div class="cta-closer__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="cta-closer__content reveal">
    {% if section.settings.eyebrow != blank %}
      <span class="eyebrow" style="color:{{ section.settings.text_color }};">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2 class="cta-closer__title serif-font" style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
    {% if section.settings.subtext != blank %}
      <p class="cta-closer__sub body-copy" style="color:{{ section.settings.text_color }};">{{ section.settings.subtext }}</p>
    {% endif %}
    {% if section.settings.cta_label != blank or section.settings.cta2_label != blank %}
      <div class="cta-closer__btns" style="color:{{ section.settings.text_color }};">
        {% if section.settings.cta_label != blank %}
          {% if section.settings.cta_style == 'fill' %}
            <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-fill">{{ section.settings.cta_label }}</a>
          {% elsif section.settings.cta_link != blank %}
            <a href="{{ section.settings.cta_link }}" class="btn-luxury">{{ section.settings.cta_label }}</a>
          {% else %}
            <button class="btn-luxury" data-audience-open>{{ section.settings.cta_label }}</button>
          {% endif %}
        {% endif %}
        {% if section.settings.cta2_label != blank %}
          <a href="{{ section.settings.cta2_link | default: '#' }}" class="btn-luxury">{{ section.settings.cta2_label }}</a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CTA Closer",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image",            "label": "Background Image" },
    { "type": "range",        "id": "overlay_opacity",   "label": "Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 50 },
    { "type": "text",         "id": "eyebrow",          "label": "Eyebrow" },
    { "type": "text",         "id": "heading",          "label": "Heading",         "default": "Begin Your Journey" },
    { "type": "textarea",     "id": "subtext",          "label": "Subtext" },
    { "type": "text",         "id": "cta_label",        "label": "CTA Label",       "default": "Book Consultation" },
    { "type": "url",          "id": "cta_link",         "label": "CTA Link" },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Primary CTA Style",
      "default": "outline",
      "options": [
        { "value": "outline", "label": "Outline (btn-luxury)" },
        { "value": "fill",    "label": "Filled Gold (btn-fill)" }
      ]
    },
    { "type": "text",         "id": "cta2_label",       "label": "CTA 2 Label" },
    { "type": "url",          "id": "cta2_link",        "label": "CTA 2 Link" },
    { "type": "color",        "id": "text_color",       "label": "Text Color",      "default": "#ffffff" },
    { "type": "checkbox",     "id": "bg_light",         "label": "Light background (white, no image)", "default": false },
    { "type": "checkbox",     "id": "compact",          "label": "Compact (remove full-height)",       "default": false }
  ]
}
{% endschema %}
