{%- comment -%} BookNV Vision — Architecture of Identity, two-column, quote + image, bg #FBFBFB {%- endcomment -%}
<section class="booknv-vision" id="vision" data-section-id="{{ section.id }}">
  <div class="booknv-vision__inner">

    <div class="booknv-vision__text reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow booknv-vision__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="booknv-vision__title serif-font">
        {{ section.settings.title_line_1 }}<br>
        <em>{{ section.settings.title_italic }}</em>
      </h2>
      {%- if section.settings.quote != blank -%}
        <blockquote class="booknv-vision__quote serif-font">{{ section.settings.quote }}</blockquote>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="booknv-vision__body">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    <div class="booknv-vision__media reveal delay-200">
      <div class="booknv-vision__img-wrap">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: 'Visionary Narrative' }}"
            class="booknv-vision__img"
            loading="lazy">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'booknv-vision__img placeholder' }}
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "BookNV Vision",
  "class": "booknv-section-vision",
  "settings": [
    { "type": "text",         "id": "eyebrow",      "label": "Eyebrow",               "default": "Architecture of Identity" },
    { "type": "text",         "id": "title_line_1", "label": "Heading — Line 1",      "default": "A Platform for" },
    { "type": "text",         "id": "title_italic", "label": "Heading — Italic Line",  "default": "Humanity." },
    { "type": "textarea",     "id": "quote",        "label": "Pull Quote",            "default": "\"The distinction of Nancy Vuu brand is the passion to give her all for the good of mankind.\"" },
    { "type": "textarea",     "id": "body",         "label": "Body Text",             "default": "Her dedication to humanity is evident as designed garments and stories come alive—exhibiting excellence, promoting honor and proclaiming new hope globally." },
    { "type": "image_picker", "id": "image",        "label": "Image" }
  ],
  "presets": [
    { "name": "BookNV Vision" }
  ]
}
{% endschema %}
