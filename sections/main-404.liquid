<section class="page-404">
  <div class="page-404__inner">
    <span class="page-404__eyebrow eyebrow" style="color: var(--gold, #c5a059);">Page Not Found</span>
    <h1 class="page-404__title serif"><em>404</em></h1>
    <p class="page-404__body">The page you are looking for has moved or no longer exists.</p>
    <a href="{{ routes.root_url }}" class="btn-editorial">Return Home</a>
  </div>
</section>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "class": "section-404"
}
{% endschema %}
