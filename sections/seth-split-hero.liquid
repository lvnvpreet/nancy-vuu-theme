<section class="seth-split-hero" data-section-id="{{ section.id }}">
  {%- for block in section.blocks -%}
    <a href="{{ block.settings.link | default: '#' }}" class="split-panel" {{ block.shopify_attributes }}>
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
          sizes="50vw"
          alt="{{ block.settings.image.alt | default: block.settings.heading }}"
          loading="eager"
          class="split-panel__img">
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'split-panel__img placeholder' }}
      {%- endif -%}
      <div class="split-panel__overlay"></div>
      <div class="split-panel__gold-line"></div>
      <div class="split-panel__content">
        {%- if block.settings.eyebrow != blank -%}
          <span class="split-panel__eyebrow">{{ block.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="split-panel__heading serif">{{ block.settings.heading }}</h2>
        {%- if block.settings.subtext != blank -%}
          <p class="split-panel__subtext">{{ block.settings.subtext }}</p>
        {%- endif -%}
      </div>
    </a>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Seth Split Hero",
  "tag": "div",
  "class": "seth-split-hero-wrapper",
  "settings": [],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "The Appointed Man"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Seth"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Architectural Authority"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seth Split Hero",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "eyebrow": "The Appointed Man",
            "heading": "Seth",
            "subtext": "Architectural Authority"
          }
        },
        {
          "type": "panel",
          "settings": {
            "eyebrow": "The Appointed Presence",
            "heading": "Eden",
            "subtext": "Restorative Peace"
          }
        }
      ]
    }
  ]
}
{% endschema %}
