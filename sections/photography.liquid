{% comment %} sections/photography.liquid {% endcomment %}
<section id="{{ section.settings.section_id | default: 'photography' }}" class="section-photography bg-cream" data-parallax="0.3">
  <div class="section-photography__content reveal">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'Services' }}</span>
    <h2 class="serif-font section-title">{{ section.settings.title | default: 'Nancy Vuu Photography' }}</h2>
    <div class="divider" style="margin-left:auto;margin-right:auto;"></div>
    <p class="body-copy section-photography__description">
      {{ section.settings.description | default: 'Capturing the essence of your transformation. Available for editorial, bridal, and portrait sessions that transcend the ordinary.' }}
    </p>
    <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-editorial">{{ section.settings.cta_label | default: 'View Portfolio' }}</a>
  </div>

  {%- if section.settings.show_marquee -%}
    <div class="marquee-track section-photography__marquee" aria-hidden="true">
      <div class="marquee-inner">
        {%- for i in (1..6) -%}
          {%- for block in section.blocks -%}
            <span class="serif-font section-photography__marquee-word">{{ block.settings.word }}</span>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Photography",
  "max_blocks": 6,
  "settings": [
    { "type": "text",     "id": "section_id",   "label": "Section anchor ID", "default": "photography" },
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow text",      "default": "Services" },
    { "type": "text",     "id": "title",        "label": "Title",             "default": "Nancy Vuu Photography" },
    { "type": "textarea", "id": "description",  "label": "Description",       "default": "Capturing the essence of your transformation. Available for editorial, bridal, and portrait sessions that transcend the ordinary." },
    { "type": "text",     "id": "cta_label",    "label": "Button text",       "default": "View Portfolio" },
    { "type": "url",      "id": "cta_link",     "label": "Button link" },
    { "type": "checkbox", "id": "show_marquee", "label": "Show marquee",      "default": true }
  ],
  "blocks": [
    {
      "type": "marquee_word",
      "name": "Marquee Word",
      "settings": [
        { "type": "text", "id": "word", "label": "Word", "default": "CAPTURE" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Photography",
      "blocks": [
        { "type": "marquee_word", "settings": { "word": "CAPTURE" } },
        { "type": "marquee_word", "settings": { "word": "CREATE" } },
        { "type": "marquee_word", "settings": { "word": "MEMORIALIZE" } }
      ]
    }
  ]
}
{% endschema %}
