      { "type": "color",        "id": "color_ink",    "label": "Primary ink colour",   "default": "#0f0f0f" },
      { "type": "color",        "id": "color_cream",  "label": "Cream background",     "default": "#faf8f5" },
      { "type": "color",        "id": "color_greige", "label": "Greige background",    "default": "#ece9e3" },
