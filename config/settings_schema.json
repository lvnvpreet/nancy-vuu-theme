[
  {
    "name": "theme_info",
    "theme_name": "Nancy Vuu",
    "theme_version": "2.0.0",
    "theme_author": "Nancy Vuu Atelier",
    "theme_documentation_url": "https://nancyvuu.com",
    "theme_support_url": "https://nancyvuu.com/pages/contact"
  },
  {
    "name": "Brand",
    "settings": [
      { "type": "image_picker", "id": "favicon",      "label": "Favicon (32×32 PNG)" },
      { "type": "image_picker", "id": "share_image",  "label": "Default social share image (1200×628)" },
      { "type": "color",        "id": "color_ink",    "label": "Primary ink colour",   "default": "#0f0f0f" },
      { "type": "color",        "id": "color_cream",  "label": "Cream background",     "default": "#faf8f5" },
      { "type": "color",        "id": "color_greige", "label": "Greige background",    "default": "#ece9e3" },
      { "type": "color",        "id": "color_accent", "label": "Accent colour",        "default": "#0f0f0f" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading font (override — default is Bodoni Moda via Google Fonts)",
        "default": "helvetica_n4"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font (override — default is Manrope via Google Fonts)",
        "default": "helvetica_n4"
      },
      {
        "type": "paragraph",
        "content": "Note: This theme uses Bodoni Moda + Manrope loaded from Google Fonts. The font pickers above are optional overrides."
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      { "type": "url", "id": "social_instagram",  "label": "Instagram URL" },
      { "type": "url", "id": "social_linkedin",   "label": "LinkedIn URL" },
      { "type": "url", "id": "social_pinterest",  "label": "Pinterest URL" },
      { "type": "url", "id": "social_tiktok",     "label": "TikTok URL" }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Slide-out drawer (recommended)" },
          { "value": "page",   "label": "Cart page" }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "Product Inquiry Modal",
    "settings": [
      { "type": "text", "id": "inquiry_modal_eyebrow", "label": "Eyebrow", "default": "Private Product Inquiry" },
      { "type": "text", "id": "inquiry_modal_title", "label": "Title", "default": "Request Availability" },
      { "type": "textarea", "id": "inquiry_modal_desc", "label": "Description", "default": "Submit your details and our atelier concierge will contact you with pricing, availability, and customization options for this piece." },
      { "type": "text", "id": "inquiry_modal_name_placeholder", "label": "Name placeholder", "default": "FULL NAME" },
      { "type": "text", "id": "inquiry_modal_email_placeholder", "label": "Email placeholder", "default": "EMAIL ADDRESS" },
      { "type": "text", "id": "inquiry_modal_phone_placeholder", "label": "Phone placeholder", "default": "PHONE NUMBER" },
      { "type": "text", "id": "inquiry_modal_company_placeholder", "label": "Company placeholder", "default": "ORGANIZATION / COMPANY" },
      { "type": "text", "id": "inquiry_modal_message_placeholder", "label": "Message placeholder", "default": "BRIEFLY DESCRIBE YOUR INTEREST..." },
      { "type": "text", "id": "inquiry_modal_submit_label", "label": "Submit button label", "default": "Submit Inquiry" },
      { "type": "text", "id": "inquiry_modal_success_title", "label": "Success title", "default": "Your Inquiry Has Been Received." },
      { "type": "textarea", "id": "inquiry_modal_success_body", "label": "Success message", "default": "Our team will be in touch shortly to discuss next steps." }
    ]
  }
]
