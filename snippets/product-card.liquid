{% comment %}
  Snippet: product-card.liquid
  Renders a single product card for collection grids.

  Usage:
  {%- render 'product-card', product: product, lazy_load: true -%}
{% endcomment %}

{%- liquid
  assign lazy = lazy_load | default: true
  assign loading = lazy | iif: 'lazy', 'eager'
  assign inquiry_only = false
  if product.metafields.custom.inquiry_only and product.metafields.custom.inquiry_only.value
    assign inquiry_only = true
  endif
-%}

<div class="product-card group" itemscope itemtype="http://schema.org/Product">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">

    <!-- Image -->
    <div class="product-card__image-wrap">
      {%- if product.featured_media -%}
        <img
          src="{{ product.featured_media | image_url: width: 600 }}"
          srcset="
            {{ product.featured_media | image_url: width: 400 }} 400w,
            {{ product.featured_media | image_url: width: 600 }} 600w,
            {{ product.featured_media | image_url: width: 900 }} 900w"
          sizes="(max-width:640px) calc(100vw - 2rem), (max-width:1024px) calc(50vw - 2rem), 400px"
          alt="{{ product.featured_media.alt | default: product.title | escape }}"
          loading="{{ loading }}"
          width="{{ product.featured_media.width }}"
          height="{{ product.featured_media.height }}"
          class="product-card__img img-zoom"
          itemprop="image">

        {%- if product.media.size > 1 -%}
          <img
            src="{{ product.media[1] | image_url: width: 600 }}"
            srcset="
              {{ product.media[1] | image_url: width: 400 }} 400w,
              {{ product.media[1] | image_url: width: 600 }} 600w"
            sizes="(max-width:640px) calc(100vw - 2rem), 400px"
            alt="{{ product.media[1].alt | default: product.title | escape }}"
            loading="lazy"
            class="product-card__img product-card__img--hover img-zoom"
            aria-hidden="true">
        {%- endif -%}
      {%- else -%}
        <div class="img-placeholder" style="width:100%;height:100%;">
          <span>{{ product.title }}</span>
        </div>
      {%- endif -%}

      <!-- Badges -->
      <div class="product-card__badges">
        {%- if inquiry_only -%}
          <span class="badge badge--available">Available</span>
        {%- elsif product.available == false -%}
          <span class="badge badge--sold-out">{{ 'products.product.sold_out' | t }}</span>
        {%- elsif product.compare_at_price > product.price -%}
          <span class="badge badge--sale">{{ 'products.product.on_sale' | t }}</span>
        {%- endif -%}
      </div>
    </div>

    {%- unless inquiry_only -%}
      <!-- Info -->
      <div class="product-card__info">
        <p class="product-card__vendor eyebrow" itemprop="brand">{{ product.vendor }}</p>
        <h3 class="product-card__title serif-font" itemprop="name">{{ product.title }}</h3>
        <div class="product-card__price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
          {%- if product.compare_at_price > product.price -%}
            <span class="price price--sale">{{ product.price | money }}</span>
            <span class="price price--compare">{{ product.compare_at_price | money }}</span>
          {%- else -%}
            <span class="price" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
              {{ product.price | money }}
            </span>
          {%- endif -%}
          <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        </div>
      </div>
    {%- endunless -%}
  </a>

  <!-- Quick Add -->
  {%- if product.variants.size == 1 and product.available and inquiry_only == false -%}
    <form action="/cart/add" method="post" class="product-card__quick-add">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="btn-editorial btn-editorial--small">
        {{ 'products.product.add_to_cart' | t }}
      </button>
    </form>
  {%- elsif product.available and inquiry_only == false -%}
    <a href="{{ product.url }}" class="btn-editorial btn-editorial--small">
      {{ 'products.product.select_options' | t }}
    </a>
  {%- endif -%}
</div>
