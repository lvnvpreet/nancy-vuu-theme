<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;1,6..96,400&family=Manrope:wght@300;400&display=swap" rel="stylesheet">
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--color-cream,#faf8f5); }
    .password-page { text-align:center; padding:2rem; }
    .password-page h1 { font-family:'Bodoni Moda',serif; font-size:clamp(2rem,8vw,5rem); margin-bottom:1rem; }
    .password-page p  { font-family:'Manrope',sans-serif; font-weight:300; color:#888; margin-bottom:2rem; font-size:.875rem; letter-spacing:.05em; }
    .password-form input { font-family:'Manrope',sans-serif; border:1px solid #ddd; padding:12px 20px; width:100%; max-width:280px; margin-bottom:1rem; display:block; margin-left:auto; margin-right:auto; font-size:.8rem; letter-spacing:.05em; outline:none; }
    .password-form button { font-family:'Manrope',sans-serif; font-size:.65rem; letter-spacing:.25em; text-transform:uppercase; padding:14px 38px; border:1px solid #111; background:transparent; cursor:pointer; transition:background .3s,color .3s; }
    .password-form button:hover { background:#111; color:#fff; }
  </style>
</head>
<body>
  <div class="password-page">
    <h1>{{ shop.name }}</h1>
    <p>{{ 'general.password_page.coming_soon' | t: default: 'Something beautiful is coming.' }}</p>
    {{ content_for_layout }}
  </div>
</body>
</html>
