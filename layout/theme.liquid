<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_ink }}">

  {%- unless settings.type_header_font.system? -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {%- endunless -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <!-- Preconnect Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,600;1,6..96,400;1,6..96,600&family=Manrope:wght@200;300;400;500;600&display=swap" rel="stylesheet">

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>

  {{ content_for_header }}

  {%- liquid
    assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
    assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
    assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
  %}

  {% style %}
    {{ settings.type_body_font | font_face: font_display: 'swap' }}
    {{ body_font_bold | font_face: font_display: 'swap' }}
    {{ body_font_italic | font_face: font_display: 'swap' }}
    {{ body_font_bold_italic | font_face: font_display: 'swap' }}
    {{ settings.type_header_font | font_face: font_display: 'swap' }}

    :root {
      --color-ink:    {{ settings.color_ink }};
      --color-cream:  {{ settings.color_cream }};
      --color-greige: {{ settings.color_greige }};
      --color-accent: {{ settings.color_accent }};
      --font-serif:   'Bodoni Moda', serif;
      --font-sans:    'Manrope', sans-serif;
    }
  {% endstyle %}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.suffix | handle }}{% endif %}">

  <a class="skip-to-content-link visually-hidden" href="#MainContent">
    {{ 'general.accessibility.skip_to_content' | t }}
  </a>

  <!-- Scroll Progress Bar -->
  <div id="scroll-progress" aria-hidden="true"></div>

  {% section 'header' %}

  <main id="MainContent" class="content-for-layout" role="main" tabindex="-1" style="padding-top: 80px;">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <!-- NV Post-Submission Success Overlay -->
  <div id="nv-success-overlay" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(8,8,8,0.97); align-items:center; justify-content:center; padding:2rem;">
    <div id="nv-success-inner" style="background:#fff; max-width:600px; width:100%; padding:4rem 3rem; text-align:center; position:relative;">
      <button onclick="nvCloseSuccess()" style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;font-size:1.5rem;cursor:pointer;color:#888;">✕</button>
      <div style="width:8px;height:8px;background:#c5a059;border-radius:50%;margin:0 auto 1.5rem;"></div>
      <p id="nv-success-eyebrow" style="font-family:var(--font-sans);font-size:.55rem;letter-spacing:.5em;text-transform:uppercase;color:#c5a059;margin-bottom:1rem;"></p>
      <h2 id="nv-success-title" style="font-family:var(--font-serif);font-size:clamp(1.5rem,3vw,2.25rem);font-style:italic;margin-bottom:1.5rem;color:#111;"></h2>
      <p id="nv-success-body" style="font-family:var(--font-sans);font-size:.9rem;color:#555;line-height:1.9;margin-bottom:2.5rem;max-width:420px;margin-left:auto;margin-right:auto;"></p>
      <a id="nv-success-cta" href="#" style="display:inline-block;background:#111;color:#fff;padding:1.25rem 3rem;font-family:var(--font-sans);font-size:.65rem;font-weight:700;letter-spacing:.3em;text-transform:uppercase;text-decoration:none;border:1px solid #111;transition:all .35s ease;"></a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       EXECUTIVE DOSSIER MODAL — Maison Attaché Program
       ═══════════════════════════════════════════════════ -->
  <style>
    .nv-dossier-modal {
      position: fixed;
      inset: 0;
      z-index: 9998;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(12px);
      padding: 1.5rem;
      overflow-y: auto;
    }
    .nv-dossier-modal.active {
      display: flex;
    }
    .nv-dossier-inner {
      background: #fff;
      width: 100%;
      max-width: 580px;
      max-height: 92vh;
      overflow-y: auto;
      position: relative;
      padding: 3.5rem 3rem 3rem;
      text-align: center;
    }
    .nv-dossier-close {
      position: absolute;
      top: 1.25rem;
      right: 1.5rem;
      background: none;
      border: none;
      font-size: 1.1rem;
      cursor: pointer;
      color: #aaa;
      transition: color .2s ease;
      line-height: 1;
    }
    .nv-dossier-close:hover { color: #111; }
    .nv-dossier-eyebrow {
      font-family: var(--font-sans);
      font-size: .55rem;
      letter-spacing: .5em;
      text-transform: uppercase;
      color: #c5a059;
      margin-bottom: 1rem;
      display: block;
    }
    .nv-dossier-title {
      font-family: var(--font-serif);
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-style: italic;
      color: #111;
      margin-bottom: 1rem;
      line-height: 1.15;
    }
    .nv-dossier-desc {
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #666;
      line-height: 1.8;
      max-width: 380px;
      margin: 0 auto 1.5rem;
    }
    .nv-dossier-divider {
      width: 2.5rem;
      height: 1px;
      background: #c5a059;
      margin: 0 auto 2rem;
    }
    /* Form fields */
    .nv-dossier-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 2rem;
      text-align: left;
    }
    .nv-dossier-field {
      margin-bottom: 1.75rem;
      text-align: left;
    }
    .nv-dossier-field.full {
      grid-column: span 2;
    }
    .nv-dossier-label {
      display: block;
      font-family: var(--font-sans);
      font-size: .55rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: .5rem;
    }
    .nv-dossier-input,
    .nv-dossier-textarea {
      width: 100%;
      border: none;
      border-bottom: 1px solid #e5e5e5;
      padding: .75rem 0;
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #111;
      background: transparent;
      outline: none;
      box-sizing: border-box;
      transition: border-color .3s ease;
    }
    .nv-dossier-input:focus,
    .nv-dossier-textarea:focus {
      border-bottom-color: #c5a059;
    }
    .nv-dossier-input::placeholder,
    .nv-dossier-textarea::placeholder {
      color: #ccc;
      font-size: .75rem;
    }
    .nv-dossier-field .nv-phone-wrap {
      align-items: center;
    }
    .nv-dossier-field .nv-phone-wrap__code {
      border-top: none !important;
      border-left: none !important;
      border-right: none !important;
      border-bottom: 1px solid #e5e5e5 !important;
      padding: .75rem 0 !important;
      margin: 0 !important;
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #111;
      background: transparent;
    }
    .nv-dossier-field .nv-phone-wrap__input {
      border-top: none !important;
      border-left: none !important;
      border-right: none !important;
      border-bottom: 1px solid #e5e5e5 !important;
      padding: .75rem 0 .75rem 14px !important;
      margin: 0 !important;
      background: transparent;
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #111;
      outline: none;
      box-sizing: border-box;
      transition: border-color .3s ease;
    }
    .nv-dossier-field .nv-phone-wrap__input::placeholder {
      color: #ccc;
      font-size: .75rem;
    }
    .nv-dossier-field .nv-phone-wrap__code:focus,
    .nv-dossier-field .nv-phone-wrap__input:focus {
      border-bottom-color: #c5a059 !important;
    }
    .nv-dossier-textarea {
      resize: none;
      min-height: 80px;
    }
    /* Social 3-col */
    .nv-dossier-social {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0 1.5rem;
      grid-column: span 2;
      text-align: left;
      margin-bottom: 1.75rem;
    }
    /* Checkboxes */
    .nv-dossier-check-group {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .75rem 1.5rem;
      grid-column: span 2;
      margin-bottom: 1.75rem;
      text-align: left;
    }
    .nv-dossier-check-label {
      font-family: var(--font-sans);
      font-size: .75rem;
      color: #444;
      display: flex;
      align-items: center;
      gap: .6rem;
      cursor: pointer;
    }
    .nv-dossier-check-label input[type="checkbox"] {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      accent-color: #c5a059;
    }
    /* Radio */
    .nv-dossier-radio-group {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      grid-column: span 2;
      margin-bottom: 1.75rem;
      text-align: left;
    }
    .nv-dossier-radio-label {
      font-family: var(--font-sans);
      font-size: .75rem;
      color: #444;
      display: flex;
      align-items: center;
      gap: .5rem;
      cursor: pointer;
    }
    .nv-dossier-radio-label input[type="radio"] {
      accent-color: #c5a059;
    }
    /* Legal */
    .nv-dossier-legal {
      grid-column: span 2;
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      margin-bottom: 2rem;
      text-align: left;
    }
    .nv-dossier-legal input[type="checkbox"] {
      margin-top: 3px;
      flex-shrink: 0;
      accent-color: #111;
    }
    .nv-dossier-legal span {
      font-family: var(--font-sans);
      font-size: .65rem;
      color: #888;
      line-height: 1.7;
    }
    /* Submit */
    .nv-dossier-submit {
      grid-column: span 2;
      width: 100%;
      background: #111;
      color: #fff;
      border: 1px solid #111;
      padding: 1.4rem;
      font-family: var(--font-sans);
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .35em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .35s ease, color .35s ease;
    }
    .nv-dossier-submit:hover {
      background: transparent;
      color: #111;
    }
    .nv-dossier-success {
      padding: 3rem 1rem;
      text-align: center;
    }
    .nv-dossier-success h3 {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.75rem;
      color: #111;
      margin-bottom: 1rem;
    }
    .nv-dossier-success p {
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #666;
      line-height: 1.8;
    }
    .nv-dossier-errors {
      color: #c00;
      font-family: var(--font-sans);
      font-size: .75rem;
      margin-bottom: 1rem;
      grid-column: span 2;
      text-align: left;
    }
    @media (max-width: 640px) {
      .nv-dossier-inner { padding: 2.5rem 1.5rem 2rem; }
      .nv-dossier-grid { grid-template-columns: 1fr; }
      .nv-dossier-field.full { grid-column: span 1; }
      .nv-dossier-check-group { grid-template-columns: 1fr; grid-column: span 1; }
      .nv-dossier-radio-group { grid-column: span 1; }
      .nv-dossier-social { grid-template-columns: 1fr; grid-column: span 1; }
      .nv-dossier-legal { grid-column: span 1; }
      .nv-dossier-submit { grid-column: span 1; }
    }
  </style>

  <div id="nv-dossier-modal" class="nv-dossier-modal" aria-modal="true" role="dialog">
    <div class="nv-dossier-inner">
      <button class="nv-dossier-close" onclick="nvCloseDossier()" aria-label="Close">✕</button>

      <div id="nv-dossier-form-wrap">
        <span class="nv-dossier-eyebrow">The House of Vuu</span>
        <h2 class="nv-dossier-title">Executive Dossier Request</h2>
        <p class="nv-dossier-desc">Access the blueprints to your luxury empire. Please provide your professional details to receive the confidential House of Vuu dossier.</p>
        <div class="nv-dossier-divider"></div>

        <form id="nv-dossier-form">
          <input type="hidden" name="form_type" value="contact">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="maison-attache-dossier">

          <div class="nv-dossier-grid">

            <!-- Row 1: Name + Title -->
            <div class="nv-dossier-field">
              <label class="nv-dossier-label">Full Name</label>
              <input type="text" name="contact[name]" class="nv-dossier-input" placeholder="Your full name" required>
            </div>
            <div class="nv-dossier-field">
              <label class="nv-dossier-label">Professional Title & Firm</label>
              <input type="text" name="contact[firm]" class="nv-dossier-input" placeholder="CEO, Acme Corp">
            </div>

            <!-- Row 2: LinkedIn + Territory -->
            <div class="nv-dossier-field">
              <label class="nv-dossier-label">LinkedIn Profile URL</label>
              <input type="url" name="contact[linkedin]" class="nv-dossier-input" placeholder="linkedin.com/in/...">
            </div>
            <div class="nv-dossier-field">
              <label class="nv-dossier-label">Primary Market / Territory</label>
              <input type="text" name="contact[territory]" class="nv-dossier-input" placeholder="e.g. California, UAE">
            </div>

            <!-- Row 3: Email (full width) -->
            <div class="nv-dossier-field full">
              <label class="nv-dossier-label">Email Address</label>
              <input type="email" name="contact[email]" class="nv-dossier-input" placeholder="your@email.com" required>
            </div>

            <!-- Row 4: Phone Number (full width) -->
            <div class="nv-dossier-field full">
              <label class="nv-dossier-label">Phone Number</label>
              {%- render 'phone-field', placeholder: 'Phone Number', input_class: 'nv-dossier-input' -%}
            </div>

            <!-- Social Media — 3 col -->
            <div class="nv-dossier-social">
              <div class="nv-dossier-field">
                <label class="nv-dossier-label">Instagram</label>
                <input type="text" name="contact[instagram]" class="nv-dossier-input" placeholder="@handle">
              </div>
              <div class="nv-dossier-field">
                <label class="nv-dossier-label">Facebook</label>
                <input type="text" name="contact[facebook]" class="nv-dossier-input" placeholder="@handle">
              </div>
              <div class="nv-dossier-field">
                <label class="nv-dossier-label">TikTok</label>
                <input type="text" name="contact[tiktok]" class="nv-dossier-input" placeholder="@handle">
              </div>
            </div>

            <!-- Client Portfolio Checkboxes -->
            <div style="grid-column:span 2; text-align:left; margin-bottom:.75rem;">
              <label class="nv-dossier-label">Current Client Portfolio Profile</label>
            </div>
            <div class="nv-dossier-check-group">
              <label class="nv-dossier-check-label">
                <input type="checkbox" name="contact[portfolio]" value="High-Net-Worth Individuals">
                High-Net-Worth Individuals
              </label>
              <label class="nv-dossier-check-label">
                <input type="checkbox" name="contact[portfolio]" value="Luxury Wedding & Event Industry">
                Luxury Wedding &amp; Event Industry
              </label>
              <label class="nv-dossier-check-label">
                <input type="checkbox" name="contact[portfolio]" value="Corporate Executives">
                Corporate Executives
              </label>
              <label class="nv-dossier-check-label">
                <input type="checkbox" name="contact[portfolio]" value="Public Figures / Talent">
                Public Figures / Talent
              </label>
            </div>

            <!-- Q1: Vision -->
            <div class="nv-dossier-field full">
              <label class="nv-dossier-label">What is your vision as a Maison Attaché, and what compels you to represent the House of Vuu?</label>
              <textarea name="contact[vision]" class="nv-dossier-textarea" placeholder="Share your vision..."></textarea>
            </div>

            <!-- Q2: Alignment -->
            <div class="nv-dossier-field full">
              <label class="nv-dossier-label">How does your vision align with restoring identity, elevating humanity and ending trafficking?</label>
              <textarea name="contact[alignment]" class="nv-dossier-textarea" placeholder="Describe your alignment..."></textarea>
            </div>

            <!-- Partnership Track Radios -->
            <div style="grid-column:span 2; text-align:left; margin-bottom:.75rem;">
              <label class="nv-dossier-label">Intent for Partnership Track</label>
            </div>
            <div class="nv-dossier-radio-group">
              <label class="nv-dossier-radio-label">
                <input type="radio" name="contact[partnership_track]" value="Maison Attaché">
                Maison Attaché
              </label>
              <label class="nv-dossier-radio-label">
                <input type="radio" name="contact[partnership_track]" value="Design Partner">
                Design Partner
              </label>
              <label class="nv-dossier-radio-label">
                <input type="radio" name="contact[partnership_track]" value="Referral Advocate">
                Referral Advocate
              </label>
            </div>

            <!-- Legal -->
            <div class="nv-dossier-legal">
              <input type="checkbox" id="dossier-legal" required>
              <span>I understand that the Maison Attaché program is highly selective and that the Executive Dossier contains proprietary financial structures of Nancy Vuu Inc.</span>
            </div>

            <!-- Errors -->
            <div class="nv-dossier-errors" id="nv-dossier-errors" style="display:none;"></div>

            <!-- Submit -->
            <button type="submit" class="nv-dossier-submit">Request Confidential Access</button>

          </div>
        </form>
      </div>

      <!-- Success State -->
      <div id="nv-dossier-success" class="nv-dossier-success" style="display:none;">
        <div style="width:8px;height:8px;background:#c5a059;border-radius:50%;margin:0 auto 1.5rem;"></div>
        <h3>Your Dossier Request<br>Has Been Secured.</h3>
        <p>Our executive team will conduct a confidential review of your application. You will receive the House of Vuu Executive Dossier upon approval. Thank you for your interest in the Maison Attaché Program.</p>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       GENERIC INQUIRY MODAL — Academy CTAs
       ═══════════════════════════════════════════════════ -->
  <style>
    #nv-inquiry-modal .nv-phone-wrap {
      align-items: center;
    }
    #nv-inquiry-modal .nv-phone-wrap__code {
      border-top: none !important;
      border-left: none !important;
      border-right: none !important;
      border-bottom: 1px solid #e5e5e5 !important;
      padding: .75rem 0 !important;
      margin: 0 !important;
      background: transparent;
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #111;
    }
    #nv-inquiry-modal .nv-phone-wrap__input,
    #nv-inquiry-modal .nv-inquiry-phone-input {
      border: none !important;
      border-bottom: 1px solid #e5e5e5 !important;
      padding: .75rem 0 .75rem 14px !important;
      margin: 0 !important;
      background: transparent;
      font-family: var(--font-sans);
      font-size: .8rem;
      color: #111;
      outline: none;
      box-sizing: border-box;
      box-shadow: none !important;
      -webkit-appearance: none;
      appearance: none;
    }
    #nv-inquiry-modal .nv-phone-wrap__code:focus,
    #nv-inquiry-modal .nv-phone-wrap__input:focus,
    #nv-inquiry-modal .nv-inquiry-phone-input:focus {
      border-bottom-color: #111 !important;
    }
  </style>

  <div id="nv-inquiry-modal" style="display:none;position:fixed;inset:0;z-index:9997;align-items:center;justify-content:center;background:rgba(10,10,10,0.85);backdrop-filter:blur(12px);padding:1.5rem;">
    <div style="background:#fff;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;position:relative;padding:3.5rem 3rem 3rem;text-align:center;">
      <button onclick="nvCloseInquiry()" style="position:absolute;top:1.25rem;right:1.5rem;background:none;border:none;font-size:1.1rem;cursor:pointer;color:#aaa;">✕</button>

      <div id="nv-inquiry-form-wrap">
        <span id="nv-inquiry-eyebrow" style="font-family:var(--font-sans);font-size:.55rem;letter-spacing:.5em;text-transform:uppercase;color:#c5a059;margin-bottom:1rem;display:block;">{{ settings.inquiry_modal_eyebrow | default: 'Private Product Inquiry' }}</span>
        <h2 id="nv-inquiry-title" style="font-family:var(--font-serif);font-size:clamp(1.5rem,3vw,2.25rem);font-style:italic;color:#111;margin-bottom:1rem;">{{ settings.inquiry_modal_title | default: 'Request Availability' }}</h2>
        <p id="nv-inquiry-desc" style="font-family:var(--font-sans);font-size:.8rem;color:#666;line-height:1.8;max-width:380px;margin:0 auto 1.5rem;">{{ settings.inquiry_modal_desc | default: 'Submit your details and our atelier concierge will contact you with pricing, availability, and customization options for this piece.' }}</p>
        <div style="width:2.5rem;height:1px;background:#c5a059;margin:0 auto 2rem;"></div>

        <form id="nv-inquiry-form" style="text-align:left;">
          <input type="hidden" name="form_type" value="contact">
          <input type="hidden" name="utf8" value="✓">
          <input id="nv-inquiry-tag" type="hidden" name="contact[tags]" value="academy-inquiry">
          <input id="nv-inquiry-product-title" type="hidden" name="contact[product_title]" value="">
          <input id="nv-inquiry-product-url" type="hidden" name="contact[product_url]" value="">
          <input id="nv-inquiry-product-variant" type="hidden" name="contact[product_variant]" value="">
          <input id="nv-inquiry-product-collection" type="hidden" name="contact[product_collection]" value="">

          <div id="nv-inquiry-product-field" style="display:none;margin-bottom:1.75rem;">
            <input id="nv-inquiry-product-display" type="text" readonly
              style="width:100%;border:none;border-bottom:1px solid #e5e5e5;padding:.75rem 0;font-family:var(--font-sans);font-size:.75rem;color:#666;background:transparent;outline:none;box-sizing:border-box;"
              value="">
          </div>

          <div style="margin-bottom:1.75rem;">
            <input type="text" name="contact[name]" placeholder="{{ settings.inquiry_modal_name_placeholder | default: 'FULL NAME' | escape }}" required
              style="width:100%;border:none;border-bottom:1px solid #e5e5e5;padding:.75rem 0;font-family:var(--font-sans);font-size:.8rem;color:#111;background:transparent;outline:none;box-sizing:border-box;">
          </div>
          <div style="margin-bottom:1.75rem;">
            <input type="email" name="contact[email]" placeholder="{{ settings.inquiry_modal_email_placeholder | default: 'EMAIL ADDRESS' | escape }}" required
              style="width:100%;border:none;border-bottom:1px solid #e5e5e5;padding:.75rem 0;font-family:var(--font-sans);font-size:.8rem;color:#111;background:transparent;outline:none;box-sizing:border-box;">
          </div>
          <div style="margin-bottom:1.75rem;">
            {%- render 'phone-field', placeholder: settings.inquiry_modal_phone_placeholder | default: 'PHONE NUMBER', input_class: 'nv-inquiry-phone-input' -%}
          </div>
          <div style="margin-bottom:1.75rem;">
            <input type="text" name="contact[company]" placeholder="{{ settings.inquiry_modal_company_placeholder | default: 'ORGANIZATION / COMPANY' | escape }}"
              style="width:100%;border:none;border-bottom:1px solid #e5e5e5;padding:.75rem 0;font-family:var(--font-sans);font-size:.8rem;color:#111;background:transparent;outline:none;box-sizing:border-box;">
          </div>
          <div style="margin-bottom:2rem;">
            <textarea name="contact[body]" placeholder="{{ settings.inquiry_modal_message_placeholder | default: 'BRIEFLY DESCRIBE YOUR INTEREST...' | escape }}" rows="4"
              style="width:100%;border:none;border-bottom:1px solid #e5e5e5;padding:.75rem 0;font-family:var(--font-sans);font-size:.8rem;color:#111;background:transparent;outline:none;box-sizing:border-box;resize:none;"></textarea>
          </div>
          <button type="submit"
            style="width:100%;background:#111;color:#fff;border:1px solid #111;padding:1.4rem;font-family:var(--font-sans);font-size:.65rem;font-weight:700;letter-spacing:.35em;text-transform:uppercase;cursor:pointer;">
            {{ settings.inquiry_modal_submit_label | default: 'Submit Inquiry' }}
          </button>
        </form>
      </div>

      <div id="nv-inquiry-success" style="display:none;padding:3rem 1rem;text-align:center;">
        <div style="width:8px;height:8px;background:#c5a059;border-radius:50%;margin:0 auto 1.5rem;"></div>
        <h3 style="font-family:var(--font-serif);font-style:italic;font-size:1.75rem;color:#111;margin-bottom:1rem;">{{ settings.inquiry_modal_success_title | default: 'Your Inquiry Has Been Received.' }}</h3>
        <p style="font-family:var(--font-sans);font-size:.8rem;color:#666;line-height:1.8;">{{ settings.inquiry_modal_success_body | default: 'Our team will be in touch shortly to discuss next steps.' }}</p>
      </div>
    </div>
  </div>
</body>
</html>
